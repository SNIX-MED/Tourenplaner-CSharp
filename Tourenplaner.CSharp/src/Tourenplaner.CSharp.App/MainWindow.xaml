<Window x:Class="Tourenplaner.CSharp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:components="clr-namespace:Tourenplaner.CSharp.App.Views.Components"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        mc:Ignorable="d"
        Title="GAWELA Tourenplaner"
        Width="1800"
        Height="1000"
        MinWidth="1220"
        MinHeight="860"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.WindowBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <CollectionViewSource x:Key="SidebarNavigationItemsView"
                              Source="{Binding SidebarNavigationItems}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName" />
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="GroupName" Direction="Ascending" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="16">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0" />
                <GradientStop Color="#EEF2FF" Offset="0.6" />
                <GradientStop Color="#F5F3FF" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarColumnWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,14,0"
                    Padding="14"
                    Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Style="{StaticResource FlatCardStyle}"
                    Background="{DynamicResource Brush.SidebarBackground}">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Margin="0,2,0,10"
                            Padding="14"
                            CornerRadius="14"
                            Background="{DynamicResource Brush.SidebarHeaderBackground}"
                            BorderBrush="{DynamicResource Brush.BorderSoft}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontSize="33" FontWeight="SemiBold" Text="GAWELA" />
                            <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Tourenplaner" />
                        </StackPanel>
                    </Border>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                        <TextBlock Margin="4,8,0,0" FontSize="11" Foreground="{DynamicResource Brush.TextSubtle}" Text="(c) GAWELA" />
                    </StackPanel>

                    <ListBox Margin="0,2,0,0"
                             ItemsSource="{Binding Source={StaticResource SidebarNavigationItemsView}}"
                             SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}">
                        <ListBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="6,12,6,4"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="{Binding Name}" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                                <GroupStyle.Panel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </GroupStyle.Panel>
                            </GroupStyle>
                        </ListBox.GroupStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <components:DashboardTopBar Grid.Row="0" Margin="0,0,0,4" />

                <Border Grid.Row="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
                            <Setter Property="Padding" Value="14" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMapSectionActive}" Value="True">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="Effect" Value="{x:Null}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ContentControl Content="{Binding CurrentSection}" Style="{StaticResource SectionFadeInContentStyle}" />
                </Border>
            </Grid>
        </Grid>

        <Popup x:Name="ToastPopup"
               IsOpen="{Binding IsToastVisible, Mode=OneWay}"
               Placement="Custom"
               PlacementTarget="{Binding ElementName=RootGrid}"
               CustomPopupPlacementCallback="ToastPopup_Placement"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="Fade">
            <Border Padding="16,14"
                    MinWidth="340"
                    MaxWidth="560"
                    Background="{DynamicResource Brush.Card}"
                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Accent}"
                               Text="&#xE946;" />
                    <TextBlock Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               Text="{Binding ToastMessage}" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>

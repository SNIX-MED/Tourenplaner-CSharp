<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Accent">#800080</Color>
    <Color x:Key="Color.AccentHover">#660066</Color>
    <Color x:Key="Color.Success">#16A34A</Color>
    <Color x:Key="Color.SuccessHover">#15803D</Color>
    <Color x:Key="Color.DarkButton">#374151</Color>
    <Color x:Key="Color.DarkButtonHover">#1F2937</Color>
    <Color x:Key="Color.Danger">#DC2626</Color>
    <Color x:Key="Color.DangerHover">#B91C1C</Color>

    <Color x:Key="Color.TextPrimary">#0F172A</Color>
    <Color x:Key="Color.TextMuted">#52637A</Color>
    <Color x:Key="Color.TextSubtle">#94A3B8</Color>
    <Color x:Key="Color.Focus">#8B5CF6</Color>

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="{StaticResource Color.SuccessHover}" />
    <SolidColorBrush x:Key="Brush.DarkButton" Color="{StaticResource Color.DarkButton}" />
    <SolidColorBrush x:Key="Brush.DarkButtonHover" Color="{StaticResource Color.DarkButtonHover}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />
    <SolidColorBrush x:Key="Brush.DangerHover" Color="{StaticResource Color.DangerHover}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
    <SolidColorBrush x:Key="Brush.TextSubtle" Color="{StaticResource Color.TextSubtle}" />
    <SolidColorBrush x:Key="Brush.Focus" Color="{StaticResource Color.Focus}" />

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#F6F7FB" />
    <SolidColorBrush x:Key="Brush.WindowBackgroundSoft" Color="#EEF2FF" />
    <SolidColorBrush x:Key="Brush.SidebarBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.SidebarHeaderBackground" Color="#F5F3FF" />
    <SolidColorBrush x:Key="Brush.Card" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.CardSoft" Color="#F8FAFC" />
    <SolidColorBrush x:Key="Brush.CardMuted" Color="#F1F5F9" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#D7DFEA" />
    <SolidColorBrush x:Key="Brush.BorderSoft" Color="#D7E0EC" />
    <SolidColorBrush x:Key="Brush.GlassSurface" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.GlassSurfaceStrong" Color="#FBFCFF" />
    <SolidColorBrush x:Key="Brush.GlassSurfaceSoft" Color="#F7F8FC" />
    <SolidColorBrush x:Key="Brush.GlassStroke" Color="#E6EAF4" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#EDE9FE" />
    <SolidColorBrush x:Key="Brush.AccentSurface" Color="#F5F3FF" />
    <SolidColorBrush x:Key="Brush.SuccessSoft" Color="#DCFCE7" />
    <SolidColorBrush x:Key="Brush.DangerSoft" Color="#FEE2E2" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#B7C3D4" />
    <SolidColorBrush x:Key="Brush.InputBackgroundDisabled" Color="#F8FAFC" />

    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.ButtonForeground" Color="#0F172A" />
    <SolidColorBrush x:Key="Brush.ButtonBorder" Color="#CBD5E1" />
    <SolidColorBrush x:Key="Brush.ButtonHoverBackground" Color="#F8FAFC" />

    <SolidColorBrush x:Key="Brush.TableBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.TableRow" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.TableAltRow" Color="#F8FAFC" />
    <SolidColorBrush x:Key="Brush.TableGrid" Color="#D4DEEA" />
    <SolidColorBrush x:Key="Brush.RowHover" Color="#EEF2FF" />
    <SolidColorBrush x:Key="Brush.RowSelected" Color="#D6ECFF" />

    <SolidColorBrush x:Key="Brush.SidebarItemBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.SidebarItemBorder" Color="#E2E8F0" />
    <SolidColorBrush x:Key="Brush.SidebarItemHover" Color="#F8FAFC" />
    <SolidColorBrush x:Key="Brush.SidebarItemSelected" Color="#800080" />

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Accent">#8B0A9E</Color>
    <Color x:Key="Color.AccentHover">#760889</Color>
    <Color x:Key="Color.Success">#16A34A</Color>
    <Color x:Key="Color.SuccessHover">#15803D</Color>
    <Color x:Key="Color.DarkButton">#2E3B52</Color>
    <Color x:Key="Color.DarkButtonHover">#223146</Color>

    <Color x:Key="Color.TextPrimary">#111827</Color>
    <Color x:Key="Color.TextMuted">#6B7280</Color>

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="{StaticResource Color.SuccessHover}" />
    <SolidColorBrush x:Key="Brush.DarkButton" Color="{StaticResource Color.DarkButton}" />
    <SolidColorBrush x:Key="Brush.DarkButtonHover" Color="{StaticResource Color.DarkButtonHover}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#EFF1F4" />
    <SolidColorBrush x:Key="Brush.Card" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.CardSoft" Color="#F7F8FB" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#D8DEE7" />
    <SolidColorBrush x:Key="Brush.BorderSoft" Color="#E6EAF0" />
    <SolidColorBrush x:Key="Brush.GlassSurface" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.GlassSurfaceStrong" Color="#F7F8FB" />
    <SolidColorBrush x:Key="Brush.GlassStroke" Color="#E6EAF0" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#F3E8FF" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#CCD4E0" />

    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.ButtonForeground" Color="#111827" />
    <SolidColorBrush x:Key="Brush.ButtonBorder" Color="#CDD5E1" />

    <SolidColorBrush x:Key="Brush.TableBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.TableRow" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.TableAltRow" Color="#F9FAFB" />
    <SolidColorBrush x:Key="Brush.TableGrid" Color="#E5E7EB" />
    <SolidColorBrush x:Key="Brush.RowHover" Color="#EEF2FF" />
    <SolidColorBrush x:Key="Brush.RowSelected" Color="#E0E7FF" />

    <SolidColorBrush x:Key="Brush.SidebarItemBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.SidebarItemBorder" Color="#D7DEE8" />
    <SolidColorBrush x:Key="Brush.SidebarItemHover" Color="#F3F4F6" />

</ResourceDictionary>

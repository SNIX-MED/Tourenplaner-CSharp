<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Accent">#9F28B7</Color>
    <Color x:Key="Color.AccentHover">#B63AD1</Color>
    <Color x:Key="Color.Success">#22C55E</Color>
    <Color x:Key="Color.SuccessHover">#16A34A</Color>
    <Color x:Key="Color.DarkButton">#334155</Color>
    <Color x:Key="Color.DarkButtonHover">#1E293B</Color>

    <Color x:Key="Color.TextPrimary">#E5E7EB</Color>
    <Color x:Key="Color.TextMuted">#9CA3AF</Color>

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="{StaticResource Color.SuccessHover}" />
    <SolidColorBrush x:Key="Brush.DarkButton" Color="{StaticResource Color.DarkButton}" />
    <SolidColorBrush x:Key="Brush.DarkButtonHover" Color="{StaticResource Color.DarkButtonHover}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#0F172A" />
    <SolidColorBrush x:Key="Brush.Card" Color="#111827" />
    <SolidColorBrush x:Key="Brush.CardSoft" Color="#1F2937" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#334155" />
    <SolidColorBrush x:Key="Brush.BorderSoft" Color="#374151" />
    <SolidColorBrush x:Key="Brush.GlassSurface" Color="#111827" />
    <SolidColorBrush x:Key="Brush.GlassSurfaceStrong" Color="#1F2937" />
    <SolidColorBrush x:Key="Brush.GlassStroke" Color="#374151" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#312E81" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#111827" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#475569" />

    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="#1F2937" />
    <SolidColorBrush x:Key="Brush.ButtonForeground" Color="#E5E7EB" />
    <SolidColorBrush x:Key="Brush.ButtonBorder" Color="#4B5563" />

    <SolidColorBrush x:Key="Brush.TableBackground" Color="#111827" />
    <SolidColorBrush x:Key="Brush.TableRow" Color="#0F172A" />
    <SolidColorBrush x:Key="Brush.TableAltRow" Color="#111827" />
    <SolidColorBrush x:Key="Brush.TableGrid" Color="#374151" />
    <SolidColorBrush x:Key="Brush.RowHover" Color="#312E81" />
    <SolidColorBrush x:Key="Brush.RowSelected" Color="#4338CA" />

    <SolidColorBrush x:Key="Brush.SidebarItemBackground" Color="#111827" />
    <SolidColorBrush x:Key="Brush.SidebarItemBorder" Color="#374151" />
    <SolidColorBrush x:Key="Brush.SidebarItemHover" Color="#1F2937" />

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Accent">#800080</Color>
    <Color x:Key="Color.AccentHover">#660066</Color>
    <Color x:Key="Color.Success">#22C55E</Color>
    <Color x:Key="Color.SuccessHover">#16A34A</Color>
    <Color x:Key="Color.DarkButton">#334155</Color>
    <Color x:Key="Color.DarkButtonHover">#1E293B</Color>

    <Color x:Key="Color.TextPrimary">#F3F4F6</Color>
    <Color x:Key="Color.TextMuted">#CBD5E1</Color>

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{StaticResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="{StaticResource Color.SuccessHover}" />
    <SolidColorBrush x:Key="Brush.DarkButton" Color="{StaticResource Color.DarkButton}" />
    <SolidColorBrush x:Key="Brush.DarkButtonHover" Color="{StaticResource Color.DarkButtonHover}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#0B1220" />
    <SolidColorBrush x:Key="Brush.Card" Color="#111A2B" />
    <SolidColorBrush x:Key="Brush.CardSoft" Color="#1A2436" />
    <SolidColorBrush x:Key="Brush.BorderStrong" Color="#475569" />
    <SolidColorBrush x:Key="Brush.BorderSoft" Color="#334155" />
    <SolidColorBrush x:Key="Brush.GlassSurface" Color="#111A2B" />
    <SolidColorBrush x:Key="Brush.GlassSurfaceStrong" Color="#1A2436" />
    <SolidColorBrush x:Key="Brush.GlassSurfaceSoft" Color="#1A2436" />
    <SolidColorBrush x:Key="Brush.GlassStroke" Color="#334155" />
    <SolidColorBrush x:Key="Brush.AccentSoft" Color="#3B2A58" />

    <SolidColorBrush x:Key="Brush.InputBackground" Color="#162033" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#5B6B80" />

    <SolidColorBrush x:Key="Brush.ButtonBackground" Color="#1A2436" />
    <SolidColorBrush x:Key="Brush.ButtonForeground" Color="#F3F4F6" />
    <SolidColorBrush x:Key="Brush.ButtonBorder" Color="#5B6B80" />

    <SolidColorBrush x:Key="Brush.TableBackground" Color="#111A2B" />
    <SolidColorBrush x:Key="Brush.TableRow" Color="#162033" />
    <SolidColorBrush x:Key="Brush.TableAltRow" Color="#1A2436" />
    <SolidColorBrush x:Key="Brush.TableGrid" Color="#334155" />
    <SolidColorBrush x:Key="Brush.RowHover" Color="#22314A" />
    <SolidColorBrush x:Key="Brush.RowSelected" Color="#3B2A58" />

    <SolidColorBrush x:Key="Brush.SidebarItemBackground" Color="#111A2B" />
    <SolidColorBrush x:Key="Brush.SidebarItemBorder" Color="#334155" />
    <SolidColorBrush x:Key="Brush.SidebarItemHover" Color="#1A2436" />

</ResourceDictionary>

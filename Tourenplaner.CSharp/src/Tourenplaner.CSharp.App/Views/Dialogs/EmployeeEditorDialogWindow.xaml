<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.EmployeeEditorDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mitarbeiter"
        Width="540"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="10" Style="{StaticResource FlatCardStyle}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="34" FontWeight="Bold" Text="Mitarbeiter" />

            <StackPanel Grid.Row="1" Margin="0,14,0,0">
                <TextBlock FontWeight="SemiBold" Text="Name *" />
                <TextBox Margin="0,6,0,0"
                         Height="38"
                         ToolTip="Name"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <TextBlock FontWeight="SemiBold" Text="Kürzel" />
                <TextBox Margin="0,6,0,0"
                         Height="38"
                         ToolTip="Kürzel"
                         Text="{Binding ShortCode, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                <TextBlock FontWeight="SemiBold" Text="Telefon" />
                <TextBox Margin="0,6,0,0"
                         Height="38"
                         ToolTip="Telefon"
                         PreviewTextInput="PhoneTextBox_PreviewTextInput"
                         DataObject.Pasting="PhoneTextBox_OnPasting"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <CheckBox Grid.Row="4"
                      Margin="0,14,0,0"
                      Content="Mitarbeiter ist aktiv"
                      IsChecked="{Binding Active}" />

            <Grid Grid.Row="5" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Height="40"
                        Margin="0,0,8,0"
                        Content="Abbrechen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnCancelClicked" />

                <Button Grid.Column="1"
                        Height="40"
                        Margin="8,0,0,0"
                        Content="Speichern"
                        Style="{StaticResource SuccessButtonStyle}"
                        IsDefault="True"
                        Click="OnSaveClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>

<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.EmployeeEditorDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Tourenplaner.CSharp.App.Views.Controls"
        Title="Mitarbeiter"
        Width="540"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Border Margin="10" Style="{StaticResource FlatCardStyle}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="34" FontWeight="Bold" Text="Mitarbeiter" />
                <Button Grid.Column="1"
                        Width="36"
                        Height="36"
                        Margin="12,0,0,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        ToolTip="Als Favorit markieren"
                        Click="OnFavoriteClicked">
                    <TextBlock FontSize="24"
                               Text="&#x2605;"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                        <Setter Property="Foreground" Value="#D4A017" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,14,0,0">
                <TextBlock FontWeight="SemiBold" Text="Name *" />
                <TextBox Margin="0,6,0,0"
                         Height="38"
                         ToolTip="Name"
                         Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <TextBlock FontWeight="SemiBold" Text="Kürzel" />
                <TextBox Margin="0,6,0,0"
                         Height="38"
                         ToolTip="Kürzel"
                         Text="{Binding ShortCode, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                <TextBlock FontWeight="SemiBold" Text="Telefon" />
                <TextBox Margin="0,6,0,0"
                         Height="38"
                         ToolTip="Telefon"
                         PreviewTextInput="PhoneTextBox_PreviewTextInput"
                         DataObject.Pasting="PhoneTextBox_OnPasting"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,14,0,0">
                <CheckBox Content="Programmprofil aktivieren (Benutzer-Auswahl)"
                          IsChecked="{Binding HasProgramProfile}" />
            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <CheckBox Content="Abwesenheit eintragen"
                          IsChecked="{Binding RegisterAbsence}" />
                <Grid Margin="0,8,0,0"
                      Visibility="{Binding RegisterAbsence, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock FontWeight="SemiBold" Text="Von (DD.MM.YYYY)" />
                        <controls:ModernDatePickerField Margin="0,6,0,0"
                                                        SelectedDateText="{Binding AbsenceStartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock FontWeight="SemiBold" Text="Bis (DD.MM.YYYY)" />
                        <controls:ModernDatePickerField Margin="0,6,0,0"
                                                        SelectedDateText="{Binding AbsenceEndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Grid Grid.Row="8" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="110"
                        Height="40"
                        Margin="0,0,12,0"
                        Content="Löschen"
                        Style="{StaticResource DangerOutlineButtonStyle}"
                        Visibility="{Binding HasExistingEntry, Converter={StaticResource BoolToVisibilityConverter}}"
                        Click="OnDeleteClicked" />

                <Button Grid.Column="2"
                        Width="120"
                        Height="40"
                        Margin="0,0,8,0"
                        Content="Abbrechen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnCancelClicked" />

                <Button Grid.Column="3"
                        Width="120"
                        Height="40"
                        Content="Speichern"
                        Style="{StaticResource SuccessButtonStyle}"
                        IsDefault="True"
                        Click="OnSaveClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>

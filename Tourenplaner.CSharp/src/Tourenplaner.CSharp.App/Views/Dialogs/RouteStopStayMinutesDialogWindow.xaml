<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.RouteStopStayMinutesDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stopp bearbeiten"
        Width="460"
        Height="560"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid MinHeight="470">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Stoppdaten bearbeiten" />

                <TextBlock Grid.Row="1"
                           Margin="0,10,0,0"
                           FontWeight="SemiBold"
                           Text="Aufenthaltszeit (Minuten)" />
                <ComboBox Grid.Row="2"
                          Margin="0,4,0,0"
                          Height="34"
                          ItemsSource="{Binding MinuteOptions}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="DisplayText"
                          SelectedValue="{Binding SelectedMinutes, Mode=TwoWay}" />

                <TextBlock Grid.Row="3"
                           Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="Avisierungsstatus">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowAvisoStatus}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ComboBox Grid.Row="4"
                          Margin="0,4,0,0"
                          Height="34"
                          ItemsSource="{Binding AvisoStatusOptions}"
                          SelectedItem="{Binding SelectedAvisoStatus, Mode=TwoWay}">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowAvisoStatus}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <TextBlock Grid.Row="5"
                           Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="Info für Mitarbeiter">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowEmployeeInfo}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox Grid.Row="6"
                         Margin="0,4,0,0"
                         MinHeight="170"
                         VerticalAlignment="Stretch"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding EmployeeInfoText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowEmployeeInfo}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Grid Grid.Row="7" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Height="34"
                            Margin="0,0,8,0"
                            Content="Abbrechen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnCancelClicked" />
                    <Button Grid.Column="1"
                            Height="34"
                            Margin="8,0,0,0"
                            Content="Speichern"
                            Style="{StaticResource SuccessButtonStyle}"
                            Click="OnSaveClicked" />
                </Grid>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>

<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.RouteStopStayMinutesDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aufenthalt bearbeiten"
        Width="360"
        Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Geplante Aufenthaltszeit" />
            <TextBlock Grid.Row="1" Margin="0,8,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Bitte Aufenthaltszeit in Minuten auswählen." />
            <ComboBox Grid.Row="2"
                      Margin="0,12,0,0"
                      Height="34"
                      ItemsSource="{Binding MinuteOptions}"
                      SelectedItem="{Binding SelectedMinutes, Mode=TwoWay}" />

            <Grid Grid.Row="3" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Height="34"
                        Margin="0,0,8,0"
                        Content="Abbrechen"
                        Background="White"
                        Foreground="#0f172a"
                        BorderBrush="#cbd5e1"
                        BorderThickness="1"
                        Click="OnCancelClicked" />
                <Button Grid.Column="1" Height="34" Margin="8,0,0,0" Content="Speichern" Style="{StaticResource SuccessButtonStyle}" Click="OnSaveClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>

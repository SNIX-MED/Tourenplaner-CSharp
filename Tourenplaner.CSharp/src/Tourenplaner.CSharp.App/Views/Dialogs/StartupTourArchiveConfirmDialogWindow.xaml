<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.StartupTourArchiveConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vergangene Touren archivieren"
        Width="560"
        Height="290"
        MinWidth="520"
        MinHeight="270"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="42"
                        Height="42"
                        Margin="0,2,14,0"
                        VerticalAlignment="Top"
                        CornerRadius="21"
                        Background="{DynamicResource Brush.AccentSoft}"
                        BorderBrush="{DynamicResource Brush.BorderSoft}"
                        BorderThickness="1">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}"
                               Text="?" />
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="HeadlineTextBlock"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="15"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               TextWrapping="Wrap"
                               Text="Sollen diese inklusive Aufträge archiviert werden?" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="120"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Content="Nein"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnNoClicked" />
                <Button Width="185"
                        IsDefault="True"
                        Content="Ja, jetzt prüfen"
                        Style="{StaticResource SuccessButtonStyle}"
                        Click="OnYesClicked" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

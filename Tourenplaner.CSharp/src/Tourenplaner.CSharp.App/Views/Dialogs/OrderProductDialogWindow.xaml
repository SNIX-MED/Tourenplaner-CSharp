<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.OrderProductDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Produkt"
        Width="560"
        Height="620"
        MinWidth="520"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True">
                <StackPanel Margin="0,0,4,0">
                <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding Heading}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Produktname" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Lieferant (optional)" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding Supplier, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Menge" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Gewicht pro Stück (kg)" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding UnitWeightKgText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Masse (optional)" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding Dimensions, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Lieferstatus" />
                <ComboBox Margin="0,6,0,0"
                          Height="38"
                          ItemsSource="{Binding DeliveryStatusOptions}"
                          SelectedItem="{Binding SelectedDeliveryStatus, Mode=TwoWay}" />

                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Margin="0,0,8,0"
                        Content="Abbrechen"
                        Style="{StaticResource DarkButtonStyle}"
                        Click="OnCancelClicked" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Speichern"
                        Style="{StaticResource SuccessButtonStyle}"
                        Click="OnSaveClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>

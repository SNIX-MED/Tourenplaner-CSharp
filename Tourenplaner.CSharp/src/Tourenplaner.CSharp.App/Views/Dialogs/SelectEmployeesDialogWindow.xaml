<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.SelectEmployeesDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mitarbeiter für Tour wählen"
        Width="620"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="32" FontWeight="Bold" Text="Mitarbeiter für Tour wählen" />

            <Border Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource SoftCardStyle}" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Employees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,6,0,6"
                                          Content="{Binding Label}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock Grid.Row="2" Margin="0,12,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding SummaryText}" />

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="38" Margin="0,0,8,0" Content="Abbrechen" Style="{StaticResource SecondaryButtonStyle}" Click="OnCancelClicked" />
                <Button Grid.Column="1" Height="38" Margin="8,0,0,0" Content="Auswählen" Style="{StaticResource SuccessButtonStyle}" Click="OnSaveClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>

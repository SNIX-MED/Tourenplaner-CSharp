<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.ColorPickerDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Farbe waehlen"
        Width="760"
        Height="560"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Window.Resources>
        <Style x:Key="SwatchButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <Grid>
                                <Border Margin="6"
                                        Background="#22FFFFFF"
                                        CornerRadius="11"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Right"
                                        Width="14"
                                        Height="14"
                                        Visibility="Collapsed"
                                        x:Name="HighlightDot" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChannelTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="64" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Margin="14" Style="{StaticResource FlatCardStyle}" Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.TextPrimary}" />
                    <TextBlock x:Name="DescriptionTextBlock"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="18,0,0,0"
                        Padding="14,10"
                        VerticalAlignment="Top"
                        CornerRadius="18"
                        Background="{DynamicResource Brush.AccentSurface}"
                        BorderBrush="{DynamicResource Brush.GlassStroke}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="Aktuelle Auswahl" />
                        <TextBlock x:Name="SelectedHexBadgeTextBlock"
                                   Margin="0,4,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextPrimary}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="18"
                        CornerRadius="22"
                        Background="{DynamicResource Brush.GlassSurfaceStrong}"
                        BorderBrush="{DynamicResource Brush.GlassStroke}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   Text="Live-Vorschau" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="So wirkt die Farbe direkt im Interface." />

                        <Border x:Name="PreviewSwatch"
                                Height="160"
                                Margin="0,18,0,0"
                                CornerRadius="24"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1" />

                        <Border Margin="0,18,0,0"
                                Padding="16"
                                CornerRadius="18"
                                Background="{DynamicResource Brush.Card}">
                            <StackPanel>
                                <TextBlock x:Name="PreviewHeadingTextBlock"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextPrimary}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Beispiel fuer Marker, Badges und Hervorhebungen." />
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <Border x:Name="PreviewBadge"
                                            Padding="12,6"
                                            CornerRadius="999"
                                            Margin="0,0,8,0">
                                        <TextBlock Foreground="White"
                                                   FontWeight="SemiBold"
                                                   Text="Marker" />
                                    </Border>
                                    <Border x:Name="PreviewDot"
                                            Width="18"
                                            Height="18"
                                            CornerRadius="9"
                                            VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Padding="18"
                            CornerRadius="22"
                            Background="{DynamicResource Brush.GlassSurfaceStrong}"
                            BorderBrush="{DynamicResource Brush.GlassStroke}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       Text="Schnellauswahl" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Beliebte Farbakzente fuer den direkten Einstieg." />

                            <primitives:UniformGrid Margin="0,16,0,0" Columns="5">
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#A3A3A3" Tag="#A3A3A3" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#64748B" Tag="#64748B" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#0EA5E9" Tag="#0EA5E9" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#2563EB" Tag="#2563EB" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#7C3AED" Tag="#7C3AED" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#16A34A" Tag="#16A34A" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#22C55E" Tag="#22C55E" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#84CC16" Tag="#84CC16" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#EAB308" Tag="#EAB308" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#F59E0B" Tag="#F59E0B" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#FB7185" Tag="#FB7185" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#EF4444" Tag="#EF4444" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#DC2626" Tag="#DC2626" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#14B8A6" Tag="#14B8A6" Click="OnSwatchClicked" />
                                <Button Style="{StaticResource SwatchButtonStyle}" Background="#0F766E" Tag="#0F766E" Click="OnSwatchClicked" />
                            </primitives:UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,18,0,0"
                            Padding="18"
                            CornerRadius="22"
                            Background="{DynamicResource Brush.Card}"
                            BorderBrush="{DynamicResource Brush.GlassStroke}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                       Text="Feinabstimmung" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Passe die Farbe exakt mit RGB-Reglern an." />

                            <Grid Margin="0,18,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="86" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Rot" />
                                <Slider x:Name="RedSlider"
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="255"
                                        ValueChanged="OnChannelSliderValueChanged" />
                                <TextBox x:Name="RedValueTextBox"
                                         Grid.Row="0"
                                         Grid.Column="2"
                                         Margin="10,0,0,0"
                                         Style="{StaticResource ChannelTextBoxStyle}"
                                         TextChanged="OnChannelTextChanged" />

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Margin="0,12,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Gruen" />
                                <Slider x:Name="GreenSlider"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="0,12,0,0"
                                        Minimum="0"
                                        Maximum="255"
                                        ValueChanged="OnChannelSliderValueChanged" />
                                <TextBox x:Name="GreenValueTextBox"
                                         Grid.Row="1"
                                         Grid.Column="2"
                                         Margin="10,12,0,0"
                                         Style="{StaticResource ChannelTextBoxStyle}"
                                         TextChanged="OnChannelTextChanged" />

                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Margin="0,12,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Blau" />
                                <Slider x:Name="BlueSlider"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,12,0,0"
                                        Minimum="0"
                                        Maximum="255"
                                        ValueChanged="OnChannelSliderValueChanged" />
                                <TextBox x:Name="BlueValueTextBox"
                                         Grid.Row="2"
                                         Grid.Column="2"
                                         Margin="10,12,0,0"
                                         Style="{StaticResource ChannelTextBoxStyle}"
                                         TextChanged="OnChannelTextChanged" />

                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Margin="0,18,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Hex" />
                                <TextBox x:Name="HexTextBox"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,18,0,0"
                                         TextChanged="OnHexTextChanged" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,22,0,0">
                <Button Width="150"
                        Margin="0,0,10,0"
                        Content="Standardfarbe"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnResetClicked" />
                <Button Width="140"
                        Margin="0,0,10,0"
                        Content="Abbrechen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        IsCancel="True" />
                <Button Width="160"
                        Content="Uebernehmen"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="OnConfirmClicked" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

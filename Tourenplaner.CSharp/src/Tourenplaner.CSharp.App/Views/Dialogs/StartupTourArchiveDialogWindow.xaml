<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.StartupTourArchiveDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vergangene Tour archivieren"
        Width="960"
        Height="700"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="30" FontWeight="Bold" Text="Vergangene Tour archivieren" />
                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Text="Aktive Aufträge sind vorausgewählt. Haken entfernen, wenn ein Auftrag nicht archiviert werden soll." />
                </StackPanel>
                <Border Grid.Column="1"
                        Padding="12,6"
                        VerticalAlignment="Top"
                        CornerRadius="10"
                        Background="{DynamicResource Brush.SurfaceMuted}"
                        BorderBrush="{DynamicResource Brush.BorderSoft}"
                        BorderThickness="1">
                    <TextBlock x:Name="TourProgressTextBlock" FontSize="14" FontWeight="SemiBold" />
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Padding="12"
                    CornerRadius="12"
                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                    BorderThickness="1"
                    Background="{DynamicResource Brush.Card}">
                <StackPanel>
                    <TextBlock x:Name="TourTitleTextBlock" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="TourMetaTextBlock"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,14,0,0"
                    Style="{StaticResource SoftCardStyle}"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="SelectionHintTextBlock"
                               Margin="4,0,4,8"
                               FontWeight="SemiBold" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Orders}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Archivieren" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Auftragsnummer"
                                                Width="180"
                                                IsReadOnly="True"
                                                Binding="{Binding OrderId}" />
                            <DataGridTextColumn Header="Kunde"
                                                Width="200"
                                                IsReadOnly="True"
                                                Binding="{Binding Customer}" />
                            <DataGridTextColumn Header="Adresse"
                                                Width="*"
                                                IsReadOnly="True"
                                                Binding="{Binding Address}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3"
                        Margin="0,14,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="150"
                        Margin="0,0,8,0"
                        Content="Abbrechen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnCancelClicked" />
                <Button Width="170"
                        Margin="0,0,8,0"
                        Content="Tour überspringen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="OnSkipClicked" />
                <Button Width="210"
                        Content="Tour archivieren"
                        Style="{StaticResource SuccessButtonStyle}"
                        Click="OnArchiveClicked" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.CalendarManualEntryDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Tourenplaner.CSharp.App.Views.Controls"
        Title="Manuellen Eintrag hinzufügen"
        Width="560"
        Height="430"
        MinWidth="520"
        MinHeight="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="DialogHeadlineText"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="Manueller Kalendereintrag" />

            <ScrollViewer Grid.Row="1"
                          Margin="0,12,0,10"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock FontWeight="SemiBold" Text="Datum" />
                            <controls:ModernDatePickerField x:Name="EntryDatePicker"
                                                            Margin="0,4,0,0"
                                                            PlaceholderText="Datum auswählen" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Width="156">
                            <TextBlock FontWeight="SemiBold" Text="Zeit (optional)" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="EntryHourComboBox"
                                          Margin="0,0,4,0" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text=":" />
                                <ComboBox x:Name="EntryMinuteComboBox"
                                          Grid.Column="2"
                                          Margin="4,0,0,0" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Width="84" Margin="10,0,0,0">
                            <TextBlock FontWeight="SemiBold" Text="Farbe" />
                            <ComboBox x:Name="EntryColorComboBox"
                                      Width="72"
                                      Margin="0,4,0,0"
                                      HorizontalContentAlignment="Center"
                                      MaxDropDownHeight="240">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="18"
                                                Height="18"
                                                HorizontalAlignment="Center"
                                                CornerRadius="2"
                                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                                BorderThickness="1"
                                                Background="{Binding Hex}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock FontWeight="SemiBold" Text="Titel" />
                        <TextBox x:Name="EntryTitleTextBox"
                                 Margin="0,4,0,0"
                                 VerticalContentAlignment="Center" />
                    </StackPanel>

                    <StackPanel Margin="0,10,0,0">
                        <TextBlock FontWeight="SemiBold" Text="Beschreibung" />
                        <TextBox x:Name="EntryDescriptionTextBox"
                                 Margin="0,4,0,0"
                                 MinHeight="68"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Margin="0,0,8,0"
                        Content="Abbrechen"
                        Style="{StaticResource DarkButtonStyle}"
                        IsCancel="True" />
                <Button x:Name="DeleteButton"
                        Grid.Column="1"
                        Margin="8,0,8,0"
                        Content="Eintrag löschen"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="OnDeleteClicked"
                        Visibility="Collapsed" />
                <Button x:Name="SaveButton"
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        Content="Eintrag hinzufügen"
                        Style="{StaticResource SuccessButtonStyle}"
                        IsDefault="True"
                        Click="OnSaveClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>



<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.CreateTourDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Tourenplaner.CSharp.App.Views.Controls"
        Title="Neue Tour erstellen"
        Width="700"
        Height="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Border Margin="12" Style="{StaticResource FlatCardStyle}" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="34" FontWeight="Bold" Text="Neue Liefertour" />

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock FontWeight="SemiBold" Text="Datum (DD.MM.YYYY)" />
                    <controls:ModernDatePickerField Margin="0,4,0,0"
                                                    SelectedDateText="{Binding DateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,6,0">
                    <TextBlock FontWeight="SemiBold" Text="Abfahrt Std" />
                    <ComboBox Margin="0,4,0,0" ItemsSource="{Binding HourOptions}" SelectedItem="{Binding SelectedHour}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                    <TextBlock FontWeight="SemiBold" Text="Abfahrt Min" />
                    <ComboBox Margin="0,4,0,0" ItemsSource="{Binding MinuteOptions}" SelectedItem="{Binding SelectedMinute}" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <TextBlock FontWeight="SemiBold" Text="Name (optional)" />
                <TextBox Margin="0,4,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                <TextBlock FontWeight="SemiBold" Text="Fahrzeug *" />
                <ComboBox Margin="0,4,0,0" ItemsSource="{Binding VehicleOptions}" SelectedItem="{Binding SelectedVehicle}" DisplayMemberPath="Label" />
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,10,0,0">
                <TextBlock FontWeight="SemiBold" Text="Anhänger" />
                <ComboBox Margin="0,4,0,0" ItemsSource="{Binding TrailerOptions}" SelectedItem="{Binding SelectedTrailer}" DisplayMemberPath="Label" />
            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <CheckBox Content="Mehrere Fahrzeuge verwenden"
                          IsChecked="{Binding UseSecondaryVehicle, Mode=TwoWay}" />
            </StackPanel>

            <Border Grid.Row="6"
                    Margin="0,8,0,0"
                    Style="{StaticResource SoftCardStyle}"
                    Padding="10"
                    Visibility="{Binding UseSecondaryVehicle, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Zusätzliches Fahrzeug" />
                    <ComboBox Margin="0,4,0,0"
                              ItemsSource="{Binding VehicleOptions}"
                              SelectedItem="{Binding SelectedSecondaryVehicle}"
                              DisplayMemberPath="Label" />
                    <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Zusätzlicher Anhänger" />
                    <ComboBox Margin="0,4,0,0"
                              ItemsSource="{Binding TrailerOptions}"
                              SelectedItem="{Binding SelectedSecondaryTrailer}"
                              DisplayMemberPath="Label" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="7" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="Mitarbeiter" />
                <Border Grid.Column="1"
                        Padding="10,4"
                        CornerRadius="999"
                        Background="{DynamicResource Brush.SurfaceRaised}">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedEmployeesSummary}" />
                </Border>
            </Grid>

            <Border Grid.Row="8" Margin="0,12,0,0" Style="{StaticResource SoftCardStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0"
                                  MaxHeight="96"
                                  VerticalAlignment="Top"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Employees}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,8,8"
                                            Padding="8,4"
                                            MinWidth="190"
                                            CornerRadius="999"
                                            Background="{DynamicResource Brush.SurfaceRaised}">
                                        <Grid MinHeight="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="4,0,4,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#D4A017"
                                                       Text="★"
                                                       Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Label}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Grid.Row="1"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Text="1 bis 2 Mitarbeiter wählen. Bei zwei Fahrzeugen sind mindestens 2 nötig." />
                </Grid>
            </Border>

            <Grid Grid.Row="10" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Height="38" Margin="0,0,8,0" Content="Abbrechen" Style="{StaticResource SecondaryButtonStyle}" Click="OnCancelClicked" />
                <Button x:Name="OpenOnMapButton"
                        Grid.Column="1"
                        Height="38"
                        Margin="8,0,8,0"
                        Content="Tour auf Karte anzeigen"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Visibility="Collapsed"
                        Click="OnOpenOnMapClicked" />
                <Button Grid.Column="2" Height="38" Margin="8,0,0,0" Content="Speichern" Style="{StaticResource SuccessButtonStyle}" IsDefault="True" Click="OnCreateClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>


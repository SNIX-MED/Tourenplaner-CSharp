<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GAWELA Tourenplaner startet"
        Width="520"
        Height="320"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="28"
            Background="#FFF7F8FA"
            BorderBrush="#220F172A"
            BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="22"
                    Padding="24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFF5F9FF" Offset="0" />
                        <GradientStop Color="#FFE9F7F2" Offset="0.55" />
                        <GradientStop Color="#FFFFF4E8" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="92"
                            Height="92"
                            CornerRadius="24"
                            Background="#FFFFFFFF"
                            BorderBrush="#140F172A"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <Image Source="/Assets/Applogo.png"
                               Width="60"
                               Height="60"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel Grid.Column="1" Margin="22,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#FF0F766E"
                                   Text="GAWELA LOGISTIK" />
                        <TextBlock Margin="0,10,0,0"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#FF0F172A"
                                   Text="Tourenplaner" />
                        <TextBlock Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   FontSize="15"
                                   Foreground="#FF475569"
                                   Text="Die Anwendung wird vorbereitet und geprueft, bevor die Arbeitsoberflaeche geoeffnet wird." />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="4,22,4,0">
                <TextBlock x:Name="StatusTextBlock"
                           FontSize="14"
                           Foreground="#FF334155"
                           Text="Start wird vorbereitet..." />
                <ProgressBar Margin="0,14,0,0"
                             Height="8"
                             IsIndeterminate="True"
                             Foreground="#FF0F766E"
                             Background="#140F172A"
                             BorderThickness="0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

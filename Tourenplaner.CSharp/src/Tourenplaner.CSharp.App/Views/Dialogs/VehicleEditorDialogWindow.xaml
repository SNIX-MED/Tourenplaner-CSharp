<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.VehicleEditorDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fahrzeug"
        Width="540"
        Height="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Border Margin="10" Style="{StaticResource FlatCardStyle}" Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <TextBlock FontSize="34" FontWeight="Bold" Text="{Binding Heading}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Typ" />
                <Border Margin="0,8,0,0" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource Brush.BorderStrong}" Background="{DynamicResource Brush.CardSoft}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Margin="4"
                                Height="36"
                                Content="Zugfahrzeug"
                                Click="OnSetVehicleTypeClicked">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTrailer}" Value="False">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="1"
                                Margin="4"
                                Height="36"
                                Content="Anhänger"
                                Click="OnSetTrailerTypeClicked">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTrailer}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                            <Setter Property="Foreground" Value="White" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Name" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Kennzeichen" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding LicensePlate, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Nutzlast (kg)" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding MaxPayloadKgText, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Margin="0,14,0,0" Visibility="{Binding VehicleOnlyVisibility}">
                    <TextBlock FontWeight="SemiBold" Text="Anhängelast (kg)" />
                    <TextBox Margin="0,6,0,0" Height="38" Text="{Binding MaxTrailerLoadKgText, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Volumen (m3)" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding VolumeM3Text, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Ladefläche (L x B x H in cm)" />
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,6,0" Height="38" Text="{Binding LengthCmText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="1" Margin="6,0,6,0" Height="38" Text="{Binding WidthCmText, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Column="2" Margin="6,0,0,0" Height="38" Text="{Binding HeightCmText, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Notizen" />
                <TextBox Margin="0,6,0,0"
                         MinHeight="110"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Margin="0,14,0,0">
                    <CheckBox Content="Ausfall eintragen"
                              IsChecked="{Binding RegisterOutage}" />
                    <Grid Margin="0,8,0,0"
                          Visibility="{Binding RegisterOutage, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock FontWeight="SemiBold" Text="Von (DD.MM.YYYY)" />
                            <TextBox Margin="0,6,0,0"
                                     Height="38"
                                     Text="{Binding OutageStartDate, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock FontWeight="SemiBold" Text="Bis (DD.MM.YYYY)" />
                            <TextBox Margin="0,6,0,0"
                                     Height="38"
                                     Text="{Binding OutageEndDate, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Height="40"
                            Margin="0,0,8,0"
                            Content="Abbrechen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnCancelClicked" />
                    <Button Grid.Column="1"
                            Height="40"
                            Margin="8,0,0,0"
                            Content="Speichern"
                            Style="{StaticResource SuccessButtonStyle}"
                            IsDefault="True"
                            Click="OnSaveClicked" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>

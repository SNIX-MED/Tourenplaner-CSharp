<Window x:Class="Tourenplaner.CSharp.App.Views.Dialogs.VehicleCombinationEditorDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fahrzeugkombination"
        Width="560"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush.WindowBackground}">
    <Border Margin="10" Style="{StaticResource FlatCardStyle}" Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <TextBlock FontSize="34" FontWeight="Bold" Text="{Binding Heading}" />

                <TextBlock Margin="0,16,0,0" FontWeight="SemiBold" Text="Zugfahrzeug" />
                <ComboBox Margin="0,6,0,0"
                          Height="38"
                          ItemsSource="{Binding VehicleOptions}"
                          SelectedItem="{Binding SelectedVehicle}"
                          DisplayMemberPath="Label" />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Anhänger" />
                <ComboBox Margin="0,6,0,0"
                          Height="38"
                          ItemsSource="{Binding TrailerOptions}"
                          SelectedItem="{Binding SelectedTrailer}"
                          DisplayMemberPath="Label" />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Ladegewicht Zugfahrzeug (kg)" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding VehiclePayloadKgText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Anhängelast (kg)" />
                <TextBox Margin="0,6,0,0" Height="38" Text="{Binding TrailerLoadKgText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Notizen" />
                <TextBox Margin="0,6,0,0"
                         MinHeight="110"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox Margin="0,14,0,0" Content="Kombination ist aktiv" IsChecked="{Binding Active}" />

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Height="40"
                            Margin="0,0,8,0"
                            Content="Abbrechen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="OnCancelClicked" />
                    <Button Grid.Column="1"
                            Height="40"
                            Margin="8,0,0,0"
                            Content="Speichern"
                            Style="{StaticResource SuccessButtonStyle}"
                            IsDefault="True"
                            Click="OnSaveClicked" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>

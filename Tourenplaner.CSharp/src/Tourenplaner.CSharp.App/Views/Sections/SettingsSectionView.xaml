                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsFieldCardStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="Verwendung" />
                                                <TextBlock Margin="0,10,0,0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           TextWrapping="Wrap"
                                                           Text="Diese Kategorie enthält nur noch globale technische TomTom-Basiswerte. Die eigentlichen Kartenoptionen stellst du direkt auf der Karte ein." />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

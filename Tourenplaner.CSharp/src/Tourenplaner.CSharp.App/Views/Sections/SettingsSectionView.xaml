<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.SettingsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1080">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <Button Grid.Column="1"
                    Width="130"
                    Height="38"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    Content="Speichern"
                    Style="{StaticResource SuccessButtonStyle}"
                    Command="{Binding SaveCommand}" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Expander IsExpanded="False" Margin="0,0,0,10">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Allgemein" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Darstellung und Standardtexte der Anwendung." />
                        </StackPanel>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource GlassPanelBorderStyle}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Avisierung E-Mail Betreff" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="10,4,0,4"
                                     ToolTip="Platzhalter X wird durch die Auftragsnummer ersetzt."
                                     Text="{Binding AvisoEmailSubjectTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>
                </Expander>

                <Expander IsExpanded="False" Margin="0,0,0,10">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Tools" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Sichtbarkeit und Standard-Links für GPS und Spediteur-Portal." />
                        </StackPanel>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource GlassPanelBorderStyle}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="GPS anzeigen" />
                            <CheckBox Grid.Row="0" Grid.Column="1" Margin="10,6,0,6" IsChecked="{Binding ShowGpsTool, Mode=TwoWay}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="GPS Standard-Link" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="10,4,0,4"
                                     Text="{Binding GpsToolUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Spediteur anzeigen" />
                            <CheckBox Grid.Row="2" Grid.Column="1" Margin="10,6,0,6" IsChecked="{Binding ShowSpediteurTool, Mode=TwoWay}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Spediteur Standard-Link" />
                            <TextBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="10,4,0,4"
                                     Text="{Binding SpediteurToolUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>
                </Expander>

                <Expander IsExpanded="False" Margin="0,0,0,10">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Firma" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Absender- und Standortdaten für Touren und Kartenansicht." />
                        </StackPanel>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource GlassPanelBorderStyle}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="190" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Firmenname" />
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="10,4,0,4"
                                     Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Firmenstrasse" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="10,4,0,4"
                                     Text="{Binding CompanyStreet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="PLZ / Ort" />
                            <Grid Grid.Row="2" Grid.Column="1" Margin="10,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Margin="0,0,8,0"
                                         Text="{Binding CompanyPostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding CompanyCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Expander>

                <Expander IsExpanded="False" Margin="0,0,0,10">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Status &amp; Kalender" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Pin-Farben und Kalender-Auslastung kompakt an einem Ort." />
                        </StackPanel>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource GlassPanelBorderStyle}" Padding="14">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Status-Farben" />
                                    <TextBlock Margin="0,2,0,10"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="Farbcodes für die Pins auf der Kartenansicht im Format #RRGGBB." />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Top"
                                        Content="Standardwerte"
                                        Command="{Binding ResetStatusColorsCommand}" />
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Nicht festgelegt" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="10,4,0,4" Text="{Binding StatusColorNotSpecified, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Bestellt" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,4,0,4" Text="{Binding StatusColorOrdered, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Auf dem Weg" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="10,4,0,4" Text="{Binding StatusColorOnTheWay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="An Lager" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="10,4,0,4" Text="{Binding StatusColorInStock, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Tourstatus Eingeplant" />
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="10,4,0,4" Text="{Binding StatusColorPlanned, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <TextBlock Margin="0,16,0,0" FontSize="18" FontWeight="SemiBold" Text="Kalender-Auslastung" />
                            <TextBlock Margin="0,2,0,10"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Farben und Schwellenwerte für Kalendertage anhand der eingeplanten Personen." />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Orange ab Personen" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="10,4,0,4" Text="{Binding CalendarLoadWarningPeopleThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Orange Farbcode" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,4,0,4" Text="{Binding CalendarLoadWarningColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Rot ab Personen" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="10,4,0,4" Text="{Binding CalendarLoadCriticalPeopleThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Rot Farbcode" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="10,4,0,4" Text="{Binding CalendarLoadCriticalColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <Expander IsExpanded="False" Margin="0,0,0,10">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Backup &amp; Restore" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Sicherungspfad, Wiederherstellung und automatische Intervalle." />
                        </StackPanel>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource GlassPanelBorderStyle}" Padding="14">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button Width="140" Content="Backup erstellen" Command="{Binding CreateBackupCommand}" />
                                <Button Width="150" Margin="8,0,0,0" Content="Backup laden" Command="{Binding RestoreLatestBackupCommand}" />
                                <Button Width="150" Margin="8,0,0,0" Content="Backups bereinigen" Command="{Binding CleanupBackupsCommand}" />
                            </WrapPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Backups Enabled" />
                                <CheckBox Grid.Row="0" Grid.Column="1" Margin="10,6,0,6" IsChecked="{Binding BackupsEnabled, Mode=TwoWay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Backup Directory" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,4,0,4" Text="{Binding BackupDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Backup Mode" />
                                <ComboBox Grid.Row="2"
                                          Grid.Column="1"
                                          Margin="10,4,0,4"
                                          ItemsSource="{Binding BackupModes}"
                                          SelectedItem="{Binding BackupModeDefault, Mode=TwoWay}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Retention Days" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="10,4,0,4" Text="{Binding BackupRetentionDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Auto Backup Enabled" />
                                <CheckBox Grid.Row="4" Grid.Column="1" Margin="10,6,0,6" IsChecked="{Binding AutoBackupEnabled, Mode=TwoWay}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Auto Backup Interval Days" />
                                <TextBox Grid.Row="5" Grid.Column="1" Margin="10,4,0,4" Text="{Binding AutoBackupIntervalDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Border Margin="0,12,0,0"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="{DynamicResource Brush.GlassSurfaceSoft}"
                                    BorderBrush="{DynamicResource Brush.GlassStroke}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontWeight="SemiBold" Text="Last Backup (ISO): " />
                                    <TextBlock Text="{Binding LastBackupIso}" />
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Neueste Sicherung" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="10,4,0,4" VerticalAlignment="Center" Text="{Binding LatestBackupFile}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Anzahl Sicherungen" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,4,0,4" VerticalAlignment="Center" Text="{Binding AvailableBackupsCount}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <Expander IsExpanded="False" Margin="0,0,0,4">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Updates &amp; Versionen" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="GitHub Releases prüfen, neue Version herunterladen und Release-Seite öffnen." />
                        </StackPanel>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource GlassPanelBorderStyle}" Padding="14">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button Width="150" Content="Updates prüfen" Command="{Binding CheckForUpdatesCommand}" />
                                <Button Width="170" Margin="8,0,0,0" Content="Update laden" Command="{Binding DownloadLatestUpdateCommand}" />
                                <Button Width="150" Margin="8,0,0,0" Content="Release öffnen" Command="{Binding OpenUpdateFeedCommand}" />
                            </WrapPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Installierte Version" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="10,4,0,4" VerticalAlignment="Center" Text="{Binding ApplicationVersion}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text=".NET Runtime" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,4,0,4" VerticalAlignment="Center" Text="{Binding RuntimeVersion}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Neueste GitHub-Version" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="10,4,0,4" VerticalAlignment="Center" Text="{Binding LatestReleaseVersion}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Veröffentlicht" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="10,4,0,4" VerticalAlignment="Center" Text="{Binding LatestReleasePublishedAt}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Download-Asset" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Margin="10,4,0,4" VerticalAlignment="Center" Text="{Binding LatestReleaseAsset}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Status" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Margin="10,4,0,4" TextWrapping="Wrap" Text="{Binding UpdateCheckResult}" />

                                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="GitHub-URL" />
                                <Grid Grid.Row="6" Grid.Column="1" Margin="10,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Margin="0,0,8,0"
                                             Text="{Binding UpdateFeedUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Content="Update öffnen"
                                            Command="{Binding OpenUpdateFeedCommand}" />
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Expander>

                <Expander IsExpanded="False" Margin="0,0,0,4">
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="SQL Server Import" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Konfigurieren und Importieren von Aufträgen aus der Business11 Datenbank." />
                        </StackPanel>
                    </Expander.Header>
                    <Border Margin="0,8,0,0" Style="{StaticResource GlassPanelBorderStyle}" Padding="14">
                        <StackPanel>
                            <WrapPanel Margin="0,0,0,10">
                                <Button Width="140" Content="Verbindung testen" Command="{Binding TestSqlConnectionCommand}" />
                                <Button Width="170" Margin="8,0,0,0" Content="Aufträge importieren" Command="{Binding ImportOrdersCommand}" 
                                        Foreground="White"
                                        Style="{StaticResource SuccessButtonStyle}" />
                            </WrapPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="SQL Server" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="10,4,0,4"
                                         ToolTip="z.B. .\SQLEXPRESS, . oder SERVER\INSTANZ"
                                         Text="{Binding SqlServer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Datenbankname" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,4,0,4"
                                         ToolTip="z.B. Business11"
                                         Text="{Binding SqlDatabase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Datenbankpfad" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="10,4,0,4"
                                         ToolTip="Ordner oder .mdf-Datei der Business11-Datenbank"
                                         Text="{Binding SqlDatabasePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Windows-Auth" />
                                <CheckBox Grid.Row="3" Grid.Column="1" Margin="10,6,0,6" IsChecked="{Binding SqlUseWindowsAuth, Mode=TwoWay}" 
                                          ToolTip="Verwendet Windows-Authentifizierung, wenn aktiviert" />

                                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="SQL Benutzer" />
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="10,4,0,4"
                                         Text="{Binding SqlUserId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="SQL Passwort" />
                                <TextBox Grid.Row="5" Grid.Column="1" Margin="10,4,0,4"
                                         Text="{Binding SqlPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <Border Margin="0,12,0,0"
                                    Padding="10"
                                    CornerRadius="10"
                                    Background="{DynamicResource Brush.GlassSurfaceSoft}"
                                    BorderBrush="{DynamicResource Brush.GlassStroke}"
                                    BorderThickness="1">
                                <TextBlock TextWrapping="Wrap" Text="{Binding ImportStatusMessage}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <TextBlock Grid.Row="2" Margin="0,12,0,0" FontWeight="SemiBold" Text="Prüfung">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationSummary}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ValidationSummary}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <Trigger Property="Text" Value="Prüfung">
                            <Setter Property="Visibility" Value="Visible" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        <Border Grid.Row="3" Margin="0,6,0,0" Padding="10" CornerRadius="10" Background="#FFF7E8" BorderBrush="#F2C46D" BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationSummary}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ValidationSummary}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Foreground="#7C4A03"
                       TextWrapping="Wrap"
                       Text="{Binding ValidationSummary, Mode=OneWay}" />
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.SettingsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1080"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <Style x:Key="SharpFilterBarCardStyle" TargetType="Border" BasedOn="{StaticResource FilterBarCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpSoftCardStyle" TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpGlassPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource GlassPanelBorderStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SettingsIconWrapStyle" TargetType="Border">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style x:Key="SettingsSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>
        <Style x:Key="SettingsSectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
        </Style>
        <Style x:Key="SettingsFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
        </Style>
        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,4,0,8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Margin" Value="0,4,0,8" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          FocusVisualStyle="{x:Null}"
                                          Content="{TemplateBinding Header}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderSurface"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                CornerRadius="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{TemplateBinding Content}"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Center" />
                                                <Grid Grid.Column="1"
                                                      Width="20"
                                                      Height="20"
                                                      Margin="12,0,0,0"
                                                      VerticalAlignment="Center">
                                                    <TextBlock x:Name="ChevronRight"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="16"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="&#xE76C;"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock x:Name="ChevronDown"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="16"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="&#xE70D;"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="Collapsed" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderSurface" Property="Background" Value="{DynamicResource Brush.SidebarItemHover}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="HeaderSurface" Property="Background" Value="{DynamicResource Brush.SidebarItemHover}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ChevronRight" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="ChevronDown" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Margin="0"
                                              Visibility="Collapsed"
                                              ContentSource="Content" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource Spacing.PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource SharpSoftCardStyle}" Padding="16" Margin="0,0,0,12">
                    <Expander IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SettingsIconWrapStyle}">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="19" Text="&#xE713;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Allgemein" />
                                    <TextBlock Style="{StaticResource SettingsSectionSubtitleStyle}" Text="Darstellung und Standardwerte der Anwendung verwalten." />
                                </StackPanel>
                            </Grid>
                        </Expander.Header>
                        <Border Margin="0,12,0,0" Style="{StaticResource SharpGlassPanelBorderStyle}" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Avisierung E-Mail Betreff" />
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="36" ToolTip="Platzhalter X wird durch die Auftragsnummer ersetzt." Text="{Binding AvisoEmailSubjectTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Standard Startzeit Tour (HH:mm)" />
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="36" MaxLength="5" ToolTip="Standard-Startzeit für neue Touren, z.B. 07:30." Text="{Binding TourDefaultStartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>
                    </Expander>
                </Border>

                <Border Style="{StaticResource SharpSoftCardStyle}" Padding="16" Margin="0,0,0,12">
                    <Expander IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SettingsIconWrapStyle}">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="19" Text="&#xE787;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Karte &amp; Kalender" />
                                    <TextBlock Style="{StaticResource SettingsSectionSubtitleStyle}" Text="Pin-Farben und Kalender-Auslastung kompakt an einem Ort verwalten." />
                                </StackPanel>
                            </Grid>
                        </Expander.Header>
                        <Border Margin="0,12,0,0" Style="{StaticResource SharpGlassPanelBorderStyle}" Padding="14">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock FontSize="26" FontWeight="SemiBold" Text="Status-Farben" />
                                        <TextBlock Margin="0,2,0,10" Foreground="{DynamicResource Brush.TextMuted}" Text="Farbcodes für die Pins auf der Kartenansicht im Format #RRGGBB." />
                                    </StackPanel>
                                    <Button DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Top" Content="Standardwerte" Command="{Binding ResetStatusColorsCommand}" />
                                </DockPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Nicht festgelegt" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding StatusColorNotSpecified, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Bestellt" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding StatusColorOrdered, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Unterwegs / Teilweise bereit" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding StatusColorOnTheWay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Lieferbereit" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding StatusColorInStock, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Suche Nichttreffer" />
                                    <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,6,0,6" Content="Pins ausgrauen statt ausblenden" IsChecked="{Binding MapSearchDimNonMatchingPins, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,12,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="Infokarte Felder" />
                                    <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Name" />
                                    <CheckBox Grid.Row="8" Grid.Column="1" Margin="0,6,0,6" Content="Name anzeigen" IsChecked="{Binding MapPinInfoCardShowName, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Auftragsnummer" />
                                    <CheckBox Grid.Row="9" Grid.Column="1" Margin="0,6,0,6" Content="Auftragsnummer anzeigen" IsChecked="{Binding MapPinInfoCardShowOrderNumber, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Strasse" />
                                    <CheckBox Grid.Row="10" Grid.Column="1" Margin="0,6,0,6" Content="Strasse anzeigen" IsChecked="{Binding MapPinInfoCardShowStreet, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="PLZ und Ort" />
                                    <CheckBox Grid.Row="11" Grid.Column="1" Margin="0,6,0,6" Content="PLZ und Ort anzeigen" IsChecked="{Binding MapPinInfoCardShowPostalCodeCity, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="12" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Notizen" />
                                    <CheckBox Grid.Row="12" Grid.Column="1" Margin="0,6,0,6" Content="Notizen anzeigen" IsChecked="{Binding MapPinInfoCardShowNotes, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="13" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Produkte" />
                                    <CheckBox Grid.Row="13" Grid.Column="1" Margin="0,6,0,6" Content="Produkte (Menge, Name) anzeigen" IsChecked="{Binding MapPinInfoCardShowProducts, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="14" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Gesamtgewicht" />
                                    <CheckBox Grid.Row="14" Grid.Column="1" Margin="0,6,0,6" Content="Gesamtgewicht anzeigen" IsChecked="{Binding MapPinInfoCardShowTotalWeight, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="15" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Infokarten Zoomverhalten" />
                                    <StackPanel Grid.Row="15" Grid.Column="1" Margin="0,6,0,6">
                                        <Slider Minimum="0.2"
                                                Maximum="4.0"
                                                SmallChange="0.1"
                                                LargeChange="0.2"
                                                TickFrequency="0.1"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding PinInfoCardZoomBehaviorStrength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="{Binding PinInfoCardZoomBehaviorStrength, StringFormat='{}Staerke: {0:0.00}x (0.2 = schwach, 4.0 = sehr stark)'}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Margin="0,16,0,0" FontSize="26" FontWeight="SemiBold" Text="Kalender-Auslastung" />
                                <TextBlock Margin="0,2,0,10" Foreground="{DynamicResource Brush.TextMuted}" Text="Farben und Schwellenwerte für Kalendertage anhand der eingeplanten Personen." />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Orange ab Personen" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding CalendarLoadWarningPeopleThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Orange Farbcode" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding CalendarLoadWarningColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Rot ab Personen" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding CalendarLoadCriticalPeopleThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Rot Farbcode" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding CalendarLoadCriticalColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Karte Rot ab Rest %" />
                                    <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" ToolTip="Wenn Restkapazität kleiner/gleich diesem Prozentwert ist, wird die Tourlinie rot." Text="{Binding MapRouteCapacityWarningThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBlock Margin="0,16,0,0" FontSize="26" FontWeight="SemiBold" Text="TomTom Karte &amp; Traffic" />
                                <TextBlock Margin="0,2,0,10" Foreground="{DynamicResource Brush.TextMuted}" Text="API-Key, Kartenstil und Abfrage-Intervalle fuer verkehrsbasierte Routenberechnung." />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="TomTom API Key" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding TomTomApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Kartenstil" />
                                    <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}" Height="34" ItemsSource="{Binding TomTomMapStyles}" SelectedItem="{Binding TomTomMapStyle, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Traffic Overlay" />
                                    <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,6" Content="Traffic-Flow auf Karte einblenden" IsChecked="{Binding TomTomShowTrafficFlow, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Traffic Refresh (s)" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" ToolTip="Min. 15 Sekunden fuer reduzierte API-Abfragen." Text="{Binding TomTomTrafficRefreshSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Route Debounce (ms)" />
                                    <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" ToolTip="Routenberechnung nur nach kurzer Ruhephase." Text="{Binding TomTomRouteRecalcDebounceMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Tile Cache" />
                                    <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,6,0,6" Content="WebView Cache fuer Kartentiles nutzen (lizenzabhaengig)" IsChecked="{Binding TomTomEnableTileCache, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Routing-Modus" />
                                    <ComboBox Grid.Row="6" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}" Height="34" ItemsSource="{Binding TomTomRoutingModes}" SelectedItem="{Binding TomTomRoutingMode, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Fahrzeughoehe (m)" />
                                    <TextBox Grid.Row="7" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" ToolTip="Nur fuer Modus 'heightAware': 0 deaktiviert Hoehenrestriktion." Text="{Binding TomTomVehicleHeightMeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                </Border>

                <Border Style="{StaticResource SharpSoftCardStyle}" Padding="16" Margin="0,0,0,12">
                    <Expander IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SettingsIconWrapStyle}">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="19" Text="&#xE90F;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Tools" />
                                    <TextBlock Style="{StaticResource SettingsSectionSubtitleStyle}" Text="Sichtbarkeit und Standard-Links für GPS und Spediteur-Portal konfigurieren." />
                                </StackPanel>
                            </Grid>
                        </Expander.Header>
                        <Border Margin="0,12,0,0" Style="{StaticResource SharpGlassPanelBorderStyle}" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="GPS anzeigen" />
                                <CheckBox Grid.Row="0" Grid.Column="1" Margin="0,6,0,6" IsChecked="{Binding ShowGpsTool, Mode=TwoWay}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="GPS Standard-Link" />
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding GpsToolUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Spediteur anzeigen" />
                                <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,6" IsChecked="{Binding ShowSpediteurTool, Mode=TwoWay}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Spediteur Standard-Link" />
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding SpediteurToolUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>
                    </Expander>
                </Border>
                <Border Style="{StaticResource SharpSoftCardStyle}" Padding="16" Margin="0,0,0,12">
                    <Expander IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SettingsIconWrapStyle}">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="19" Text="&#xE80F;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Firma" />
                                    <TextBlock Style="{StaticResource SettingsSectionSubtitleStyle}" Text="Absender- und Standortdaten für Touren und Kartenansicht." />
                                </StackPanel>
                            </Grid>
                        </Expander.Header>
                        <Border Margin="0,12,0,0" Style="{StaticResource SharpGlassPanelBorderStyle}" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Firmenname" />
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Firmenstrasse" />
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding CompanyStreet, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="PLZ / Ort" />
                                <Grid Grid.Row="2" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Margin="0,0,8,0" Text="{Binding CompanyPostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding CompanyCity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Expander>
                </Border>

                <Border Style="{StaticResource SharpSoftCardStyle}" Padding="16" Margin="0,0,0,12">
                    <Expander IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SettingsIconWrapStyle}">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="19" Text="&#xE72C;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="Backup &amp; Restore" />
                                    <TextBlock Style="{StaticResource SettingsSectionSubtitleStyle}" Text="Sicherungspfad, Wiederherstellung und automatische Intervalle konfigurieren." />
                                </StackPanel>
                            </Grid>
                        </Expander.Header>
                        <Border Margin="0,12,0,0" Style="{StaticResource SharpGlassPanelBorderStyle}" Padding="14">
                            <StackPanel>
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Width="160" Content="Backup erstellen" Command="{Binding CreateBackupCommand}" />
                                    <Button Width="160" Margin="8,0,0,0" Content="Backup laden" Command="{Binding RestoreLatestBackupCommand}" />
                                    <Button Width="180" Margin="8,0,0,0" Content="Backups bereinigen" Command="{Binding CleanupBackupsCommand}" />
                                </WrapPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Backups Enabled" />
                                    <CheckBox Grid.Row="0" Grid.Column="1" Margin="0,6,0,6" IsChecked="{Binding BackupsEnabled, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Backup Directory" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding BackupDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Backup Mode" />
                                    <ComboBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsComboBoxStyle}" Height="34" ItemsSource="{Binding BackupModes}" SelectedItem="{Binding BackupModeDefault, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Retention Days" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding BackupRetentionDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Auto Backup Enabled" />
                                    <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,6,0,6" IsChecked="{Binding AutoBackupEnabled, Mode=TwoWay}" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Auto Backup Interval Days" />
                                    <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Height="34" Text="{Binding AutoBackupIntervalDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Border Margin="0,12,0,0" Padding="12" CornerRadius="12" Background="{DynamicResource Brush.GlassSurfaceSoft}" BorderBrush="{DynamicResource Brush.GlassStroke}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold" Text="Last Backup (ISO): " />
                                        <TextBlock Text="{Binding LastBackupIso}" />
                                    </StackPanel>
                                </Border>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Neueste Sicherung" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="{Binding LatestBackupFile}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Anzahl Sicherungen" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Text="{Binding AvailableBackupsCount}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                </Border>
                <Border Style="{StaticResource SharpSoftCardStyle}" Padding="16" Margin="0,0,0,12">
                    <Expander IsExpanded="False">
                        <Expander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource SettingsIconWrapStyle}">
                                    <TextBlock FontFamily="Segoe Fluent Icons" FontSize="19" Text="&#xE9F9;" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Style="{StaticResource SettingsSectionTitleStyle}" Text="XML Import" />
                                    <TextBlock Style="{StaticResource SettingsSectionSubtitleStyle}" Text="Auftraege aus XML importieren und XML-Musterdatei herunterladen." />
                                </StackPanel>
                            </Grid>
                        </Expander.Header>
                        <Border Margin="0,12,0,0" Style="{StaticResource SharpGlassPanelBorderStyle}" Padding="14">
                            <StackPanel>
                                <WrapPanel Margin="0,0,0,10">
                                    <Button Width="180" Content="XML-Datei waehlen" Command="{Binding BrowseXmlImportFileCommand}" />
                                    <Button Width="220" Margin="8,0,0,0" Content="XML-Musterdatei herunterladen" Command="{Binding DownloadXmlTemplateCommand}" />
                                    <Button Width="180" Margin="8,0,0,0" Content="Auftraege importieren" Foreground="White" Style="{StaticResource SuccessButtonStyle}" Command="{Binding ImportOrdersCommand}" />
                                </WrapPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="XML-Dateipfad" />
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Width="34"
                                            Height="34"
                                            Margin="0,0,8,0"
                                            Padding="0"
                                            ToolTip="XML-Datei auswaehlen"
                                            Command="{Binding BrowseXmlImportFileCommand}">
                                        <Image Source="pack://application:,,,/Assets/Ordner.png"
                                               Width="20"
                                               Height="20"
                                               Stretch="Uniform"
                                               SnapsToDevicePixels="True" />
                                    </Button>
                                    <TextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource SettingsTextBoxStyle}" Height="34" ToolTip="Pfad zur XML-Datei mit den Auftragsdaten" Text="{Binding XmlImportFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Expander>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Margin="0,12,0,0" Padding="12" CornerRadius="12" Background="{DynamicResource Brush.DangerSoft}" BorderBrush="{DynamicResource Brush.Danger}" BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationSummary}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ValidationSummary}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Pruefung" />
                <TextBlock TextWrapping="Wrap" Text="{Binding ValidationSummary, Mode=OneWay}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>





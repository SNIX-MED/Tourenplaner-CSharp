                                                           Text="Diese Kategorie enthält nur noch globale technische TomTom-Basiswerte. Die eigentlichen Kartenoptionen stellst du direkt auf der Karte ein." />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />

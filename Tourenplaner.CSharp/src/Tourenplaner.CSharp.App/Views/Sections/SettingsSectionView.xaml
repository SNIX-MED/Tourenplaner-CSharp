                                                    <DataTemplate>
                                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap" Text="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>


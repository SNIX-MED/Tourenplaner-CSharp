                                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource SettingsComboBoxStyle}" ItemsSource="{Binding BackupModes}" SelectedItem="{Binding BackupModeDefault, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Aufbewahrung (Tage)" />
                                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding BackupRetentionDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Automatische Backups" />

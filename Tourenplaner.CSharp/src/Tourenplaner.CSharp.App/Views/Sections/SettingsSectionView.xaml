<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.SettingsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1320"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <Style x:Key="SharpSoftCardStyle" TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpGlassPanelBorderStyle" TargetType="Border" BasedOn="{StaticResource GlassPanelBorderStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SettingsSidebarCardStyle" TargetType="Border" BasedOn="{StaticResource SharpSoftCardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="{DynamicResource Brush.SidebarBackground}" />
        </Style>
        <Style x:Key="SettingsSurfaceCardStyle" TargetType="Border" BasedOn="{StaticResource SharpSoftCardStyle}">
            <Setter Property="Padding" Value="22" />
            <Setter Property="CornerRadius" Value="28" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="SettingsMetricCardStyle" TargetType="Border" BasedOn="{StaticResource SharpGlassPanelBorderStyle}">
            <Setter Property="Width" Value="250" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="{DynamicResource Brush.GlassSurfaceSoft}" />
        </Style>
        <Style x:Key="SettingsSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>
        <Style x:Key="SettingsSectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SettingsSubsectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>
        <Style x:Key="SettingsFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="MinHeight" Value="40" />
        </Style>
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="MinHeight" Value="40" />
        </Style>
        <Style x:Key="SettingsFieldCardStyle" TargetType="Border" BasedOn="{StaticResource SharpGlassPanelBorderStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{DynamicResource Brush.GlassSurfaceSoft}" />
        </Style>
        <Style x:Key="SettingsInnerPanelStyle" TargetType="Border" BasedOn="{StaticResource SharpGlassPanelBorderStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="{DynamicResource Brush.GlassSurfaceSoft}" />
        </Style>
        <Style x:Key="ColorPreviewCardStyle" TargetType="Border" BasedOn="{StaticResource SharpGlassPanelBorderStyle}">
            <Setter Property="Width" Value="176" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
        </Style>
        <Style x:Key="ColorPreviewActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
        <Style x:Key="ToggleTileStyle" TargetType="Border" BasedOn="{StaticResource SharpGlassPanelBorderStyle}">
            <Setter Property="Width" Value="240" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
        </Style>
        <Style x:Key="SettingsCategoryListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource SidebarListBoxItemStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,12" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,14,0"
                Style="{StaticResource SettingsSidebarCardStyle}">
            <StackPanel>
                <TextBlock Margin="6,12,6,4"
                           Style="{StaticResource SidebarSectionHeaderTextStyle}"
                           Text="Kategorien" />
                <ListBox Margin="0,2,0,0"
                         ItemsSource="{Binding SettingsCategories}"
                         SelectedItem="{Binding SelectedSettingsCategory, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource SettingsCategoryListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource SidebarNavigationTextStyle}" Text="{Binding Title}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <WrapPanel Margin="0,0,0,2">
                    <Border Style="{StaticResource SettingsMetricCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="14"
                                        Background="#F2EAFE">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="17"
                                               Foreground="#7C3AED"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE943;" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Installierte Version" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Text="{Binding ApplicationVersion}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="{Binding RuntimeVersion, StringFormat='{}.NET Runtime {0}'}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsMetricCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="14"
                                        Background="#FFF3E8">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="17"
                                               Foreground="#F97316"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE895;" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Update-Status" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,0"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="{Binding UpdateStatusText}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="{Binding LastUpdateCheckText, StringFormat='{}Letzte Prüfung: {0}'}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsMetricCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="14"
                                        Background="#ECFDF3">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="17"
                                               Foreground="#16A34A"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE73E;" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Sicherungen" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Text="{Binding AvailableBackupsCount, StringFormat='{}{0} verfügbar'}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="{Binding LatestBackupSummaryText}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsMetricCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="14"
                                        Background="#EEF2FF">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="17"
                                               Foreground="#4F46E5"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE8B7;" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Importvorschau" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,0"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Text="{Binding XmlImportPreviewSummary}" />
                            <TextBlock Grid.Row="2"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="Noch keine XML-Datei geprüft.">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasXmlImportPreview}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </WrapPanel>

                <Border Style="{StaticResource SettingsSurfaceCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource SettingsSectionTitleStyle}"
                                           Text="{Binding SelectedSettingsCategoryTitle}" />
                                <TextBlock Style="{StaticResource SettingsSectionSubtitleStyle}"
                                           Text="{Binding SelectedSettingsCategoryDescription}" />
                                <Border Margin="0,14,0,0"
                                        Padding="12,10"
                                        CornerRadius="16"
                                        Background="{DynamicResource Brush.GlassSurfaceSoft}"
                                        BorderBrush="{DynamicResource Brush.GlassStroke}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusText}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusText}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       Margin="18,0,0,0"
                                       VerticalAlignment="Top">
                                <Button Width="170"
                                        Margin="0,0,10,10"
                                        Content="Speichern"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SaveCommand}" />
                                <Button Width="190"
                                        Margin="0,0,0,10"
                                        Content="Updates prüfen"
                                        Command="{Binding CheckForUpdatesCommand}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsCategoryKey}" Value="updates">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,28,0,0">
                            <StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsCategoryKey}" Value="general">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SettingsFieldCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="E-Mail-Betreff (Standard)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}"
                                                         ToolTip="Platzhalter X wird durch die Auftragsnummer ersetzt."
                                                         Text="{Binding AvisoEmailSubjectTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           TextWrapping="Wrap"
                                                           Text="Dieser Betreff wird für standardmässige Touren-E-Mails verwendet." />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsFieldCardStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="Standard-Startzeit für neue Touren" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}"
                                                         MaxLength="5"
                                                         ToolTip="Beispiel: 07:30"
                                                         Text="{Binding TourDefaultStartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           TextWrapping="Wrap"
                                                           Text="Diese Startzeit wird automatisch für neu angelegte Touren vorgeschlagen." />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Style="{StaticResource SettingsInnerPanelStyle}" Margin="0,0,0,0" Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Hinweis" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Text="Diese Kategorie sammelt die globalen Start- und Kommunikationsstandards. Änderungen wirken sich auf neue Prozesse aus, bestehende Daten bleiben unberührt." />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsCategoryKey}" Value="map">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Statusfarben" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Text="Direkte Farb-Vorschauen für Marker, Legenden und Kalenderhinweise statt technischer Hex-Felder." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Width="170"
                                                VerticalAlignment="Top"
                                                Content="Standardfarben"
                                                Command="{Binding ResetStatusColorsCommand}" />
                                    </Grid>

                                    <WrapPanel>
                                        <Border Style="{StaticResource ColorPreviewCardStyle}">
                                            <StackPanel>
                                                <Border Height="46" CornerRadius="14" Background="{Binding StatusColorNotSpecified}" />
                                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Nicht festgelegt" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Neutraler Auftragszustand" />
                                                <Button Margin="0,10,0,0" Style="{StaticResource ColorPreviewActionButtonStyle}" Content="Farbe ändern" Command="{Binding PickStatusColorNotSpecifiedCommand}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource ColorPreviewCardStyle}">
                                            <StackPanel>
                                                <Border Height="46" CornerRadius="14" Background="{Binding StatusColorOrdered}" />
                                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Bestellt" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Bestellte Aufträge" />
                                                <Button Margin="0,10,0,0" Style="{StaticResource ColorPreviewActionButtonStyle}" Content="Farbe ändern" Command="{Binding PickStatusColorOrderedCommand}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource ColorPreviewCardStyle}">
                                            <StackPanel>
                                                <Border Height="46" CornerRadius="14" Background="{Binding StatusColorOnTheWay}" />
                                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Unterwegs / Teilweise bereit" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Aktive oder teilweise fertige Aufträge" />
                                                <Button Margin="0,10,0,0" Style="{StaticResource ColorPreviewActionButtonStyle}" Content="Farbe ändern" Command="{Binding PickStatusColorOnTheWayCommand}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource ColorPreviewCardStyle}">
                                            <StackPanel>
                                                <Border Height="46" CornerRadius="14" Background="{Binding StatusColorInStock}" />
                                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Lieferbereit" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Vollständig bereit zur Auslieferung" />
                                                <Button Margin="0,10,0,0" Style="{StaticResource ColorPreviewActionButtonStyle}" Content="Farbe ändern" Command="{Binding PickStatusColorInStockCommand}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource ColorPreviewCardStyle}">
                                            <StackPanel>
                                                <Border Height="46" CornerRadius="14" Background="{Binding StatusColorPlanned}" />
                                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Eingeplant" />
                                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Touren- und Planungsbezug" />
                                                <Button Margin="0,10,0,0" Style="{StaticResource ColorPreviewActionButtonStyle}" Content="Farbe ändern" Command="{Binding PickStatusColorPlannedCommand}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <Border>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Kalender &amp; Kapazität" />
                                            <WrapPanel Margin="0,14,0,0">
                                                <Border Style="{StaticResource ColorPreviewCardStyle}">
                                                    <StackPanel>
                                                        <Border Height="46" CornerRadius="14" Background="{Binding CalendarLoadWarningColor}" />
                                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Warnstufe" />
                                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Stark ausgelastete Tage" />
                                                        <Button Margin="0,10,0,0" Style="{StaticResource ColorPreviewActionButtonStyle}" Content="Farbe ändern" Command="{Binding PickCalendarLoadWarningColorCommand}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource ColorPreviewCardStyle}">
                                                    <StackPanel>
                                                        <Border Height="46" CornerRadius="14" Background="{Binding CalendarLoadCriticalColor}" />
                                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Kritische Stufe" />
                                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="Kritisch ausgelastete Tage" />
                                                        <Button Margin="0,10,0,0" Style="{StaticResource ColorPreviewActionButtonStyle}" Content="Farbe ändern" Command="{Binding PickCalendarLoadCriticalColorCommand}" />
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>

                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="190" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Warnung ab Personen" />
                                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding CalendarLoadWarningPeopleThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Kritisch ab Personen" />
                                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding CalendarLoadCriticalPeopleThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Route rot ab Rest %" />
                                                <TextBox Grid.Row="2" Grid.Column="1"
                                                         Margin="0,18,0,0"
                                                         Style="{StaticResource SettingsTextBoxStyle}"
                                                         ToolTip="Wenn Restkapazität kleiner oder gleich diesem Prozentwert ist, wird die Tourlinie rot."
                                                         Text="{Binding MapRouteCapacityWarningThresholdPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Details-Panel standardmässig offen" />
                                                <CheckBox Grid.Row="3"
                                                          Grid.Column="1"
                                                          Margin="0,22,0,0"
                                                          Content="Beim Kartenstart direkt anzeigen"
                                                          IsChecked="{Binding MapDetailsPanelExpanded, Mode=TwoWay}" />
                                            </Grid>

                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsFieldCardStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="Route Debounce (ms)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding TomTomRouteRecalcDebounceMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SettingsFieldCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="Max. Tempo Zugfahrzeug (km/h)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding TomTomVehicleOnlyMaxSpeedKmh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsFieldCardStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="Max. Tempo mit Anhänger (km/h)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding TomTomVehicleWithTrailerMaxSpeedKmh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SettingsFieldCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="Verkehrsbewertung" />
                                                <ComboBox Style="{StaticResource SettingsComboBoxStyle}"
                                                          ItemsSource="{Binding TomTomTrafficSeverityOptions}"
                                                          SelectedItem="{Binding SelectedTomTomTrafficSeverityOption, Mode=TwoWay}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DisplayName}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           TextWrapping="Wrap"
                                                           Text="Legt fest, wie streng Verkehrssegmente aus TomTom intern als leicht, mittel oder schwer eingestuft werden." />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsFieldCardStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="05:00 - 06:00 Staupuffer (%)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding TrafficBufferPercentFrom0500To0730, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SettingsFieldCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="06:00 - 09:00 Staupuffer (%)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding TrafficBufferPercentFrom0730To0900, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsFieldCardStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="09:00 - 15:30 Staupuffer (%)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding TrafficBufferPercentFrom0900To1530, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SettingsFieldCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsFieldLabelStyle}" Text="15:30 - 18:30 Staupuffer (%)" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding TrafficBufferPercentFrom1530To1830, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SettingsFieldCardStyle}">
                                            <StackPanel>
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           TextWrapping="Wrap"
                                                           Text="Bis 30 Minuten Fahrzeit wird kein Stauzuschlag gerechnet. Ab 30 Minuten wird je nach Abfahrtszeit des Streckenabschnitts der passende Prozentwert einmalig als ETA-Puffer eingerechnet. Ausserhalb 05:00 bis 18:30 wird aktuell kein Zuschlag angewendet." />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                </StackPanel>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsCategoryKey}" Value="tools">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{StaticResource SettingsFieldCardStyle}">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="GPS" />
                                                <CheckBox Margin="0,14,0,0"
                                                          Content="GPS-Bereich in der Navigation anzeigen"
                                                          IsChecked="{Binding ShowGpsTool, Mode=TwoWay}" />
                                                <TextBlock Margin="0,16,0,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="GPS Standard-Link" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding GpsToolUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Style="{StaticResource SettingsFieldCardStyle}" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Spediteur" />
                                                <CheckBox Margin="0,14,0,0"
                                                          Content="Spediteur-Bereich in der Navigation anzeigen"
                                                          IsChecked="{Binding ShowSpediteurTool, Mode=TwoWay}" />
                                                <TextBlock Margin="0,16,0,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Spediteur Standard-Link" />
                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding SpediteurToolUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsCategoryKey}" Value="backup">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <WrapPanel Margin="0,0,0,16">
                                        <Button Width="160" Margin="0,0,10,10" Content="Backup erstellen" Command="{Binding CreateBackupCommand}" />
                                        <Button Width="160" Margin="0,0,10,10" Content="Backup laden" Command="{Binding RestoreLatestBackupCommand}" />
                                        <Button Width="180" Margin="0,0,0,10" Content="Backups bereinigen" Command="{Binding CleanupBackupsCommand}" />
                                    </WrapPanel>

                                    <Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Backups aktiv" />
                                            <CheckBox Grid.Row="0" Grid.Column="1" Content="Sicherungssystem verwenden" IsChecked="{Binding BackupsEnabled, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Backup-Verzeichnis" />
                                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding BackupDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Backup-Modus" />
                                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource SettingsComboBoxStyle}" ItemsSource="{Binding BackupModes}" SelectedItem="{Binding BackupModeDefault, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Aufbewahrung (Tage)" />
                                            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding BackupRetentionDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Automatische Backups" />
                                            <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,22,0,0" Content="Automatisch im Hintergrund erstellen" IsChecked="{Binding AutoBackupEnabled, Mode=TwoWay}" />
                                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Intervall (Tage)" />
                                            <TextBox Grid.Row="5" Grid.Column="1" Margin="0,18,0,0" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding AutoBackupIntervalDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Border>

                                    <WrapPanel Margin="0,18,0,0">
                                        <Border Style="{StaticResource SettingsMetricCardStyle}" Width="360">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="Letzte vorhandene Sicherung" />
                                                <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="{Binding LatestBackupModifiedText}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           Text="{Binding LatestBackupFile}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsCategoryKey}" Value="xml-import">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <WrapPanel Margin="0,0,0,10">
                                        <Button Width="170" Margin="0,0,10,10" Content="XML-Datei wählen" Command="{Binding BrowseXmlImportFileCommand}" />
                                        <Button Width="220" Margin="0,0,10,10" Content="XML-Musterdatei herunterladen" Command="{Binding DownloadXmlTemplateCommand}" />
                                        <Button Width="150" Margin="0,0,10,10" Content="XML prüfen" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding PreviewXmlImportCommand}" />
                                        <Button Width="170" Margin="0,0,0,10" Content="Import ausführen" Style="{StaticResource SuccessButtonStyle}" Command="{Binding ImportOrdersCommand}" />
                                    </WrapPanel>

                                    <Border Style="{StaticResource SettingsInnerPanelStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="XML-Zuordnung" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       TextWrapping="Wrap"
                                                       Text="Lege hier fest, welche XML-Bezeichnungen den Importfeldern entsprechen. Leere Werte fallen automatisch auf die Standardbezeichnungen der Musterdatei zurück." />

                                            <TextBlock Margin="0,18,0,8" FontWeight="SemiBold" Text="Struktur" />
                                            <ItemsControl ItemsSource="{Binding XmlImportStructureFields}">

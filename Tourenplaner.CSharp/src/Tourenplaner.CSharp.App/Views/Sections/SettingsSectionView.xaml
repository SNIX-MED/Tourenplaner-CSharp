                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           TextWrapping="Wrap"
                                                           Text="Kartenstil, Traffic-Anzeige und Routing-Restriktionen werden direkt in den Map-Options der Karte gesteuert. Fahrzeugmaße kommen aus der Fahrzeugverwaltung." />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

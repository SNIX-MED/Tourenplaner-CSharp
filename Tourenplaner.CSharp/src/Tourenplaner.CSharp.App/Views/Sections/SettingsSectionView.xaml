                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="220" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Margin="0,10,14,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="{Binding ProgramField}" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding XmlName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding DefaultXmlName, StringFormat='{}Standard: {0}'}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Margin="0,12,0,8" FontWeight="SemiBold" Text="Adressfelder" />
                                            <ItemsControl ItemsSource="{Binding XmlImportAddressFields}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="220" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Margin="0,10,14,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="{Binding ProgramField}" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding XmlName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding DefaultXmlName, StringFormat='{}Standard: {0}'}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Margin="0,12,0,8" FontWeight="SemiBold" Text="Auftragsfelder" />
                                            <ItemsControl ItemsSource="{Binding XmlImportOrderFields}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="220" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Margin="0,10,14,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="{Binding ProgramField}" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding XmlName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding DefaultXmlName, StringFormat='{}Standard: {0}'}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Margin="0,12,0,8" FontWeight="SemiBold" Text="Produktfelder" />
                                            <ItemsControl ItemsSource="{Binding XmlImportProductFields}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="220" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Margin="0,10,14,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="{Binding ProgramField}" />
                                                            <StackPanel Grid.Column="1">
                                                                <TextBox Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding XmlName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding DefaultXmlName, StringFormat='{}Standard: {0}'}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="XML-Dateipfad" />
                                            <Button Grid.Column="1"
                                                    Width="38"
                                                    Height="38"
                                                    Margin="0,0,10,0"
                                                    Padding="0"
                                                    ToolTip="XML-Datei auswählen"
                                                    Command="{Binding BrowseXmlImportFileCommand}">
                                                <Image Source="pack://application:,,,/Assets/Ordner.png"
                                                       Width="20"
                                                       Height="20"
                                                       Stretch="Uniform" />
                                            </Button>
                                            <TextBox Grid.Column="2" Style="{StaticResource SettingsTextBoxStyle}" Text="{Binding XmlImportFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </Border>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource SettingsInnerPanelStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ImportStatusMessage}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ImportStatusMessage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding ImportStatusMessage}" TextWrapping="Wrap" />
                                    </Border>

                                    <Border Padding="18"
                                            CornerRadius="22"
                                            Background="#FEF3C7"
                                            BorderBrush="#F59E0B"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasXmlImportPinIssueSummary}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Pins manuell prüfen" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Text="{Binding XmlImportPinIssueSummary}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       Text="Diese importierten Aufträge konnten nicht exakt geokodiert werden und sollten in der Karte oder in den Aufträgen manuell kontrolliert werden."
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource SettingsInnerPanelStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasXmlImportPreview}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Importvorschau" />
                                            <TextBlock Margin="0,6,0,0" Text="{Binding XmlImportPreviewSummary}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       Text="{Binding XmlImportPreviewHiddenItemsText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasXmlImportPreviewHiddenItems}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource SettingsInnerPanelStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasXmlImportPreviewItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Betroffene Aufträge" />
                                            <ScrollViewer Margin="0,14,0,0" MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding XmlImportPreviewItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,10"
                                                                    Padding="12"
                                                                    CornerRadius="14"
                                                                    Background="{DynamicResource Brush.Card}"
                                                                    BorderBrush="{DynamicResource Brush.GlassStroke}"
                                                                    BorderThickness="1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0"
                                                                            VerticalAlignment="Top"
                                                                            Padding="10,5"
                                                                            CornerRadius="999"
                                                                            Background="{Binding ActionBackground}">
                                                                        <TextBlock Foreground="{Binding ActionForeground}"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding ActionLabel}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                                        <TextBlock FontWeight="SemiBold" Text="{Binding OrderId}" />
                                                                        <TextBlock Margin="0,2,0,0" Text="{Binding CustomerLine}" />
                                                                        <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding MetaLine}" />
                                                                        <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap" Text="{Binding ChangeSummary}" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="18"
                                            CornerRadius="22"
                                            Background="#FFF7ED"
                                            BorderBrush="#FDBA74"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasXmlImportPinIssues}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Problematische Pin-Zuordnungen" />
                                            <ScrollViewer Margin="0,14,0,0" MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding XmlImportPinIssueItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,0,0,10"
                                                                    Padding="12"
                                                                    CornerRadius="14"
                                                                    Background="{DynamicResource Brush.Card}"
                                                                    BorderBrush="{DynamicResource Brush.GlassStroke}"
                                                                    BorderThickness="1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Grid.Column="0"
                                                                            VerticalAlignment="Top"
                                                                            Padding="10,5"
                                                                            CornerRadius="999"
                                                                            Background="{Binding IssueBackground}">
                                                                        <TextBlock Foreground="{Binding IssueForeground}"
                                                                                   FontWeight="SemiBold"
                                                                                   Text="{Binding IssueLabel}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                                        <TextBlock FontWeight="SemiBold" Text="{Binding OrderId}" />
                                                                        <TextBlock Margin="0,2,0,0" Text="{Binding CustomerLine}" />
                                                                        <TextBlock Margin="0,2,0,0" Text="{Binding AddressDisplayLine}" TextWrapping="Wrap" />
                                                                        <TextBlock Margin="0,8,0,0"
                                                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                                                   Text="{Binding IssueSummary}"
                                                                                   TextWrapping="Wrap" />
                                                                        <TextBlock Margin="0,4,0,0"
                                                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                                                   Text="{Binding MatchSummary}"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="18"
                                            CornerRadius="22"
                                            Background="{DynamicResource Brush.DangerSoft}"
                                            BorderBrush="{DynamicResource Brush.Danger}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasXmlImportPreviewErrors}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SettingsSubsectionTitleStyle}" Text="Fehlerbericht" />
                                            <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding XmlImportPreviewErrors}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="0,0,0,6" TextWrapping="Wrap" Text="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsCategoryKey}" Value="updates">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Style="{StaticResource SettingsInnerPanelStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Installierte Version" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Text="{Binding ApplicationVersion}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Update-Status" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" TextWrapping="Wrap" Text="{Binding UpdateStatusText}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzte Prüfung" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" Text="{Binding LastUpdateCheckText}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Verfügbare Version" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,18,0,0" Text="{Binding AvailableUpdateVersion}" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Veröffentlicht" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,18,0,0" Text="{Binding UpdatePublishedAtText}" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsInnerPanelStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzter Start" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding StartupStatusText}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Zeitpunkt" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" Text="{Binding StartupRecordedAtText}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzter Schritt" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" Text="{Binding StartupLastStepText}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Detail" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,18,0,0" TextWrapping="Wrap" Text="{Binding StartupDetailText}" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsInnerPanelStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Sync-Modus" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding SyncModeText}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Sync-Status" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" TextWrapping="Wrap" Text="{Binding SyncStatusText}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzte Statusänderung" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" Text="{Binding LastSyncStatusChangeText}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzte externe Änderung" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,18,0,0" Text="{Binding LastRemoteSyncText}" />
                                            <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzte lokale Änderung" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,18,0,0" Text="{Binding LastLocalSyncText}" />
                                            <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzte Aktivität" />
                                            <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,18,0,0" Text="{Binding LastSyncActivityText}" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsInnerPanelStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="170" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Update-Konfig" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding UpdateConfigPath}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Diagnose-Datei" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,18,0,0" TextWrapping="Wrap" Text="{Binding DiagnosticsFilePath}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Crash-Log" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,18,0,0" TextWrapping="Wrap" Text="{Binding CrashLogPath}" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,18,12,0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Letzter Sync-Fehler" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,18,0,0" TextWrapping="Wrap" Text="{Binding SyncErrorText}" />
                                        </Grid>
                                    </Border>

                                    <WrapPanel Margin="0,0,0,0">
                                        <Button Width="210" Margin="0,0,10,10" Content="Jetzt nach Updates suchen" Command="{Binding CheckForUpdatesCommand}" />
                                        <Button Width="170" Margin="0,0,10,10" Content="Konfiguration prüfen" Command="{Binding ValidateCommand}" />
                                        <Button Width="180"
                                                Margin="0,0,0,10"
                                                Content="Update herunterladen"
                                                Command="{Binding DownloadAvailableUpdateCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CanDownloadAvailableUpdate}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2"
                                Visibility="Collapsed"
                                Margin="0,26,0,0"
                                Padding="16"
                                CornerRadius="18"
                                Background="#F5F0FF"
                                BorderBrush="#DCCFFF"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="34"
                                        Height="34"
                                        CornerRadius="17"
                                        Background="#FFFFFF">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="16"
                                               Foreground="#7C3AED"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE946;" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock FontWeight="SemiBold" Text="Hinweis" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               TextWrapping="Wrap"
                                               Text="Änderungen werden teils direkt übernommen, teils nach dem Speichern. Einzelne Bereiche wie Updates oder Importprüfungen aktualisieren ihren Status zusätzlich automatisch." />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Padding="16"
                        CornerRadius="18"
                        Background="{DynamicResource Brush.DangerSoft}"
                        BorderBrush="{DynamicResource Brush.Danger}"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ValidationSummary}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ValidationSummary}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Prüfung" />
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap" Text="{Binding ValidationSummary}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>



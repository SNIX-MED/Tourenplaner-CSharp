<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.NonMapOrdersSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Tourenplaner.CSharp.App.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <Style x:Key="OrdersGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource Brush.TableBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="OrdersGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.CardMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="OrdersGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="MinHeight" Value="60" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.RowHover}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.RowSelected}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsArchived}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.DangerSoft}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsArchived}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFDE2E2" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsArchived}" Value="True" />
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFACACA" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OrdersGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="PrimaryTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,1,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="QuickActionsContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Popup.AllowsTransparency" Value="True" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="2"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True">
                            <StackPanel>
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionsMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.CardMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource Spacing.PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,12" Style="{StaticResource FilterBarCardStyle}" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Height="40"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource Brush.InputBorder}"
                        BorderThickness="1"
                        Background="{DynamicResource Brush.InputBackground}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontFamily="Segoe Fluent Icons"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="&#xE721;" />
                        <Grid Grid.Column="1">
                            <TextBox BorderThickness="0"
                                     Background="Transparent"
                                     ToolTip="Suche nach Nummer, Auftraggeber, Lieferadresse oder Tour"
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock IsHitTestVisible="False"
                                       Margin="2,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.TextSubtle}"
                                       Text="Suche...">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="FilterPopupButton"
                            Width="92"
                            Margin="8,0,0,0"
                            Content="Filter"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Popup x:Name="FilterPopup"
                           PlacementTarget="{Binding ElementName=FilterPopupButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Style="{StaticResource SoftCardStyle}"
                                Margin="0,6,0,0"
                                Padding="12"
                                MinWidth="360">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Margin="0,0,0,8" Text="Filter" />
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="Lieferart" />
                                <ComboBox Height="36"
                                          Margin="0,4,0,8"
                                          ItemsSource="{Binding DeliveryTypeFilterOptions}"
                                          SelectedItem="{Binding SelectedDeliveryTypeFilter, Mode=TwoWay}" />
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="Status" />
                                <ComboBox Height="36"
                                          Margin="0,4,0,10"
                                          ItemsSource="{Binding StatusFilterOptions}"
                                          SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}" />
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="Ansicht" />
                                <Border Margin="0,4,0,0"
                                        CornerRadius="13"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource Brush.BorderSoft}"
                                        Background="{DynamicResource Brush.CardMuted}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Margin="4"
                                                Height="34"
                                                Content="Aktiv"
                                                Command="{Binding ShowActiveOrdersCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowActiveOrders}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Margin="4"
                                                Height="34"
                                                Content="Archiviert"
                                                Command="{Binding ShowArchivedOrdersCommand}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowArchivedOrders}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Button x:Name="ColumnsPopupButton"
                            Width="92"
                            Margin="8,0,0,0"
                            Content="Spalten"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    <Popup x:Name="ColumnsPopup"
                           PlacementTarget="{Binding ElementName=ColumnsPopupButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Style="{StaticResource SoftCardStyle}"
                                Margin="0,6,0,0"
                                Padding="10"
                                MinWidth="190">
                            <StackPanel>
                                <CheckBox Margin="0,0,0,8"
                                          Content="Auftraggeber"
                                          IsChecked="{Binding IsCustomerColumnVisible, Mode=TwoWay}" />
                                <CheckBox Margin="0,0,0,8"
                                          Content="Lieferadresse"
                                          IsChecked="{Binding IsDeliveryAddressColumnVisible, Mode=TwoWay}" />
                                <CheckBox Content="Lieferperson"
                                          IsChecked="{Binding IsDeliveryPersonColumnVisible, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Button Width="92" Margin="8,0,0,0" Content="Zurück" Command="{Binding UndoDeleteCommand}" />
                    <Button Width="152"
                            Margin="8,0,0,0"
                            Content="Manuell hinzufügen"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding AddManualOrderCommand}" />
                    <Button Width="96"
                            Margin="8,0,0,0"
                            Content="Löschen"
                            Style="{StaticResource DangerOutlineButtonStyle}"
                            Command="{Binding RemoveCommand}" />
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0,12,0,0"
                        Padding="10,8"
                        CornerRadius="12"
                        BorderBrush="{DynamicResource Brush.BorderSoft}"
                        BorderThickness="1"
                        Background="{DynamicResource Brush.CardMuted}">
                    <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding StatusText}" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="0" Background="Transparent" BorderThickness="0">
            <Border BorderBrush="{DynamicResource Brush.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Background="{DynamicResource Brush.CardMuted}">
                <controls:RoundedClipBorder Margin="1"
                                            CornerRadius="13"
                                            Background="{DynamicResource Brush.TableBackground}"
                                            ClipToBounds="True">
                    <DataGrid x:Name="NonMapOrdersGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FrozenColumnCount="2"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              SnapsToDevicePixels="True"
                              ItemsSource="{Binding NonMapOrders}"
                              SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                              PreviewMouseRightButtonDown="NonMapOrdersGrid_PreviewMouseRightButtonDown"
                              Style="{StaticResource OrdersGridStyle}"
                              ColumnHeaderStyle="{StaticResource OrdersGridHeaderStyle}"
                              RowStyle="{StaticResource OrdersGridRowStyle}"
                              CellStyle="{StaticResource OrdersGridCellStyle}">
                        <DataGrid.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Style="{StaticResource QuickActionsContextMenuStyle}">
                                <ContextMenu.Resources>
                                    <Style TargetType="Separator">
                                        <Setter Property="Margin" Value="8,4" />
                                        <Setter Property="Background" Value="{DynamicResource Brush.BorderSoft}" />
                                    </Style>
                                </ContextMenu.Resources>
                                <MenuItem Header="Auftragsnummer kopieren"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding CopySelectedOrderNumberCommand}" />
                                <MenuItem Header="Auftrag bearbeiten"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding EditSelectedOrderCommand}" />
                                <MenuItem Header="{Binding ToggleArchiveSelectedOrderMenuText}"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding ToggleArchiveSelectedOrderCommand}" />
                                <Separator />
                                <MenuItem Header="Auftrag löschen"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding RemoveCommand}"
                                          Foreground="{DynamicResource Brush.Danger}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditSelectedOrderCommand}" />
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Auftragsnummer" Width="150" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Id}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   FontSize="20"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                            <Setter Property="Foreground" Value="Black" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Auftragsdatum" Width="130" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ScheduledDate}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="Black" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                            <Setter Property="Foreground" Value="Black" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="CustomerColumn" Header="Auftraggeber" Width="2.1*" MinWidth="180" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding OrderAddressName}" />
                                        <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding OrderAddressLine}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="DeliveryAddressColumn" Header="Lieferadresse" Width="1.9*" MinWidth="180" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding DeliveryStreetLine}" />
                                        <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding DeliveryPostalCityLine}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="DeliveryPersonColumn" Header="Lieferperson" Width="1.7*" MinWidth="170" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding DeliveryPersonPrimary}" />
                                        <TextBlock Text="{Binding DeliveryPersonSecondary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DeliveryPersonSecondary}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Lieferart / Status" Width="1.25*" MinWidth="170" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding DeliveryType}" />
                                        <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding OrderStatus}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="68" IsReadOnly="True">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text=" " />
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="36"
                                            Height="36"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Padding="0"
                                            Click="OnOpenOrderClick"
                                            Style="{StaticResource SecondaryButtonStyle}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="18">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <TextBlock FontFamily="Segoe Fluent Icons"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="&#xE72A;" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </controls:RoundedClipBorder>
            </Border>
        </Border>
    </Grid>
</UserControl>

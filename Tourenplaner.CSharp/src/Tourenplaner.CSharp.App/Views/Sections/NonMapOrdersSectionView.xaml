<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.NonMapOrdersSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Tourenplaner.CSharp.App.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="OrdersGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="{DynamicResource Brush.TableBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="OrdersGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="{DynamicResource Brush.TableHeaderBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TableHeaderForeground}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="OrdersGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.RowHover}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.RowSelected}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsArchived}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.DangerSoft}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsArchived}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFDE2E2" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsArchived}" Value="True" />
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFACACA" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OrdersGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="DeliveryTypeBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="DeliveryTypeBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DeliveryStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="1,2,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PrepaymentBadgeStyle" TargetType="Border">
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="5,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#111827" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Visibility" Value="{Binding IstVorauszahlung, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Style>

        <Style x:Key="PrepaymentBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Text" Value="VZ" />
        </Style>

        <Style x:Key="PrimaryTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="QuickActionsContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Popup.AllowsTransparency" Value="True" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="2"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True">
                            <StackPanel>
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionsMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.CardMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource Spacing.PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,4"
                Background="Transparent"
                BorderThickness="0"
                Visibility="{Binding IsNonMapOrdersFilterPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="430">
                <Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource FilterPanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                   Text="&#xE8EF;" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Auftragstyp" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Art des Auftrags"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="1"
                                            Margin="0,16,0,0">
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FilterPanelOptionBorderStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IncludeOpenOrders}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <CheckBox Style="{StaticResource FilterPanelOptionCheckBoxStyle}"
                                                  AutomationProperties.Name="Offene Aufträge"
                                                  IsChecked="{Binding IncludeOpenOrders, Mode=TwoWay}">
                                            <TextBlock Text="Offene Aufträge"
                                                       TextWrapping="Wrap" />
                                        </CheckBox>
                                    </Border>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource FilterPanelOptionBorderStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IncludePlannedOrders}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <CheckBox Style="{StaticResource FilterPanelOptionCheckBoxStyle}"
                                                  AutomationProperties.Name="Eingeplante Aufträge"
                                                  IsChecked="{Binding IncludePlannedOrders, Mode=TwoWay}">
                                            <TextBlock Text="Eingeplante Aufträge"
                                                       TextWrapping="Wrap" />
                                        </CheckBox>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource FilterPanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                   Text="&#xE8D4;" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Auftragsstatus" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Status des Auftrags"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl Grid.Row="1"
                                              Margin="0,16,0,0"
                                              ItemTemplate="{StaticResource FilterPanelOptionTemplate}"
                                              ItemsSource="{Binding OrderStatusFilters}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource FilterPanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                   Text="&#xE806;" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Lieferart" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Art der Lieferung"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl Grid.Row="1"
                                              Margin="0,16,0,0"
                                              ItemTemplate="{StaticResource FilterPanelOptionTemplate}"
                                              ItemsSource="{Binding DeliveryTypeFilters}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="3"
                                Style="{StaticResource FilterPanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                   Text="&#xE7ED;" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Avisierungsstatus" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Status der Avisierung"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <ItemsControl Grid.Row="1"
                                              Margin="0,16,0,0"
                                              ItemTemplate="{StaticResource FilterPanelOptionTemplate}"
                                              ItemsSource="{Binding AvisoStatusFilters}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="4"
                                Style="{StaticResource FilterPanelCardStyle}"
                                Width="Auto"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                        <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                   Text="&#xE80F;" />
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,0,0">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="Lieferant" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Auswahl des Lieferanten"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            MinWidth="150"
                                            Margin="16,0,0,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Content="{Binding ToggleAllFiltersButtonText}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ToggleAllOrderFiltersCommand}"
                                            AutomationProperties.Name="Alle Filter auswählen oder abwählen" />
                                </Grid>
                                <ItemsControl Grid.Row="1"
                                              Margin="0,16,0,0"
                                              ItemTemplate="{StaticResource SupplierFilterPanelOptionTemplate}"
                                              ItemsSource="{Binding SupplierFilters}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"
                                                       ItemWidth="195" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="10"
                Visibility="Collapsed">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                    <Setter Property="Effect" Value="{x:Null}" />
                </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          MaxHeight="430">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource FilterPanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                               Text="&#xE806;" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="12,0,0,0">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Lieferart" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="Art der Lieferung"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                            <ComboBox Grid.Row="1"
                                      Height="36"
                                      Margin="0,16,0,0"
                                      ItemsSource="{Binding DeliveryTypeFilterOptions}"
                                      SelectedItem="{Binding SelectedDeliveryTypeFilter, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Style="{StaticResource FilterPanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                               Text="&#xE8D4;" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="12,0,0,0">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Status" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="Status des Auftrags"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                            <ComboBox Grid.Row="1"
                                      Height="36"
                                      Margin="0,16,0,0"
                                      ItemsSource="{Binding StatusFilterOptions}"
                                      SelectedItem="{Binding SelectedStatusFilter, Mode=TwoWay}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource FilterPanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                               Text="&#xE8A5;" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="12,0,0,0">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="Ansicht" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="Aktive oder archivierte Aufträge"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                            <Border Grid.Row="1"
                                    Margin="0,16,0,0"
                                    CornerRadius="13"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    Background="{DynamicResource Brush.CardMuted}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Margin="4"
                                            Height="34"
                                            Content="Aktiv"
                                            Command="{Binding ShowActiveOrdersCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowActiveOrders}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Margin="4"
                                            Height="34"
                                            Content="Archiviert"
                                            Command="{Binding ShowArchivedOrdersCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowArchivedOrders}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>



        <Border Grid.Row="1" Padding="0" Background="Transparent" BorderThickness="0">
            <Border BorderBrush="{DynamicResource Brush.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Background="{DynamicResource Brush.CardMuted}">
                <controls:RoundedClipBorder Margin="1"
                                            CornerRadius="13"
                                            Background="{DynamicResource Brush.TableBackground}"
                                            ClipToBounds="True">
                    <DataGrid x:Name="NonMapOrdersGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              FrozenColumnCount="2"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              SnapsToDevicePixels="True"
                              ItemsSource="{Binding NonMapOrders}"
                              SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                              PreviewMouseRightButtonDown="NonMapOrdersGrid_PreviewMouseRightButtonDown"
                              Style="{StaticResource OrdersGridStyle}"
                              ColumnHeaderStyle="{StaticResource OrdersGridHeaderStyle}"
                              RowStyle="{StaticResource OrdersGridRowStyle}"
                              CellStyle="{StaticResource OrdersGridCellStyle}">
                        <DataGrid.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         Style="{StaticResource QuickActionsContextMenuStyle}">
                                <ContextMenu.Resources>
                                    <Style TargetType="Separator">
                                        <Setter Property="Margin" Value="8,4" />
                                        <Setter Property="Background" Value="{DynamicResource Brush.BorderSoft}" />
                                    </Style>
                                </ContextMenu.Resources>
                                <MenuItem Header="Auftragsnummer kopieren"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding CopySelectedOrderNumberCommand}" />
                                <MenuItem Header="Auftrag bearbeiten"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding EditSelectedOrderCommand}" />
                                <MenuItem Header="{Binding ToggleArchiveSelectedOrderMenuText}"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding ToggleArchiveSelectedOrderCommand}" />
                                <Separator />
                                <MenuItem Header="Auftrag löschen"
                                          Style="{StaticResource QuickActionsMenuItemStyle}"
                                          Command="{Binding RemoveCommand}"
                                          Foreground="{DynamicResource Brush.Danger}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditSelectedOrderCommand}" />
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Auftragsnummer" Width="150" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <StackPanel Margin="6,0,0,0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Id}"
                                                       VerticalAlignment="Center"
                                                       FontSize="17"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border Style="{StaticResource PrepaymentBadgeStyle}">
                                                <TextBlock Style="{StaticResource PrepaymentBadgeTextStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Auftragsdatum" Width="130" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ScheduledDate}" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="CustomerColumn" Header="Auftraggeber" Width="2.1*" MinWidth="180" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding OrderAddressName}" />
                                        <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding OrderAddressLine}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="DeliveryAddressColumn" Header="Lieferadresse" Width="1.9*" MinWidth="180" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding DeliveryStreetLine}" />
                                        <TextBlock Style="{StaticResource SecondaryTextStyle}" Text="{Binding DeliveryPostalCityLine}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn x:Name="DeliveryPersonColumn" Header="Lieferperson" Width="1.7*" MinWidth="170" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PrimaryTextStyle}" Text="{Binding DeliveryPersonPrimary}" />
                                        <TextBlock Text="{Binding DeliveryPersonSecondary}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DeliveryPersonSecondary}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Lieferart / Status" Width="1.25*" MinWidth="170" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <Border x:Name="DeliveryTypeBadge"
                                                HorizontalAlignment="Left"
                                                Background="{Binding OrderStatusBadgeBackground}"
                                                BorderBrush="{Binding OrderStatusBadgeBorderBrush}"
                                                Tag="{Binding OrderStatusBadgeForeground}"
                                                Style="{StaticResource DeliveryTypeBadgeStyle}">
                                            <TextBlock Style="{StaticResource DeliveryTypeBadgeTextStyle}" Text="{Binding DeliveryType}" />
                                        </Border>
                                        <TextBlock Style="{StaticResource DeliveryStatusTextStyle}" Text="{Binding OrderStatus}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </controls:RoundedClipBorder>
            </Border>
        </Border>
    </Grid>
</UserControl>

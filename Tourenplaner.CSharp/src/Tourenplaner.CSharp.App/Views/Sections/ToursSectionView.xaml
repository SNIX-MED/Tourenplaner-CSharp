<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.ToursSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1080">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="SemiBold" />

        <DockPanel Grid.Row="1" Margin="0,12,0,12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Width="180"
                        Margin="8,0,0,0"
                        Content="Reload Tours"
                        Command="{Binding RefreshCommand}" />
                <Button Width="220"
                        Margin="8,0,0,0"
                        Content="Recalculate ETA/ETD"
                        Command="{Binding RecalculateCommand}" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="#334155"
                       Text="{Binding StatusText}" />
        </DockPanel>

        <GroupBox Grid.Row="2" Header="Selected Tour Assignment" Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Date (dd.MM.yyyy)" />
                <TextBox Grid.Column="1" Margin="6,0,0,0" Text="{Binding EditorDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" Text="Start (HH:mm)" />
                <TextBox Grid.Column="3" Margin="6,0,0,0" Text="{Binding EditorStartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="4" Margin="12,0,0,0" VerticalAlignment="Center" Text="Vehicle" />
                <ComboBox Grid.Column="5"
                          Margin="6,0,0,0"
                          ItemsSource="{Binding AvailableVehicles}"
                          SelectedItem="{Binding SelectedVehicle, Mode=TwoWay}"
                          DisplayMemberPath="Label" />

                <Button Grid.Column="6"
                        Width="150"
                        Margin="12,0,0,0"
                        Content="Save Assignment"
                        Command="{Binding SaveAssignmentCommand}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Top" Text="Trailer" />
                <ComboBox Grid.Row="1"
                          Grid.Column="1"
                          Margin="6,10,0,0"
                          ItemsSource="{Binding AvailableTrailers}"
                          SelectedItem="{Binding SelectedTrailer, Mode=TwoWay}"
                          DisplayMemberPath="Label" />

                <TextBlock Grid.Row="1" Grid.Column="2" Margin="12,10,0,0" VerticalAlignment="Top" Text="Employees (max 2)" />
                <ScrollViewer Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="3" Margin="6,10,0,0" VerticalScrollBarVisibility="Auto" MaxHeight="90">
                    <ItemsControl ItemsSource="{Binding AvailableEmployees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,2,0,2"
                                          Content="{Binding Label}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="1"
                           Grid.Column="6"
                           Margin="12,10,0,0"
                           TextWrapping="Wrap"
                           Foreground="#7C2D12"
                           Text="{Binding EditorConflictText}" />
            </Grid>
        </GroupBox>

        <DataGrid Grid.Row="3"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding Tours}"
                  SelectedItem="{Binding SelectedTour, Mode=TwoWay}"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding TourId}" Width="60" />
                <DataGridTextColumn Header="Tour" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="110" />
                <DataGridTextColumn Header="Start" Binding="{Binding Start}" Width="80" />
                <DataGridTextColumn Header="End" Binding="{Binding End}" Width="80" />
                <DataGridTextColumn Header="Vehicle" Binding="{Binding VehicleId}" Width="120" />
                <DataGridTextColumn Header="Trailer" Binding="{Binding TrailerId}" Width="120" />
                <DataGridTextColumn Header="Employees" Binding="{Binding Employees}" Width="2*" />
                <DataGridTextColumn Header="Stops" Binding="{Binding StopCount}" Width="70" />
                <DataGridTextColumn Header="Stop Conflicts" Binding="{Binding StopConflicts}" Width="120" />
                <DataGridTextColumn Header="Assign Conflicts" Binding="{Binding AssignmentConflicts}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <GroupBox Grid.Row="4" Margin="0,12,0,0" Header="Stops for Selected Tour">
            <DataGrid AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding SelectedTourStops}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Order}" Width="50" />
                    <DataGridTextColumn Header="Stop" Binding="{Binding Name}" Width="2*" />
                    <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="2*" />
                    <DataGridTextColumn Header="Time Window" Binding="{Binding Window}" Width="130" />
                    <DataGridTextColumn Header="ETA" Binding="{Binding Arrival}" Width="80" />
                    <DataGridTextColumn Header="ETD" Binding="{Binding Departure}" Width="80" />
                    <DataGridTextColumn Header="Conflict" Binding="{Binding Conflict}" Width="2*" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</UserControl>

<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.ToursSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1450">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource FlatCardStyle}" Padding="12">
            <GroupBox Header="Touren">
                <DataGrid AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Tours}"
                          SelectedItem="{Binding SelectedTour, Mode=TwoWay}"
                          MouseDoubleClick="OnToursGridMouseDoubleClick"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Datum" Width="130" Binding="{Binding Date}" />
                        <DataGridTextColumn Header="Name" Width="2*" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Fahrzeug" Width="2*" Binding="{Binding VehicleId}" />
                        <DataGridTextColumn Header="Mitarbeiter" Width="2*" Binding="{Binding Employees}" />
                        <DataGridTextColumn Header="Stopps" Width="90" Binding="{Binding StopCount}" />
                        <DataGridTextColumn Header="Totalgewicht" Width="130" Binding="{Binding TotalWeightKg}" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Border>

        <GridSplitter Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Height="8"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      Background="{DynamicResource Brush.BorderSoft}" />

        <Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FlatCardStyle}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <GroupBox Header="Stopps in ausgewählter Tour">
                    <DataGrid AutoGenerateColumns="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding SelectedTourStops}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Width="50" Binding="{Binding Order}" />
                            <DataGridTextColumn Header="Auftragsnummer" Width="130" Binding="{Binding OrderNumber}" />
                            <DataGridTextColumn Header="Adresse / Name" Width="*" Binding="{Binding Name}" />
                            <DataGridTextColumn Header="Gewicht" Width="90" Binding="{Binding Weight}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <Border Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource SoftCardStyle}" Padding="10">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="{Binding SelectedTourWeightText}" />
                        <TextBlock Margin="0,4,0,0"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedTourLoadSummaryText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTourLoadSummaryText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedTourVehicleText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Height="40"
                    Margin="0,0,8,0"
                    Content="Tour auf Karte anzeigen"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding OpenTourOnMapCommand}" />
            <Button Grid.Column="1" Height="40" Margin="8,0,8,0" Content="Tour bearbeiten" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding EditTourOnMapCommand}" />
            <Button Grid.Column="2" Height="40" Margin="8,0,0,0" Content="Tour löschen" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteTourCommand}" />
        </Grid>
    </Grid>
</UserControl>

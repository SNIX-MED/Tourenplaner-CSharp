<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.ToursSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Tourenplaner.CSharp.App.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1450">
    <UserControl.Resources>
        <Style x:Key="MultiLineGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToursGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource Brush.TableBackground}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="Transparent" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="ToursGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.CardMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToursGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.TableGrid}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.RowHover}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.RowSelected}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsArchived}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.DangerSoft}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsArchived}" Value="True" />
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFDE2E2" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsArchived}" Value="True" />
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="#FFFACACA" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToursGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.RowSelected}" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                        <Condition Binding="{Binding DataContext.IsArchived, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToursGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TourStopCardsListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="TourStopCardListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionsContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Popup.AllowsTransparency" Value="True" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="2"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True">
                            <StackPanel>
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionsMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.CardMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource Spacing.PageMargin}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" MinWidth="560" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="2.05*" MinWidth="720" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource FlatCardStyle}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Left" FontSize="14" FontWeight="SemiBold" Text="Tourenübersicht" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Width="94"
                                    Margin="0,0,8,0"
                                    Content="Aktiv"
                                    Command="{Binding ShowActiveToursCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowActiveTours}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Width="110"
                                    Margin="0,0,8,0"
                                    Content="Archiviert"
                                    Command="{Binding ShowArchivedToursCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowArchivedTours}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                                <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                        <Border DockPanel.Dock="Right"
                                Padding="8,3"
                                CornerRadius="10"
                                Background="{DynamicResource Brush.SurfaceAlt}">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="{Binding FilterInfoText}" />
                        </Border>
                    </DockPanel>

                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource Brush.BorderSoft}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Background="{DynamicResource Brush.CardMuted}">
                        <controls:RoundedClipBorder Margin="1"
                                                    CornerRadius="13"
                                                    Background="{DynamicResource Brush.TableBackground}"
                                                    ClipToBounds="True">
                            <DataGrid x:Name="ToursGrid"
                                  AutoGenerateColumns="False"
                                  AllowDrop="True"
                                  IsReadOnly="True"
                                  SnapsToDevicePixels="True"
                                  ItemsSource="{Binding Tours}"
                                  Style="{StaticResource ToursGridStyle}"
                                  RowStyle="{StaticResource ToursGridRowStyle}"
                                  CellStyle="{StaticResource ToursGridCellStyle}"
                                  ColumnHeaderStyle="{StaticResource ToursGridHeaderStyle}"
                                  SelectedItem="{Binding SelectedTour, Mode=TwoWay}"
                                  PreviewMouseRightButtonDown="ToursGrid_PreviewMouseRightButtonDown"
                                  DragOver="ToursGrid_DragOver"
                                  DragLeave="ToursGrid_DragLeave"
                                  Drop="ToursGrid_Drop"
                                  MouseDoubleClick="OnToursGridMouseDoubleClick">
                            <DataGrid.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                             Style="{StaticResource QuickActionsContextMenuStyle}">
                                    <ContextMenu.Resources>
                                        <Style TargetType="Separator">
                                            <Setter Property="Margin" Value="8,4" />
                                            <Setter Property="Background" Value="{DynamicResource Brush.BorderSoft}" />
                                        </Style>
                                    </ContextMenu.Resources>
                                    <MenuItem Header="Tour bearbeiten"
                                              Style="{StaticResource QuickActionsMenuItemStyle}"
                                              Command="{Binding EditTourOnMapCommand}" />
                                    <MenuItem Header="Tour anzeigen"
                                              Style="{StaticResource QuickActionsMenuItemStyle}"
                                              Command="{Binding OpenTourOnMapCommand}" />
                                    <MenuItem Header="{Binding ToggleArchiveTourButtonText}"
                                              Style="{StaticResource QuickActionsMenuItemStyle}"
                                              Command="{Binding ToggleArchiveTourCommand}" />
                                    <Separator />
                                    <MenuItem Header="Tour löschen"
                                              Style="{StaticResource QuickActionsMenuItemStyle}"
                                              Command="{Binding DeleteTourCommand}"
                                              Foreground="{DynamicResource Brush.Danger}" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                <DataGridTextColumn Header="Datum" Width="112" Binding="{Binding Date}" ElementStyle="{StaticResource ToursGridTextStyle}" />
                                <DataGridTextColumn Header="Tour" Width="3.45*" Binding="{Binding Name}" ElementStyle="{StaticResource ToursGridTextStyle}" />
                                <DataGridTextColumn Header="Mitarbeiter" Width="92" Binding="{Binding Employees}" ElementStyle="{StaticResource ToursGridTextStyle}" />
                                <DataGridTextColumn Header="Stopps" Width="64" Binding="{Binding StopCount}" ElementStyle="{StaticResource ToursGridTextStyle}" />
                                <DataGridTextColumn Header="Gewicht (kg)" Width="92" Binding="{Binding TotalWeightKg}" ElementStyle="{StaticResource ToursGridTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </controls:RoundedClipBorder>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Width="8"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          Background="{DynamicResource Brush.BorderSoft}" />

            <Border Grid.Column="2" Margin="12,0,0,0" Style="{StaticResource FlatCardStyle}" Padding="12" Effect="{x:Null}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Stopps in ausgewählter Tour" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="{Binding SelectedTour.Name, TargetNullValue=Keine Tour ausgewählt}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Border Padding="10,4"
                                    CornerRadius="11"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource Brush.SurfaceAlt}">
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="{Binding SelectedTourStops.Count, StringFormat=Stopps: {0}}" />
                            </Border>

                            <Border Margin="0,6,0,0"
                                    Padding="10,8"
                                    CornerRadius="11"
                                    HorizontalAlignment="Right"
                                    Background="{DynamicResource Brush.AccentSoft}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasDragPreview}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="Drag Vorschau" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                               Text="{Binding DragPreviewEtaText}" />
                                    <TextBlock Margin="0,1,0,0"
                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                               Text="{Binding DragPreviewDurationText}" />
                                    <TextBlock Margin="0,1,0,0"
                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                               Text="{Binding DragPreviewDistanceText}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource Brush.BorderSoft}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Background="{DynamicResource Brush.TableBackground}"
                            Padding="12"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True"
                            TextOptions.TextFormattingMode="Display"
                            TextOptions.TextRenderingMode="ClearType"
                            RenderOptions.ClearTypeHint="Enabled">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ListBox x:Name="SelectedTourStopsGrid"
                                     ItemsSource="{Binding SelectedTourStops}"
                                     SelectedItem="{Binding SelectedTourStop, Mode=TwoWay}"
                                     AllowDrop="True"
                                     ContextMenuOpening="OnSelectedTourStopContextMenuOpening"
                                     PreviewMouseLeftButtonDown="SelectedTourStopsGrid_PreviewMouseLeftButtonDown"
                                     PreviewMouseRightButtonDown="SelectedTourStopsGrid_PreviewMouseRightButtonDown"
                                     MouseMove="SelectedTourStopsGrid_MouseMove"
                                     DragOver="SelectedTourStopsGrid_DragOver"
                                     DragLeave="SelectedTourStopsGrid_DragLeave"
                                     Drop="SelectedTourStopsGrid_Drop"
                                     UseLayoutRounding="True"
                                     SnapsToDevicePixels="True"
                                     TextOptions.TextFormattingMode="Display"
                                     TextOptions.TextRenderingMode="ClearType"
                                     RenderOptions.ClearTypeHint="Enabled"
                                     Style="{StaticResource TourStopCardsListStyle}"
                                     ItemContainerStyle="{StaticResource TourStopCardListItemStyle}">
                                <ListBox.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                 Style="{StaticResource QuickActionsContextMenuStyle}">
                                        <ContextMenu.Resources>
                                            <Style TargetType="Separator">
                                                <Setter Property="Margin" Value="8,4" />
                                                <Setter Property="Background" Value="{DynamicResource Brush.BorderSoft}" />
                                            </Style>
                                        </ContextMenu.Resources>
                                        <MenuItem Header="Aufenthaltszeit ändern"
                                                  Style="{StaticResource QuickActionsMenuItemStyle}"
                                                  Click="OnSelectedTourStopEditStayMenuItemClick" />
                                        <MenuItem Header="Stopp entfernen"
                                                  Style="{StaticResource QuickActionsMenuItemStyle}"
                                                  Foreground="{DynamicResource Brush.Danger}"
                                                  Click="OnSelectedTourStopRemoveMenuItemClick" />
                                        <Separator />
                                        <MenuItem Header="Auftrag bearbeiten"
                                                  Style="{StaticResource QuickActionsMenuItemStyle}"
                                                  Click="OnSelectedTourStopEditOrderMenuItemClick" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="14"
                                                BorderThickness="1"
                                                Margin="0,0,0,10"
                                                UseLayoutRounding="True"
                                                SnapsToDevicePixels="True"
                                                TextOptions.TextFormattingMode="Display"
                                                TextOptions.TextRenderingMode="ClearType"
                                                RenderOptions.ClearTypeHint="Enabled">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                                    <Setter Property="Padding" Value="12" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
                                                    <Setter Property="Effect" Value="{x:Null}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRouteStart}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#7BC6A4" />
                                                            <Setter Property="Background" Value="#F2FBF6" />
                                                            <Setter Property="Padding" Value="6,4" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRouteEnd}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#8EC6E8" />
                                                            <Setter Property="Background" Value="#F2F9FF" />
                                                            <Setter Property="Padding" Value="6,4" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="84" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="38"
                                                        Height="38"
                                                        CornerRadius="19"
                                                        VerticalAlignment="Top"
                                                        HorizontalAlignment="Center"
                                                        Background="#4EBA74">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Order}"
                                                               Foreground="White"
                                                               FontWeight="SemiBold"
                                                               FontSize="16"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>

                                                <TextBlock Text="{Binding Order}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           Visibility="Collapsed">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <StackPanel Grid.Column="1" Margin="8,0,6,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Margin" Value="8,0,6,0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                    <Setter Property="Margin" Value="2,0,4,0" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Brush.TextPrimary}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontSize" Value="17" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                        <Setter Property="FontSize" Value="12" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Address}"
                                                               Margin="0,2,0,0"
                                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding Window, StringFormat=Zeitfenster: {0}}"
                                                                   Foreground="{DynamicResource Brush.TextMuted}" />
                                                        <TextBlock Text="  |  "
                                                                   Margin="8,0,0,0"
                                                                   Foreground="{DynamicResource Brush.TextMuted}" />
                                                        <TextBlock Text="{Binding Departure, StringFormat=Abfahrt: {0}}"
                                                                   Foreground="{DynamicResource Brush.TextSecondary}" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayTime}"
                                                               HorizontalAlignment="Right"
                                                               FontWeight="SemiBold"
                                                               FontSize="18"
                                                               Foreground="{DynamicResource Brush.TextPrimary}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="FontSize" Value="18" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                        <Setter Property="FontSize" Value="12" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock HorizontalAlignment="Right"
                                                               Foreground="{DynamicResource Brush.TextMuted}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Ankunft" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRouteStart}" Value="True">
                                                                        <Setter Property="Text" Value="Start" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRouteEnd}" Value="True">
                                                                        <Setter Property="Text" Value="Ende" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCompanyStop}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,0,12,0"
                                Style="{StaticResource SoftCardStyle}"
                                Padding="10"
                                Effect="{x:Null}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True"
                                TextOptions.TextFormattingMode="Display"
                                TextOptions.TextRenderingMode="ClearType"
                                RenderOptions.ClearTypeHint="Enabled">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding SelectedTourWeightText}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedTourLoadSummaryText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedTourLoadSummaryText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           TextWrapping="Wrap"
                                           Text="{Binding SelectedTourVehicleText}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1" Width="220" Orientation="Vertical">
                            <Button Height="36"
                                    Margin="0,0,0,8"
                                    Content="Tour auf Karte anzeigen"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding OpenTourOnMapCommand}" />
                            <Button Height="36"
                                    Margin="0,0,0,8"
                                    Content="Tour bearbeiten"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding EditTourOnMapCommand}" />
                            <Button Height="36"
                                    Content="Tour löschen"
                                    Style="{StaticResource DangerOutlineButtonStyle}"
                                    Command="{Binding DeleteTourCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.ToursSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1450">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,10" Style="{StaticResource FlatCardStyle}" Padding="10">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="SemiBold" FontSize="19" Text="Datumsfilter" />
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding FilterInfoText}" />
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <TextBox x:Name="FromDateTextBox"
                                 Height="38"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Von (DD.MM.YYYY)"
                                 Text="{Binding FromDateText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   IsHitTestVisible="False"
                                   Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat={}{0:dd.MM.yyyy}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=FromDateTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Grid Grid.Column="1" Margin="8,0">
                        <TextBox x:Name="ToDateTextBox"
                                 Height="38"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Bis (DD.MM.YYYY)"
                                 Text="{Binding ToDateText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   IsHitTestVisible="False"
                                   Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat={}{0:dd.MM.yyyy}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=ToDateTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Column="2" Margin="8,0,0,0" Height="38" Content="Übernehmen" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ApplyDateFilterCommand}" />
                </Grid>

                <UniformGrid Margin="0,10,0,0" Rows="1" Columns="4">
                    <Button Content="Heute" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding FilterTodayCommand}" />
                    <Button Margin="8,0,0,0" Content="Morgen" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding FilterTomorrowCommand}" />
                    <Button Margin="8,0,0,0" Content="Diese Woche" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding FilterThisWeekCommand}" />
                    <Button Margin="8,0,0,0" Content="Reset" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ResetDateFilterCommand}" />
                </UniformGrid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource FlatCardStyle}" Padding="10">
            <GroupBox Header="Touren">
                <DataGrid AutoGenerateColumns="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding Tours}"
                          SelectedItem="{Binding SelectedTour, Mode=TwoWay}"
                          MouseDoubleClick="OnToursGridMouseDoubleClick"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Datum" Width="130" Binding="{Binding Date}" />
                        <DataGridTextColumn Header="Name" Width="2*" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Fahrzeug" Width="2*" Binding="{Binding VehicleId}" />
                        <DataGridTextColumn Header="Mitarbeiter" Width="2*" Binding="{Binding Employees}" />
                        <DataGridTextColumn Header="Stopps" Width="90" Binding="{Binding StopCount}" />
                        <DataGridTextColumn Header="Totalgewicht" Width="130" Binding="{Binding TotalWeightKg}" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Border>

        <GridSplitter Grid.Row="2"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Height="8"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      Background="{DynamicResource Brush.BorderSoft}" />

        <Border Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource FlatCardStyle}" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <GroupBox Header="Stopps in ausgewählter Tour">
                    <DataGrid AutoGenerateColumns="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding SelectedTourStops}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Width="50" Binding="{Binding Order}" />
                            <DataGridTextColumn Header="Auftragsnummer" Width="130" Binding="{Binding OrderNumber}" />
                            <DataGridTextColumn Header="Adresse / Name" Width="*" Binding="{Binding Name}" />
                            <DataGridTextColumn Header="Gewicht" Width="90" Binding="{Binding Weight}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <TextBlock Grid.Row="1" Margin="4,10,0,0" FontWeight="SemiBold" Text="{Binding SelectedTourWeightText}" />
                <TextBlock Grid.Row="2" Margin="4,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding SelectedTourVehicleText}" />
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Height="40"
                    Margin="0,0,8,0"
                    Content="Tour auf Karte anzeigen"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding OpenTourOnMapCommand}" />
            <Button Grid.Column="1" Height="40" Margin="8,0,8,0" Content="Tour bearbeiten" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding EditTourOnMapCommand}" />
            <Button Grid.Column="2" Height="40" Margin="8,0,0,0" Content="Tour löschen" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteTourCommand}" />
        </Grid>
    </Grid>
</UserControl>

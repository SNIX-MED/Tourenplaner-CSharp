<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.UpdatesSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="1000">
    <Grid Margin="{StaticResource Spacing.PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionHeaderCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource SectionHeaderTitleTextStyle}" Text="{Binding Title}" />
                    <TextBlock Style="{StaticResource SectionHeaderSubtitleTextStyle}"
                               Text="Version, Runtime und Update-Feed zentral prüfen und verwalten." />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="13"
                               Text="{Binding StatusText}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Width="120"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}" />
                    <Button Width="150"
                            Margin="{StaticResource Spacing.ButtonInlineLeftMargin}"
                            Content="Open Update Feed"
                            Command="{Binding OpenUpdateFeedCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="{StaticResource Spacing.BlockTopMargin}"
                BorderBrush="{DynamicResource Brush.GlassStroke}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12"
                Background="{DynamicResource Brush.GlassSurfaceStrong}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Application Version" />
                <TextBlock Grid.Row="0" Grid.Column="1" Margin="8,4,0,4" VerticalAlignment="Center" Text="{Binding ApplicationVersion}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text=".NET Runtime Version" />
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="8,4,0,4" VerticalAlignment="Center" Text="{Binding RuntimeVersion}" />

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Last Backup (ISO)" />
                <TextBlock Grid.Row="2" Grid.Column="1" Margin="8,4,0,4" VerticalAlignment="Center" Text="{Binding LastBackupIso}" />

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Latest Backup File" />
                <TextBlock Grid.Row="3" Grid.Column="1" Margin="8,4,0,4" VerticalAlignment="Center" Text="{Binding LatestBackupFile}" />

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Available Backup Files" />
                <TextBlock Grid.Row="4" Grid.Column="1" Margin="8,4,0,4" VerticalAlignment="Center" Text="{Binding AvailableBackupsCount}" />

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Update Feed URL" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Margin="8,4,0,4"
                         Text="{Binding UpdateFeedUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

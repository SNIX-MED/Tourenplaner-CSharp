<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.KalenderSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="920"
             d:DesignWidth="1400">
    <UserControl.Resources>
        <Style x:Key="StartUpcomingCardStyle" TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
            <Setter Property="Padding" Value="4" />
            <Setter Property="Height" Value="62" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="40" FontWeight="Bold" Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{DynamicResource Brush.TextMuted}"
                       Text="{Binding Description}" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource SoftCardStyle}" Padding="14">
            <StackPanel>
                <TextBlock FontSize="31" FontWeight="SemiBold" Text="Kalender der naechsten 4 Wochen" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Text="Vier Wochen im Ueberblick, gruppiert nach Kalenderwochen." />

                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding UpcomingWeeks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,6,0"
                                    Padding="8"
                                    CornerRadius="12"
                                    Background="{DynamicResource Brush.CardSoft}"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                               Text="{Binding Label}" />

                                    <ListBox Margin="0,8,0,0"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ItemsSource="{Binding Days}"
                                             SelectedItem="{Binding DataContext.SelectedUpcomingDay, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin" Value="0,0,0,6" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding LoadBackground}"
                                                        BorderBrush="{Binding LoadBorderBrush}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="84" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding LoadForeground}"
                                                                       Text="{Binding DateText}" />
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{Binding LoadForeground}"
                                                                   Opacity="0.9"
                                                                   FontSize="9"
                                                                   MaxHeight="24"
                                                                   Text="{Binding SummaryText}" />
                                                    </Grid>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource StartUpcomingCardStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Margin="0,14,0,0" Style="{StaticResource FlatCardStyle}" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="27" FontWeight="SemiBold" Text="{Binding SelectedDayHeadline}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Width="180" Margin="0,0,8,0" Content="Tag in Liefertouren" Command="{Binding OpenSelectedDayInToursCommand}" />
                        <Button Width="130" Margin="0,0,8,0" Content="Tour öffnen" Command="{Binding OpenSelectedTourCommand}" />
                        <Button Width="130" Content="Tour loeschen" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteSelectedTourCommand}" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,10"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Text="{Binding StatusText}" />

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding SelectedDayTours}"
                         SelectedItem="{Binding SelectedDayTour, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Style="{StaticResource FlatCardStyle}" Padding="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding Summary}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Brush.TextMuted}">
                                            <Run Text="Fahrzeug: " />
                                            <Run Text="{Binding VehicleId}" />
                                            <Run Text=" | Mitarbeiter: " />
                                            <Run Text="{Binding Employees}" />
                                            <Run Text=" | Stopps: " />
                                            <Run Text="{Binding StopCount}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" Text="{Binding StartTime}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.KalenderSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="920"
             d:DesignWidth="1400"
             PreviewMouseWheel="OnPagePreviewMouseWheel"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <Style x:Key="SharpFlatCardStyle" TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpSoftCardStyle" TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpFilterBarCardStyle" TargetType="Border" BasedOn="{StaticResource FilterBarCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="StartUpcomingCardStyle" TargetType="Border" BasedOn="{StaticResource SharpFlatCardStyle}">
            <Setter Property="Padding" Value="6,5" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="WeekNavButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="86" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="18"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.CardSoft}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  IsManipulationEnabled="True"
                  PanningMode="VerticalFirst">
    <StackPanel Margin="6">

        <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource WeekNavButtonStyle}"
                    Command="{Binding PreviousWeekRangeCommand}"
                    ToolTip="Eine Woche zurück">
                <Path Width="10"
                      Height="16"
                      Data="M 8 2 L 3 8 L 8 14"
                      Stroke="{DynamicResource Brush.TextMuted}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round" />
            </Button>

            <ItemsControl Grid.Column="1" ItemsSource="{Binding UpcomingWeeks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,0"
                                Padding="8"
                                CornerRadius="12"
                                Background="{DynamicResource Brush.CardSoft}"
                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           Text="{Binding Label}" />

                                <ItemsControl Margin="0,6,0,0"
                                              ItemsSource="{Binding Days}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding LoadBackground}"
                                                    Margin="0,0,6,6"
                                                    Cursor="Hand"
                                                    PreviewMouseLeftButtonDown="OnUpcomingDayCardMouseLeftButtonDown">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding LoadForeground}"
                                                               Text="{Binding DateText}" />

                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,2,0,0"
                                                               VerticalAlignment="Top"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               Foreground="{Binding LoadForeground}"
                                                               Opacity="0.95"
                                                               FontSize="11"
                                                               Text="{Binding TourCountText}" />

                                                    <TextBlock Grid.Row="2"
                                                               Margin="0,2,0,0"
                                                               VerticalAlignment="Top"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               Foreground="{Binding LoadForeground}"
                                                               Opacity="0.9"
                                                               FontSize="11"
                                                               Text="{Binding SummaryText}" />
                                                </Grid>
                                                <Border.ToolTip>
                                                    <ToolTip MaxWidth="360">
                                                        <StackPanel>
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding DateText}" />
                                                            <TextBlock Margin="0,3,0,0" FontWeight="SemiBold" Text="{Binding TourCountText}" />
                                                            <TextBlock Margin="0,6,0,0"
                                                                       TextWrapping="Wrap"
                                                                       Text="{Binding SummaryText}" />
                                                        </StackPanel>
                                                    </ToolTip>
                                                </Border.ToolTip>
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource StartUpcomingCardStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPast}" Value="True">
                                                                <Setter Property="Opacity" Value="0.58" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="BorderThickness" Value="2" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderThickness" Value="2" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Grid.Column="2"
                    VerticalAlignment="Center"
                    Style="{StaticResource WeekNavButtonStyle}"
                    Command="{Binding NextWeekRangeCommand}"
                    ToolTip="Eine Woche vor">
                <Path Width="10"
                      Height="16"
                      Data="M 2 2 L 7 8 L 2 14"
                      Stroke="{DynamicResource Brush.TextMuted}"
                      StrokeThickness="2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round" />
            </Button>
        </Grid>

        <Border Margin="0,14,0,0" Style="{StaticResource SharpFlatCardStyle}" Padding="14">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding SelectedDayHeadline}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Width="170" Margin="0,0,8,0" Command="{Binding OpenSplitScreenCommand}" Style="{StaticResource SecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="||" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Split-Ansicht" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Width="130" Margin="0,0,8,0" Content="Tour öffnen" Command="{Binding OpenSelectedTourCommand}" />
                        <Button Width="130" Content="Tour löschen" Style="{StaticResource DangerOutlineButtonStyle}" Command="{Binding DeleteSelectedTourCommand}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="0,8,0,10" Style="{StaticResource SharpSoftCardStyle}" Padding="10">
                    <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding StatusText}" />
                </Border>

                <ItemsControl Grid.Row="2" ItemsSource="{Binding SelectedDayManualEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8"
                                    Padding="8"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="{DynamicResource Brush.CardSoft}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="8"
                                            Height="8"
                                            Margin="0,5,0,0"
                                            CornerRadius="4"
                                            Background="{Binding ColorHex}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="{Binding TimeText}" />
                                            <Run Text=" " />
                                            <Run Text="{Binding Title}" />
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ListBox Grid.Row="3"
                         ItemsSource="{Binding SelectedDayTours}"
                         SelectedItem="{Binding SelectedDayTour, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         PreviewMouseWheel="OnPagePreviewMouseWheel"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,12,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="360"
                                        Padding="10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SharpFlatCardStyle}">
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           Text="{Binding DateText}" />
                                                <TextBlock FontWeight="SemiBold"
                                                           FontSize="16"
                                                           Text="{Binding Name}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Width="36"
                                                    Height="36"
                                                    Margin="8,0,6,0"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    ToolTip="Tour auf Karte anzeigen"
                                                    Click="OnOpenTourOnMapClicked">
                                                <Image Width="24"
                                                       Height="24"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       SnapsToDevicePixels="True"
                                                       Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Pin.png" />
                                            </Button>
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                       Text="{Binding StartTime}" />
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,6,0,8"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="{Binding Summary}" />

                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Stops}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Style="{StaticResource SharpSoftCardStyle}"
                                                            Padding="10"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="OnTourStopCardMouseLeftButtonDown">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="24"
                                                                    Height="24"
                                                                    CornerRadius="12"
                                                                    Background="{DynamicResource Brush.AccentSoft}"
                                                                    VerticalAlignment="Top"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.Accent}"
                                                                           Text="{Binding StopLetter}" />
                                                            </Border>

                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{DynamicResource Brush.TextSubtle}"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding OrderAddress}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding DeliveryAddress}" />
                                                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding ProductLines}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock FontSize="12"
                                                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding}" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Margin="0,6,0,0"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           Text="{Binding WeightText}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
        </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>





<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.KalenderSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="920"
             d:DesignWidth="1400"
             PreviewMouseWheel="OnPagePreviewMouseWheel"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <Style x:Key="SharpFlatCardStyle" TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpSoftCardStyle" TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpFilterBarCardStyle" TargetType="Border" BasedOn="{StaticResource FilterBarCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="StartUpcomingCardStyle" TargetType="Border" BasedOn="{StaticResource SharpFlatCardStyle}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="MinHeight" Value="66" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  IsManipulationEnabled="True"
                  PanningMode="VerticalFirst">
    <StackPanel Margin="{StaticResource Spacing.PageMargin}">

        <Border Margin="0,14,0,0" Style="{StaticResource SharpFilterBarCardStyle}">
            <StackPanel>
                <ItemsControl Margin="0,0,0,0" ItemsSource="{Binding UpcomingWeeks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    Padding="10"
                                    CornerRadius="14"
                                    Background="{DynamicResource Brush.CardSoft}"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                               Text="{Binding Label}" />

                                    <ItemsControl Margin="0,8,0,0"
                                                  ItemsSource="{Binding Days}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding LoadBackground}"
                                                        Margin="0,0,0,6"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="OnUpcomingDayCardMouseLeftButtonDown">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="88" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding LoadForeground}"
                                                                   Text="{Binding DateText}" />

                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{Binding LoadForeground}"
                                                                   Opacity="0.9"
                                                                   FontSize="12"
                                                                   Text="{Binding SummaryText}" />
                                                    </Grid>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource StartUpcomingCardStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Margin="0,14,0,0" Style="{StaticResource SharpFlatCardStyle}" Padding="14">
                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding SelectedDayHeadline}" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Width="170" Margin="0,0,8,0" Command="{Binding OpenSplitScreenCommand}" Style="{StaticResource SecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="⧉" Margin="0,0,6,0" VerticalAlignment="Center" />
                                <TextBlock Text="Split-Ansicht" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Width="180" Margin="0,0,8,0" Content="Tag in Liefertouren" Command="{Binding OpenSelectedDayInToursCommand}" />
                        <Button Width="130" Margin="0,0,8,0" Content="Tour öffnen" Command="{Binding OpenSelectedTourCommand}" />
                        <Button Width="130" Content="Tour löschen" Style="{StaticResource DangerOutlineButtonStyle}" Command="{Binding DeleteSelectedTourCommand}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Margin="0,8,0,10" Style="{StaticResource SharpSoftCardStyle}" Padding="10">
                    <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="{Binding StatusText}" />
                </Border>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding SelectedDayTours}"
                         SelectedItem="{Binding SelectedDayTour, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         PreviewMouseWheel="OnPagePreviewMouseWheel"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         ScrollViewer.CanContentScroll="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,12,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Width="360"
                                        Padding="10">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SharpFlatCardStyle}">
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="BorderThickness" Value="2" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           Text="{Binding DateText}" />
                                                <TextBlock FontWeight="SemiBold"
                                                           FontSize="16"
                                                           Text="{Binding Name}" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Width="36"
                                                    Height="36"
                                                    Margin="8,0,6,0"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    ToolTip="Tour auf Karte anzeigen"
                                                    Click="OnOpenTourOnMapClicked">
                                                <Image Width="24"
                                                       Height="24"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       SnapsToDevicePixels="True"
                                                       Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Pin.png" />
                                            </Button>
                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                       Text="{Binding StartTime}" />
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,6,0,8"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="{Binding Summary}" />

                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Stops}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Style="{StaticResource SharpSoftCardStyle}"
                                                            Padding="10"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="OnTourStopCardMouseLeftButtonDown">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="24"
                                                                    Height="24"
                                                                    CornerRadius="12"
                                                                    Background="{DynamicResource Brush.AccentSoft}"
                                                                    VerticalAlignment="Top"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.Accent}"
                                                                           Text="{Binding StopLetter}" />
                                                            </Border>

                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{DynamicResource Brush.TextSubtle}"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding OrderAddress}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding DeliveryAddress}" />
                                                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding ProductLines}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock FontSize="12"
                                                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding}" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Margin="0,6,0,0"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           Text="{Binding WeightText}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                </ListBox>
                </Grid>
        </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>




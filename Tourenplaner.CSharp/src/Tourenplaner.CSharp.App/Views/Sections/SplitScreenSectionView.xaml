<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.SplitScreenSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Tourenplaner.CSharp.App.ViewModels.Sections"
             xmlns:v="clr-namespace:Tourenplaner.CSharp.App.Views.Sections"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1500">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:KarteSectionViewModel}">
            <v:KarteSectionView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="{StaticResource Spacing.PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource FilterBarCardStyle}" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Split-Ansicht: Karte &amp; Tourenübersicht" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Text="Karte rechts, Tages-/Tourenübersicht links. Diese Ansicht nutzt die volle Fensterfläche." />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="170"
                        Height="38"
                        Content="Ansicht verlassen"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding LeaveViewCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SoftCardStyle}" Padding="12" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="8,2"
                                Content="‹"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding PreviousDayCommand}" />
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedDayCompactText}" HorizontalAlignment="Center" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       Text="{Binding CalendarSection.StatusText}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Margin="8,0,0,0"
                                Padding="8,2"
                                Content="›"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding NextDayCommand}" />
                        <Button Grid.Column="3"
                                Margin="12,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="42"
                                Height="42"
                                Padding="0"
                                ToolTip="Tour auf Karte"
                                Command="{Binding OpenSelectedTourOnMapCommand}">
                            <Image Width="22"
                                   Height="22"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True"
                                   Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Pin.png" />
                        </Button>
                    </Grid>

                    <ListBox Grid.Row="1" Margin="0,10,0,0"
                             ItemsSource="{Binding CalendarSection.SelectedDayTours}"
                             SelectedItem="{Binding CalendarSection.SelectedDayTour, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="10"
                                        Style="{StaticResource FlatCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           Text="{Binding DateText}" />
                                                <TextBlock FontWeight="SemiBold"
                                                           FontSize="16"
                                                           Text="{Binding Name}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                       Text="{Binding StartTime}" />
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                           Margin="0,4,0,8"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="{Binding Summary}" />

                                        <ItemsControl Grid.Row="2" ItemsSource="{Binding Stops}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Style="{StaticResource SoftCardStyle}"
                                                            Padding="10">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="24"
                                                                    Height="24"
                                                                    CornerRadius="12"
                                                                    Background="{DynamicResource Brush.AccentSoft}"
                                                                    VerticalAlignment="Top"
                                                                    HorizontalAlignment="Left">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.Accent}"
                                                                           Text="{Binding StopLetter}" />
                                                            </Border>

                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{DynamicResource Brush.TextSubtle}"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding OrderAddress}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding DeliveryAddress}" />
                                                                <ItemsControl Margin="0,6,0,0" ItemsSource="{Binding ProductLines}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock FontSize="12"
                                                                                       Foreground="{DynamicResource Brush.TextPrimary}"
                                                                                       TextWrapping="Wrap"
                                                                                       Text="{Binding}" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Margin="0,6,0,0"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           Text="{Binding WeightText}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="True"
                          Background="{DynamicResource Brush.BorderSoft}" />

            <Border Grid.Column="2" Style="{StaticResource FlatCardStyle}" Padding="4" Margin="6,0,0,0">
                <ContentControl Content="{Binding MapSection}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>

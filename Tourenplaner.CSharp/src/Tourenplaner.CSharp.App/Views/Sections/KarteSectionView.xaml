                                        Margin="0,6,0,0"
                                        VerticalAlignment="Top"
                                        Background="{Binding DetailOrderStatusBadgeBackgroundColor, Mode=OneWay}"
                                        BorderBrush="{Binding DetailOrderStatusColor, Mode=OneWay}"
                                        Style="{StaticResource DetailOrderStatusBadgeStyle}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding DetailOrderStatusColor, Mode=OneWay}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DetailOrderStatus, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="2"
                                      Grid.Column="1"
                                      Grid.ColumnSpan="4"
                                      Margin="0,6,0,0"
                                      VerticalAlignment="Top">
                                    <ComboBox MinHeight="38"
                                              VerticalAlignment="Top"
                                              ItemsSource="{Binding AvisoStatusOptions}"
                                              ToolTip="Nur verfügbar bei zugeordneter Tour."
                                              SelectedItem="{Binding DetailSelectedAvisoStatus, Mode=TwoWay}">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>
                                    <Border MinHeight="38"
                                            Padding="10,6"
                                            CornerRadius="12"
                                            Background="{DynamicResource Brush.CardSoft}"
                                            BorderBrush="{DynamicResource Brush.BorderSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Nicht eingeplant" />
                                    </Border>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDetailsOpen}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Margin="0,0,6,0"
                                                Padding="10"
                                                CornerRadius="12"
                                                Background="{DynamicResource Brush.AccentSurface}"
                                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Lieferadresse:" />
                                                <TextBlock Margin="0,4,0,0" Text="{Binding DetailCustomer}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Margin="6,0,0,0"
                                                Width="160"
                                                HorizontalAlignment="Left"
                                                Padding="10"
                                                CornerRadius="12"
                                                Background="{DynamicResource Brush.CardSoft}"
                                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <Grid>
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Text="Kontaktdaten:" />
                                                </Grid>
                                                <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" Text="E-Mail:" />
                                                <TextBlock Margin="0,2,0,0"
                                                           Text="{Binding DetailEmail}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Telefon:" />
                                                <TextBlock Text="{Binding DetailPhone}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DetailNotes}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DetailNotes}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Border Margin="0,0,0,0"
                                                Padding="10"
                                                CornerRadius="12"
                                                Background="{DynamicResource Brush.CardSoft}"
                                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding DetailNotes}"
                                                       TextWrapping="Wrap"
                                                       FontWeight="Bold"
                                                       Foreground="#DC2626" />
                                        </Border>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DetailProductItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="Produkte:" />
                                        <ComboBox Grid.Column="1"
                                                  Margin="6,0,0,0"
                                                  Width="160"
                                                  Height="34"
                                                  HorizontalAlignment="Left"
                                                  ItemsSource="{Binding DetailProductDeliveryStatusOptions}"
                                                  SelectedItem="{Binding DetailSelectedProductStatus, Mode=TwoWay}" />
                                    </Grid>
                                </StackPanel>

                                <ScrollViewer x:Name="DetailsScrollViewer"
                                              Grid.Row="1"
                                              Margin="0,0,0,10"
                                              VerticalScrollBarVisibility="Auto"
                                              PreviewMouseWheel="OnDetailsPreviewMouseWheel">
                                    <StackPanel>
                                        <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding DetailProductItems}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DetailProductItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="10"
                                                            CornerRadius="10"
                                                            Background="{Binding BackgroundColor}"
                                                            MouseLeftButtonDown="OnDetailProductMouseLeftButtonDown">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{Binding BorderColor}" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="Background" Value="{Binding BackgroundColor}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                        <Setter Property="BorderThickness" Value="3" />
                                                                        <Setter Property="Background" Value="#E8F1FF" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Title}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Margin="12,0,0,0"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                                               Text="{Binding Supplier}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasSupplier}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                                <StackPanel Margin="0,4,0,0"
                                                                            Orientation="Horizontal">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasDimensions}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <Ellipse Width="5"
                                                                             Height="5"
                                                                             Margin="0,0,8,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{DynamicResource Brush.Accent}" />
                                                                    <TextBlock Text="{Binding DimensionsLine}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                </StackPanel>
                                                                <Grid Margin="0,4,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0"
                                                                                Orientation="Horizontal">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="5"
                                                                                     Height="5"
                                                                                     Margin="0,0,8,0"
                                                                                     VerticalAlignment="Center"
                                                                                     Fill="{DynamicResource Brush.Accent}" />
                                                                            <TextBlock Text="{Binding WeightLine}"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Margin="18,0,0,0">
                                                                            <Ellipse Width="5"
                                                                                     Height="5"
                                                                                     Margin="0,0,8,0"
                                                                                     VerticalAlignment="Center"
                                                                                     Fill="{DynamicResource Brush.Accent}" />
                                                                            <TextBlock Text="{Binding TotalLine}"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1"
                                                                               Margin="12,0,0,0"
                                                                               VerticalAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{Binding BorderColor}"
                                                                               Text="{Binding DeliveryStatus}" />
                                                                </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Keine Produkte vorhanden.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DetailProductItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </StackPanel>
                                </ScrollViewer>

                                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                    <TextBlock FontWeight="SemiBold" Text="Lieferart:" />
                                    <TextBlock Text="{Binding DetailDeliveryType}" />
                                </StackPanel>

                                <StackPanel Grid.Row="3" Margin="0,0,0,8">
                                    <Border Margin="0,0,0,8"
                                            Padding="8,6"
                                            CornerRadius="10"
                                            Background="{DynamicResource Brush.AccentSurface}"
                                            BorderBrush="{DynamicResource Brush.BorderSoft}"
                                            BorderThickness="1"
                                            Visibility="{Binding HasSelectedBatchOrders, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Foreground="{DynamicResource Brush.TextMuted}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedBatchOrderSummary}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Foreground="{DynamicResource Brush.TextSubtle}"
                                                       FontSize="11"
                                                       Text="Pins mit Strg+Klick markieren oder im Pin-Popup auswählen." />
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="0,0,0,8"
                                          Visibility="{Binding HasSelectedBatchOrders, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Height="34"
                                                Content="Markierte hinzufügen"
                                                Style="{StaticResource SuccessButtonStyle}"
                                                Command="{Binding AddSelectedOrdersToRouteCommand}" />
                                        <Button Grid.Column="1"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Content="Markierte entfernen"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding RemoveSelectedOrdersFromTourCommand}" />
                                        <Button Grid.Column="2"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Content="Auswahl leeren"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ClearSelectedOrdersCommand}" />
                                    </Grid>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Button Height="36"
                                                Margin="0"
                                                Content="Zu Tour hinzufügen"
                                                Style="{StaticResource SuccessButtonStyle}"
                                                Command="{Binding AddToRouteCommand}" />
                                    </Grid>

                                     <Grid>
                                         <Grid.Style>
                                             <Style TargetType="Grid">
                                                 <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                         </Grid.Style>
                                        <Button
                                                Height="36"
                                                Margin="0"
                                                Content="Tour anzeigen"
                                                ToolTip="Nur verfügbar bei zugeordneter Tour."
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ShowSelectedOrderTourCommand}" />
                                     </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>











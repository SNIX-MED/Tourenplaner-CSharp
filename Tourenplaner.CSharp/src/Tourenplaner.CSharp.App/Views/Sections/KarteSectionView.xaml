<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.KarteSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1500">
    <UserControl.Resources>
        <Style x:Key="DetailsToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="104" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailsHeaderToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailsRailButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="RouteStopsGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="CanUserSortColumns" Value="False" />
        </Style>

        <Style x:Key="RouteStopsCenterTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource FilterBarCardStyle}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Karte"
                           FontSize="24"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0" />
                <TextBox Grid.Column="1"
                         Height="40"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"
                         ToolTip="Ort suchen (Enter)..."
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="2" Height="40" Margin="0,0,10,0" Content="Suchen" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding RefreshCommand}" />
                <ComboBox Grid.Column="3"
                          Height="40"
                          Margin="0,0,10,0"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                          VerticalAlignment="Center" />
                <Button Grid.Column="4" Height="40" Content="Route exportieren" Style="{StaticResource SuccessButtonStyle}" Command="{Binding ExportRouteCommand}" />
            </Grid>
        </Border>

        <Expander Grid.Row="1" IsExpanded="False" Header="Legende" Margin="0,0,0,10">
            <Border Style="{StaticResource SoftCardStyle}" Padding="12" Margin="0,6,0,0">
                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="Pin-Form = Lieferart | Pin-Farbe = Auftragsstatus bzw. Tourstatus | Blaue Linie = aktuelle Route" />
            </Border>
        </Expander>

        <Border Grid.Row="2" Style="{StaticResource FlatCardStyle}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="460" MinWidth="320" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SoftCardStyle}" Padding="12" Margin="0,0,6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="210" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="164" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Aktuelle Route" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      Margin="8,0,6,0"
                                      Height="34"
                                      MinWidth="140"
                                      ItemsSource="{Binding SavedTours}"
                                      SelectedItem="{Binding SelectedSavedTour, Mode=TwoWay}"
                                      DisplayMemberPath="Label" />
                            <Button Grid.Column="2"
                                    Height="34"
                                    Content="Bearbeiten"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding EditSelectedTourCommand}" />
                            <Button Grid.Column="3"
                                    Height="34"
                                    MinWidth="38"
                                    Margin="4,0,0,0"
                                    Padding="0"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding OpenCreateTourDialogCommand}">
                                <TextBlock Text="+"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Grid.Column="4"
                                    Height="34"
                                    Margin="4,0,0,0"
                                    Content="X"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding LeaveSelectedTourCommand}" />
                        </Grid>

                        <Border Grid.Row="1" Margin="0,10,0,10" Style="{StaticResource FlatCardStyle}" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="108" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Startzeit" Margin="0,0,8,0" />
                                <TextBox Grid.Column="1" Height="34" Text="{Binding RouteStartHour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" />
                                <TextBlock Grid.Column="2" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBox Grid.Column="3" Height="34" Text="{Binding RouteStartMinute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" />
                                <Button Grid.Column="4" Height="34" Margin="10,0,8,0" Content="Übernehmen" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ApplyStartTimeCommand}" />
                                <Button Grid.Column="5" Height="34" Content="Route optimieren" Style="{StaticResource SuccessButtonStyle}" Command="{Binding OptimizeRouteCommand}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Background="{DynamicResource Brush.TableBackground}"
                                ClipToBounds="True">
                            <DataGrid x:Name="RouteStopsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      AllowDrop="True"
                                      HeadersVisibility="Column"
                                      ItemsSource="{Binding RouteStops}"
                                      SelectedItem="{Binding SelectedRouteStop, Mode=TwoWay}"
                                      MouseDoubleClick="RouteStopsGrid_MouseDoubleClick"
                                      PreviewMouseLeftButtonDown="RouteStopsGrid_PreviewMouseLeftButtonDown"
                                      MouseMove="RouteStopsGrid_MouseMove"
                                      DragOver="RouteStopsGrid_DragOver"
                                      Drop="RouteStopsGrid_Drop"
                                      Style="{StaticResource RouteStopsGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Width="42" Binding="{Binding DisplayPosition}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="Adresse / Name" Width="*" Binding="{Binding DisplayName}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="Fenster" Width="92" Binding="{Binding DisplayOrder}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="Aufenthalt" Width="96" Binding="{Binding DisplayStay}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="ETA" Width="72" Binding="{Binding DisplayEta}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Row="3" Margin="0,10,0,8" Style="{StaticResource SoftCardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding RouteTotalWeightText}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           Text="{Binding RouteLoadSummaryText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RouteLoadSummaryText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0" Text="{Binding RouteTimingSummary}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource FlatCardStyle}" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Fahrzeiten" FontWeight="SemiBold" />
                                <TextBox Grid.Row="1"
                                         Margin="0,8,0,0"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"
                                         Text="{Binding DriveTimesText, Mode=OneWay}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="5" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="?" Command="{Binding MoveStopUpCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="1" Content="?" Margin="8,0,0,0" Command="{Binding MoveStopDownCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="2" Content="Entfernen" Margin="8,0,0,0" Command="{Binding RemoveFromRouteCommand}" Style="{StaticResource DangerButtonStyle}" />
                            <Button Grid.Column="3" Content="Speichern" Margin="8,0,0,0" Command="{Binding SaveCurrentTourCommand}" Style="{StaticResource SuccessButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns"
                              ShowsPreview="True"
                              Background="{DynamicResource Brush.BorderSoft}" />

                <Border Grid.Column="2" Style="{StaticResource FlatCardStyle}" Padding="4" Margin="6,0,10,0">
                    <Grid>
                        <Border BorderBrush="{DynamicResource Brush.BorderSoft}" BorderThickness="1" CornerRadius="14" Background="{DynamicResource Brush.Card}" />
                        <wv2:WebView2 x:Name="MapWebView" Margin="1" />
                        <TextBlock x:Name="MapFallbackNotice"
                                   Margin="16"
                                   VerticalAlignment="Top"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Text="Karte nicht verfügbar. Der Workflow bleibt über die Liste nutzbar." />
                    </Grid>
                </Border>

                <Border Grid.Column="3" Padding="4" Margin="0,0,8,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDetailsOpen}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDetailsPanelExpanded}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Button Command="{Binding ToggleDetailsPanelCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DetailsRailButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDetailsPanelExpanded}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="{Binding DetailsToggleGlyph}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Column="4" Margin="-4,0,0,0">
                    <Border Width="390" Padding="12" HorizontalAlignment="Right">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDetailsOpen}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDetailsPanelExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Details" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource DetailsHeaderToggleButtonStyle}"
                                        Command="{Binding ToggleDetailsPanelCommand}">
                                    <TextBlock Text="{Binding DetailsToggleGlyph}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDetailsOpen}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ScrollViewer Grid.Row="0" Margin="0,0,0,10" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Auftragsadresse:" />
                                        <TextBlock Text="{Binding DetailAddress}" TextWrapping="Wrap" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Lieferadresse:" />
                                        <TextBlock Text="{Binding DetailCustomer}" TextWrapping="Wrap" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Auftragsnummer:" />
                                        <TextBlock Text="{Binding DetailOrderNumber}" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Produkte:" />
                                        <TextBlock Text="{Binding DetailProducts}" TextWrapping="Wrap" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Lieferart:" />
                                        <TextBlock Text="{Binding DetailDeliveryType}" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Auftragsstatus:" />
                                        <TextBlock Text="{Binding DetailOrderStatus}" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Avisierungsstatus:" />
                                        <TextBlock Text="{Binding DetailAvisoStatus}" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Tourstatus:" />
                                        <TextBlock Text="{Binding DetailTourStatus}" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="E-Mail:" />
                                        <TextBlock Text="{Binding DetailEmail}" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Telefon:" />
                                        <TextBlock Text="{Binding DetailPhone}" />
                                    </StackPanel>
                                </ScrollViewer>

                                <Grid Grid.Row="1" Margin="0,0,0,10" IsSharedSizeScope="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Height="36"
                                            Margin="0,0,4,0"
                                            Content="E Mail senden"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SendEmailCommand}" />
                                    <ComboBox Grid.Column="1"
                                              Height="36"
                                              Margin="4,0,0,0"
                                              VerticalAlignment="Top"
                                              ItemsSource="{Binding AvisoStatusOptions}"
                                              IsEnabled="{Binding CanEditDetailAvisoStatus}"
                                              ToolTip="Nur verfügbar bei zugeordneter Tour."
                                              SelectedItem="{Binding DetailSelectedAvisoStatus, Mode=TwoWay}" />
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Height="36" Margin="0,0,4,0" Content="Zu Tour hinzufügen" Style="{StaticResource SuccessButtonStyle}" Command="{Binding AddToRouteCommand}" />
                                    <Button Grid.Column="1"
                                            Height="36"
                                            Margin="4,0,0,0"
                                            Content="Aus Tour entfernen"
                                            IsEnabled="{Binding CanEditDetailAvisoStatus}"
                                            ToolTip="Nur verfügbar bei zugeordneter Tour."
                                            Style="{StaticResource DangerButtonStyle}"
                                            Command="{Binding RemoveOrderFromTourCommand}" />
                                </Grid>
                                <Grid Grid.Row="3" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Height="36"
                                            Margin="0,0,4,0"
                                            Content="Tour anzeigen"
                                            IsEnabled="{Binding CanEditDetailAvisoStatus}"
                                            ToolTip="Nur verfügbar bei zugeordneter Tour."
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ShowSelectedOrderTourCommand}" />
                                    <Button Grid.Column="1"
                                            Height="36"
                                            Margin="4,0,0,0"
                                            Content="Auftrag bearbeiten"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding EditOrderCommand}" />
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="86" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0"
                                                  Height="36"
                                                  ToolTip="Auftragsstatus ändern"
                                                  ItemsSource="{Binding OrderStatusOptions}"
                                                  SelectedItem="{Binding DetailSelectedStatus, Mode=TwoWay}" />
                                        <Button Grid.Column="1" Height="36" Margin="8,0,0,0" Content="Schliessen" Style="{StaticResource DarkButtonStyle}" Command="{Binding CloseDetailsCommand}" />
                                    </Grid>
                                    <TextBlock Grid.Row="0"
                                               Margin="0,0,0,6"
                                               FontWeight="SemiBold"
                                               Text="Auftragsstatus ändern" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>


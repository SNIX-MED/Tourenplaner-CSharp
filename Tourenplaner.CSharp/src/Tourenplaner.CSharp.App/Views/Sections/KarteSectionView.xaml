<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.KarteSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1500">
    <UserControl.Resources>
        <Style x:Key="RouteStopsGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8DEE7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#F7F9FC" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E6EAF0" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="ColumnHeaderHeight" Value="36" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style x:Key="RouteStopsHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="#EEF2F7" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E0E6EF" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style x:Key="RouteStopsRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#E6EAF0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF0F9" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C7D6EA" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RouteStopsCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="RouteStopsCenterTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource FlatCardStyle}" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Karte" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,14,0" />
                <TextBox Grid.Column="1"
                         Height="38"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"
                         ToolTip="Ort suchen (Enter)..."
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="2" Height="38" Margin="0,0,10,0" Content="Suchen" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding RefreshCommand}" />
                <ComboBox Grid.Column="3"
                          Height="38"
                          Margin="0,0,10,0"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                          VerticalAlignment="Center" />
                <Button Grid.Column="4" Height="38" Content="Route exportieren" Style="{StaticResource SuccessButtonStyle}" Command="{Binding ExportRouteCommand}" />
            </Grid>
        </Border>

        <Expander Grid.Row="1" IsExpanded="False" Header="Legende" Margin="0,0,0,10">
            <Border Style="{StaticResource FlatCardStyle}" Padding="10" Margin="0,6,0,0">
                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Text="Blaue Marker: offene Aufträge | Graue Marker: zugewiesen | Blaue Linie: aktuelle Route" />
            </Border>
        </Expander>

        <Border Grid.Row="2" Style="{StaticResource FlatCardStyle}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="440" MinWidth="300" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SoftCardStyle}" Padding="10" Margin="0,0,4,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="200" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Aktuelle Route" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      Margin="8,0,6,0"
                                      Height="32"
                                      MinWidth="140"
                                      ItemsSource="{Binding SavedTours}"
                                      SelectedItem="{Binding SelectedSavedTour, Mode=TwoWay}"
                                      DisplayMemberPath="Label" />
                            <Button Grid.Column="2"
                                    Height="32"
                                    Content="Bearbeiten"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding EditSelectedTourCommand}" />
                            <Button Grid.Column="3"
                                    Height="32"
                                    MinWidth="36"
                                    Margin="4,0,0,0"
                                    Padding="0"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding OpenCreateTourDialogCommand}">
                                <TextBlock Text="+"
                                           Foreground="White"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Grid.Column="4"
                                    Height="32"
                                    Margin="4,0,0,0"
                                    Content="X"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding LeaveSelectedTourCommand}" />
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Startzeit" Margin="0,0,8,0" />
                            <TextBox Grid.Column="1" Height="32" Text="{Binding RouteStartHour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" />
                            <TextBlock Grid.Column="2" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <TextBox Grid.Column="3" Height="32" Text="{Binding RouteStartMinute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" />
                            <Button Grid.Column="4" Height="32" Margin="10,0,8,0" Content="Übernehmen" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ApplyStartTimeCommand}" />
                            <Button Grid.Column="5" Height="32" Content="Route optimieren" Style="{StaticResource SuccessButtonStyle}" Command="{Binding OptimizeRouteCommand}" />
                        </Grid>

                        <Border Grid.Row="2"
                                BorderBrush="#D8DEE7"
                                BorderThickness="1"
                                CornerRadius="6"
                                Background="White"
                                ClipToBounds="True">
                            <DataGrid x:Name="RouteStopsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      AllowDrop="True"
                                      HeadersVisibility="Column"
                                      ItemsSource="{Binding RouteStops}"
                                      SelectedItem="{Binding SelectedRouteStop, Mode=TwoWay}"
                                      MouseDoubleClick="RouteStopsGrid_MouseDoubleClick"
                                      PreviewMouseLeftButtonDown="RouteStopsGrid_PreviewMouseLeftButtonDown"
                                      MouseMove="RouteStopsGrid_MouseMove"
                                      DragOver="RouteStopsGrid_DragOver"
                                      Drop="RouteStopsGrid_Drop"
                                      Style="{StaticResource RouteStopsGridStyle}"
                                      ColumnHeaderStyle="{StaticResource RouteStopsHeaderStyle}"
                                      RowStyle="{StaticResource RouteStopsRowStyle}"
                                      CellStyle="{StaticResource RouteStopsCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Width="42" Binding="{Binding DisplayPosition}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="Adresse / Name" Width="*" Binding="{Binding DisplayName}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="Fenster" Width="92" Binding="{Binding DisplayOrder}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="Aufenthalt" Width="96" Binding="{Binding DisplayStay}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                    <DataGridTextColumn Header="ETA" Width="72" Binding="{Binding DisplayEta}" ElementStyle="{StaticResource RouteStopsCenterTextStyle}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <StackPanel Grid.Row="3" Margin="0,10,0,8">
                            <TextBlock FontWeight="SemiBold">
                                <Run Text="Totalgewicht: " />
                                <Run Text="0 kg" />
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0" Text="{Binding RouteTimingSummary}" />
                        </StackPanel>

                        <Border Grid.Row="4" Style="{StaticResource SoftCardStyle}" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Fahrzeiten" FontWeight="SemiBold" />
                                <TextBox Grid.Row="1" Margin="0,8,0,0" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Text="{Binding DriveTimesText, Mode=OneWay}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="5" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="?" Command="{Binding MoveStopUpCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="1" Content="?" Margin="8,0,0,0" Command="{Binding MoveStopDownCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="2" Content="Zeitfenster" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="3" Content="Entfernen" Margin="8,0,0,0" Command="{Binding RemoveFromRouteCommand}" Style="{StaticResource DangerButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns"
                              ShowsPreview="True"
                              Background="{DynamicResource Brush.BorderStrong}" />

                <Border Grid.Column="2" Style="{StaticResource SoftCardStyle}" Padding="4" Margin="4,0,8,0">
                    <Grid>
                        <Border BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1" CornerRadius="12" Background="White" />
                        <wv2:WebView2 x:Name="MapWebView" Margin="1" />
                        <TextBlock x:Name="MapFallbackNotice"
                                   Margin="16"
                                   VerticalAlignment="Top"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Text="Karte nicht verfügbar. Der Workflow bleibt über die Liste nutzbar." />
                    </Grid>
                </Border>

                <Border Grid.Column="3" Width="390" Padding="10" Margin="8,0,0,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDetailsOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Details" FontSize="20" FontWeight="SemiBold" />

                        <ScrollViewer Grid.Row="1" Margin="0,10,0,10" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Auftragsadresse:" />
                                <TextBlock Text="{Binding DetailAddress}" TextWrapping="Wrap" />

                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Lieferadresse:" />
                                <TextBlock Text="{Binding DetailCustomer}" TextWrapping="Wrap" />

                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Auftragsnummer:" />
                                <TextBlock Text="{Binding DetailOrderNumber}" />

                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Produkte:" />
                                <TextBlock Text="N/A" />

                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Lieferart:" />
                                <TextBlock Text="{Binding DetailDeliveryType}" />

                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Status:" />
                                <TextBlock Text="{Binding DetailStatus}" />

                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="E-Mail:" />
                                <TextBlock Text="{Binding DetailEmail}" />

                                <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Telefon:" />
                                <TextBlock Text="{Binding DetailPhone}" />
                            </StackPanel>
                        </ScrollViewer>

                        <Button Grid.Row="2" Height="36" Margin="0,0,0,8" Content="Zu Tour hinzufügen" Style="{StaticResource SuccessButtonStyle}" Command="{Binding AddToRouteCommand}" />
                        <Button Grid.Row="3" Height="36" Margin="0,0,0,8" Content="E Mail senden" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SendEmailCommand}" />
                        <Button Grid.Row="4" Height="36" Margin="0,0,0,10" Content="Auftrag bearbeiten" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding EditOrderCommand}" />

                        <Grid Grid.Row="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Height="34">
                                <ComboBoxItem Content="nicht festgelegt" />
                                <ComboBoxItem Content="zugewiesen" />
                            </ComboBox>
                            <Button Grid.Column="1" Height="34" Margin="8,0,0,0" Content="Schließen" Style="{StaticResource DarkButtonStyle}" Command="{Binding CloseDetailsCommand}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>


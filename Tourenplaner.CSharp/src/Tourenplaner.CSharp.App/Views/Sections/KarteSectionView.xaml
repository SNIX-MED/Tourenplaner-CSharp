<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.KarteSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1500">
    <UserControl.Resources>
        <Style x:Key="DetailsToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="104" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailsHeaderToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailsRailButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="RouteStopsListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="RouteStopListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF4FF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="{StaticResource Spacing.PageMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="460" MinWidth="320" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SoftCardStyle}" Padding="12" Margin="0,0,6,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Aktuelle Route" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      Margin="8,0,6,0"
                                      Height="34"
                                      MinWidth="160"
                                      ItemsSource="{Binding SavedTours}"
                                      SelectedItem="{Binding SelectedSavedTour, Mode=TwoWay}"
                                      DisplayMemberPath="Label" />
                            <Button Grid.Column="2"
                                    Height="34"
                                    Content="Bearbeiten"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding EditSelectedTourCommand}" />
                        </Grid>

                        <Border Grid.Row="1" Margin="0,10,0,10" Style="{StaticResource FlatCardStyle}" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="68" />
                                    <ColumnDefinition Width="108" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Startzeit" Margin="0,0,8,0" />
                                <TextBox Grid.Column="1" Height="34" Text="{Binding RouteStartHour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" />
                                <TextBlock Grid.Column="2" Text=":" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBox Grid.Column="3" Height="34" Text="{Binding RouteStartMinute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center" />
                                <Button Grid.Column="4" Height="34" Margin="10,0,8,0" Content="Übernehmen" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ApplyStartTimeCommand}" />
                                <Button Grid.Column="5" Height="34" Content="Route optimieren" Style="{StaticResource SuccessButtonStyle}" Command="{Binding OptimizeRouteCommand}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Background="{DynamicResource Brush.TableBackground}"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Routenübersicht"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Margin="2,0,0,8" />

                                <ScrollViewer Grid.Row="1"
                                              x:Name="RouteStopsScrollViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PreviewMouseWheel="OnRouteStopsPreviewMouseWheel">
                                    <ListBox x:Name="RouteStopsList"
                                             ItemsSource="{Binding RouteStops}"
                                             SelectedItem="{Binding SelectedRouteStop, Mode=TwoWay}"
                                             MouseDoubleClick="RouteStopsList_MouseDoubleClick"
                                             PreviewMouseLeftButtonDown="RouteStopsList_PreviewMouseLeftButtonDown"
                                             MouseMove="RouteStopsList_MouseMove"
                                             DragOver="RouteStopsList_DragOver"
                                             Drop="RouteStopsList_Drop"
                                             AllowDrop="True"
                                             Style="{StaticResource RouteStopsListStyle}"
                                             ItemContainerStyle="{StaticResource RouteStopListItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,0">
                                                    <Border CornerRadius="14"
                                                            BorderThickness="1"
                                                            Margin="0,0,0,8">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                                                <Setter Property="Padding" Value="12" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRouteStart}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#7BC6A4" />
                                                                        <Setter Property="Background" Value="#F2FBF6" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRouteEnd}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#8EC6E8" />
                                                                        <Setter Property="Background" Value="#F2F9FF" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                        <Setter Property="Padding" Value="4,2" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="46" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="84" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="38"
                                                                    Height="38"
                                                                    CornerRadius="19"
                                                                    VerticalAlignment="Top"
                                                                    HorizontalAlignment="Center"
                                                                    Background="#4EBA74">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Width" Value="38" />
                                                                        <Setter Property="Height" Value="38" />
                                                                        <Setter Property="CornerRadius" Value="19" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding DisplayPosition}"
                                                                           Foreground="White"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="16"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="FontSize" Value="16" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                    <Setter Property="FontSize" Value="13" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <TextBlock Text="{Binding DisplayPosition}"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="13"
                                                                       Visibility="Collapsed">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>

                                                            <StackPanel Grid.Column="1" Margin="8,0,6,0">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Setter Property="Margin" Value="8,0,6,0" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                <Setter Property="Margin" Value="2,0,4,0" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               FontSize="17"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource Brush.TextPrimary}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="FontSize" Value="17" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                        <Setter Property="FontSize" Value="12" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <Border DockPanel.Dock="Right"
                                                                            Padding="10,3"
                                                                            CornerRadius="999"
                                                                            Background="#5DBE85"
                                                                            Visibility="Collapsed">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding RouteBadgeText}"
                                                                                   Foreground="White"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="12" />
                                                                    </Border>
                                                                </DockPanel>
                                                                <TextBlock Text="{Binding DisplayAddress}"
                                                                           Margin="0,2,0,0"
                                                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                                                           TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DisplayAddress}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <TextBlock Text="Zeitfenster: "
                                                                               Foreground="{DynamicResource Brush.TextMuted}" />
                                                                    <TextBlock Text="{Binding DisplayWindow}"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                    <TextBlock Text="  |  ETA: "
                                                                               Margin="10,0,0,0"
                                                                               Foreground="{DynamicResource Brush.TextMuted}" />
                                                                    <TextBlock Text="{Binding DisplayEta}"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                                                               FontWeight="SemiBold" />
                                                                    <TextBlock Text="  |  Auftrag: "
                                                                               Margin="10,0,0,0"
                                                                               Foreground="{DynamicResource Brush.TextMuted}" />
                                                                    <TextBlock Text="{Binding DisplayOrder}"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                    <TextBlock Text="  |  Aufenthalt: "
                                                                               Margin="10,0,0,0"
                                                                               Foreground="{DynamicResource Brush.TextMuted}" />
                                                                    <TextBlock Text="{Binding DisplayStay}"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayEta}"
                                                                           HorizontalAlignment="Right"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="18"
                                                                           Foreground="{DynamicResource Brush.TextPrimary}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="FontSize" Value="18" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                    <Setter Property="FontSize" Value="12" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="Ankunft"
                                                                           HorizontalAlignment="Right"
                                                                           Foreground="{DynamicResource Brush.TextMuted}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Ankunft" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsRouteStart}" Value="True">
                                                                                    <Setter Property="Text" Value="Start" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsRouteEnd}" Value="True">
                                                                                    <Setter Property="Text" Value="Ende" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <Border Margin="16,0,16,10"
                                                            Padding="10,8"
                                                            CornerRadius="10"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
                                                                <Setter Property="BorderBrush" Value="{Binding NextLegAccentColor}" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasNextLeg}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE804;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0"
                                           Foreground="{Binding NextLegAccentColor}" />
                                                            <TextBlock Text="{Binding NextLegDurationText}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.TextPrimary}" />
                                                            <TextBlock Text="  -  "
                                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                                            <TextBlock Text="{Binding NextLegDistanceText}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.TextPrimary}" />
                                                            <TextBlock Text="  |  "
                                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                                       Margin="8,0,0,0" />
                                                            <TextBlock Text="{Binding NextLegDepartureText}"
                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                <TextBlock Text="  →  "
                                           Foreground="{DynamicResource Brush.TextMuted}" />
                                                            <TextBlock Text="{Binding NextLegArrivalText}"
                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Margin="0,10,0,8" Style="{StaticResource SoftCardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding RouteTotalWeightText}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           Text="{Binding RouteLoadSummaryText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RouteLoadSummaryText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0" Text="{Binding RouteTimingSummary}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="5" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Tour schliessen" Command="{Binding LeaveSelectedTourCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="1" Content="Tour löschen" Margin="8,0,0,0" Command="{Binding DeleteSelectedTourCommand}" Style="{StaticResource DangerOutlineButtonStyle}" />
                            <Button Grid.Column="2" Content="Speichern" Margin="8,0,0,0" Command="{Binding SaveCurrentTourCommand}" Style="{StaticResource SuccessButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns"
                              ShowsPreview="True"
                              Background="{DynamicResource Brush.BorderSoft}" />

                <Border Grid.Column="2" Style="{StaticResource FlatCardStyle}" Padding="4" Margin="6,0,10,0">
                    <Border BorderBrush="{DynamicResource Brush.BorderSoft}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Background="{DynamicResource Brush.Card}"
                            ClipToBounds="True">
                        <Grid>
                            <wv2:WebView2 x:Name="MapWebView" Margin="0" />
                            <TextBlock x:Name="MapFallbackNotice"
                                       Margin="16"
                                       VerticalAlignment="Top"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed"
                                       Text="Karte nicht verfügbar. Der Workflow bleibt über die Liste nutzbar." />
                        </Grid>
                    </Border>
                </Border>

                <Grid Grid.Column="3" Margin="-4,0,0,0">
                    <Border Width="390" Padding="12" HorizontalAlignment="Right">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDetailsOpen}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDetailsPanelExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="40" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Text="{Binding DetailOrderNumber, Mode=OneWay, StringFormat=Auftrag {0}}" />
                                <Button Grid.Column="1"
                                        Margin="0,0,6,0"
                                        Style="{StaticResource DetailsHeaderToggleButtonStyle}"
                                        Command="{Binding CloseDetailsCommand}">
                                    <TextBlock Text="X"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                                <Button Grid.Column="2"
                                        Style="{StaticResource DetailsHeaderToggleButtonStyle}"
                                        Command="{Binding ToggleDetailsPanelCommand}">
                                    <TextBlock Text="{Binding DetailsToggleGlyph}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDetailsOpen}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ScrollViewer x:Name="DetailsScrollViewer"
                                              Grid.Row="0"
                                              Margin="0,0,0,10"
                                              VerticalScrollBarVisibility="Auto"
                                              PreviewMouseWheel="OnDetailsPreviewMouseWheel">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Auftragsadresse:" />
                                        <TextBlock Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="{Binding DetailAddress}"
                                                   TextWrapping="Wrap" />

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="11*" />
                                                <ColumnDefinition Width="9*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Margin="0,0,6,0"
                                                    Padding="10"
                                                    CornerRadius="12"
                                                    Background="{DynamicResource Brush.AccentSurface}"
                                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="Lieferadresse:" />
                                                    <TextBlock Margin="0,4,0,0" Text="{Binding DetailCustomer}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1"
                                                    Margin="6,0,0,0"
                                                    Padding="10"
                                                    CornerRadius="12"
                                                    Background="{DynamicResource Brush.CardSoft}"
                                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="Kontaktdaten:" />
                                                    <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" Text="E-Mail:" />
                                                    <TextBlock Text="{Binding DetailEmail}" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,8,0,0" FontWeight="SemiBold" Text="Telefon:" />
                                                    <TextBlock Text="{Binding DetailPhone}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Produkte:" />
                                        <TextBlock Text="{Binding DetailProducts}" TextWrapping="Wrap" />

                                        <TextBlock Margin="0,10,0,0" FontWeight="SemiBold" Text="Lieferart:" />
                                        <TextBlock Text="{Binding DetailDeliveryType}" />

                                    </StackPanel>
                                </ScrollViewer>

                                <Grid Grid.Row="1" Margin="0,0,0,10" IsSharedSizeScope="True">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                        <TextBlock Margin="0,0,0,6"
                                                   FontWeight="SemiBold"
                                                   Text="Auftragsstatus:" />
                                        <ComboBox Height="36"
                                                  ItemsSource="{Binding OrderStatusOptions}"
                                                  SelectedItem="{Binding DetailSelectedStatus, Mode=TwoWay}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                        <TextBlock Margin="0,0,0,6"
                                                   FontWeight="SemiBold"
                                                   Text="Avisierungsstatus:" />
                                        <ComboBox Height="36"
                                                  ItemsSource="{Binding AvisoStatusOptions}"
                                                  ToolTip="Nur verfügbar bei zugeordneter Tour."
                                                  SelectedItem="{Binding DetailSelectedAvisoStatus, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="2" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Height="36"
                                                Margin="0,0,4,0"
                                                Content="Zu Tour hinzufügen"
                                                Style="{StaticResource SuccessButtonStyle}"
                                                Command="{Binding AddToRouteCommand}" />
                                        <ComboBox Grid.Column="1"
                                                  Height="36"
                                                  Margin="4,0,0,0"
                                                  VerticalAlignment="Top"
                                                  ToolTip="Auftragsstatus ändern"
                                                  ItemsSource="{Binding OrderStatusOptions}"
                                                  SelectedItem="{Binding DetailSelectedStatus, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Height="36"
                                                Margin="0,0,4,0"
                                                Content="Stopp entfernen"
                                                ToolTip="Nur verfügbar bei zugeordneter Tour."
                                                Style="{StaticResource DangerOutlineButtonStyle}"
                                                Command="{Binding RemoveOrderFromTourCommand}" />
                                        <Button Grid.Column="1"
                                                Height="36"
                                                Margin="4,0,0,0"
                                                Content="Tour anzeigen"
                                                ToolTip="Nur verfügbar bei zugeordneter Tour."
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ShowSelectedOrderTourCommand}" />
                                    </Grid>
                                </Grid>
                                <Grid Grid.Row="3" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Height="36"
                                            Margin="0,0,4,0"
                                            Content="E Mail senden"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SendEmailCommand}" />
                                    <Button Grid.Column="1"
                                            Height="36"
                                            Margin="4,0,0,0"
                                            Content="Auftrag bearbeiten"
                                            Command="{Binding EditOrderCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Grid.Column" Value="1" />
                                                <Setter Property="Grid.ColumnSpan" Value="1" />
                                                <Setter Property="Margin" Value="4,0,0,0" />
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>










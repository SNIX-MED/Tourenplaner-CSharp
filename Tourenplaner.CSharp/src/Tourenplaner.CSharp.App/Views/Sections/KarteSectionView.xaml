                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Button>
                                <Button Grid.Row="0"
                                        Grid.Column="4"
                                        Style="{StaticResource DetailsHeaderToggleButtonStyle}"

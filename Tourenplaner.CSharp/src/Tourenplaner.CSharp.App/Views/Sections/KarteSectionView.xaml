                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding RouteBadgeText}"
                                                                                   Foreground="White"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="12" />
                                                                    </Border>
                                                                </DockPanel>
                                                                <TextBlock Text="{Binding DisplayAddress}"
                                                                           Margin="0,2,0,0"
                                                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                                                           TextWrapping="Wrap">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding DisplayAddress}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <TextBlock Text="Aufenthalt: "
                                                                               Foreground="{DynamicResource Brush.TextMuted}" />
                                                                    <TextBlock Text="{Binding DisplayStay}"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                    <TextBlock Text="  |  ETA: "
                                                                               Margin="10,0,0,0"
                                                                               Foreground="{DynamicResource Brush.TextMuted}" />
                                                                    <TextBlock Text="{Binding DisplayEta}"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}"
                                                                               FontWeight="SemiBold" />
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayEta}"
                                                                           HorizontalAlignment="Right"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="18"
                                                                           Foreground="{DynamicResource Brush.TextPrimary}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="FontSize" Value="18" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                    <Setter Property="FontSize" Value="12" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="Ankunft"
                                                                           HorizontalAlignment="Right"
                                                                           Foreground="{DynamicResource Brush.TextMuted}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="Ankunft" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsRouteStart}" Value="True">
                                                                                    <Setter Property="Text" Value="Start" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsRouteEnd}" Value="True">
                                                                                    <Setter Property="Text" Value="Ende" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <Border Margin="16,-2,16,6"
                                                            Padding="6,2"
                                                            CornerRadius="10"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
                                                                <Setter Property="BorderThickness" Value="0" />
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="Effect" Value="{x:Null}" />
                                                                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                                                                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
                                                                <Setter Property="SnapsToDevicePixels" Value="True" />
                                                                <Setter Property="UseLayoutRounding" Value="True" />
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasNextLeg}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE804;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,6,0"
                                           Foreground="{Binding NextLegAccentColor}" />
                                                            <TextBlock Text="{Binding NextLegDurationText}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.TextPrimary}" />
                                                            <TextBlock Text="  -  "
                                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                                            <TextBlock Text="{Binding NextLegDistanceText}"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Brush.TextPrimary}" />
                                                            <TextBlock Text="  |  "
                                                                       Foreground="{DynamicResource Brush.TextMuted}"
                                                                       Margin="8,0,0,0" />
                                                            <TextBlock Text="{Binding NextLegDepartureText}"
                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                <TextBlock Text="  ?  "
                                           Foreground="{DynamicResource Brush.TextMuted}" />
                                                            <TextBlock Text="{Binding NextLegArrivalText}"
                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3" Margin="0,10,0,8" Style="{StaticResource SoftCardStyle}" Padding="10">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="{Binding RouteTotalWeightText}" />
                                <TextBlock Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding RouteLoadSummaryText}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RouteLoadSummaryText}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" Margin="0,4,0,0" Text="{Binding RouteTimingSummary}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="5" Margin="0,10,0,0">

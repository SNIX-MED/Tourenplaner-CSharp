                                    <DataTrigger Binding="{Binding IsDetailsOpen}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDetailsPanelExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />

                                            Grid.RowSpan="2"
                                            Grid.Column="0"
                                            Margin="0,8,10,0"
                                            VerticalAlignment="Top">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="Auftragsadresse:" />
                                    <TextBlock Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="{Binding DetailAddress}"
                                               TextWrapping="Wrap" />

                                                                                    <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                                        <Setter Property="FontSize" Value="12" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>

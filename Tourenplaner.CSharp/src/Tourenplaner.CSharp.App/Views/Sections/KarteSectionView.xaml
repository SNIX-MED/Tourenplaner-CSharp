                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           Margin="8,0,0,0" />
                                                                <TextBlock Text="{Binding NextLegDepartureText}"
                                                                           Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                <TextBlock Text="  ->  "
                                                                           Foreground="{DynamicResource Brush.TextMuted}" />
                                                                <TextBlock Text="{Binding NextLegArrivalText}"
                                                                           Foreground="{DynamicResource Brush.TextSecondary}" />

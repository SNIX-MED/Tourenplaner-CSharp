                                        <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding DetailProductItems}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DetailProductItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="10"
                                                            CornerRadius="10"
                                                            Background="{Binding BackgroundColor}"
                                                            MouseLeftButtonDown="OnDetailProductMouseLeftButtonDown">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{Binding BorderColor}" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                                <Setter Property="Background" Value="{Binding BackgroundColor}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                        <Setter Property="BorderThickness" Value="3" />
                                                                        <Setter Property="Background" Value="#E8F1FF" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               FontWeight="SemiBold"
                                                                               Text="{Binding Title}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Margin="12,0,0,0"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                                               Text="{Binding Supplier}">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasSupplier}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                                <StackPanel Margin="0,4,0,0"
                                                                            Orientation="Horizontal">
                                                                    <StackPanel.Style>
                                                                        <Style TargetType="StackPanel">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasDimensions}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </StackPanel.Style>
                                                                    <Ellipse Width="5"
                                                                             Height="5"
                                                                             Margin="0,0,8,0"
                                                                             VerticalAlignment="Center"
                                                                             Fill="{DynamicResource Brush.Accent}" />
                                                                    <TextBlock Text="{Binding DimensionsLine}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                </StackPanel>
                                                                <Grid Margin="0,4,0,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0"
                                                                                Orientation="Horizontal">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <Ellipse Width="5"
                                                                                     Height="5"
                                                                                     Margin="0,0,8,0"
                                                                                     VerticalAlignment="Center"
                                                                                     Fill="{DynamicResource Brush.Accent}" />
                                                                            <TextBlock Text="{Binding WeightLine}"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Margin="18,0,0,0">
                                                                            <Ellipse Width="5"
                                                                                     Height="5"
                                                                                     Margin="0,0,8,0"
                                                                                     VerticalAlignment="Center"
                                                                                     Fill="{DynamicResource Brush.Accent}" />
                                                                            <TextBlock Text="{Binding TotalLine}"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="{DynamicResource Brush.TextSecondary}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1"
                                                                               Margin="12,0,0,0"
                                                                               VerticalAlignment="Center"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{Binding BorderColor}"
                                                                               Text="{Binding DeliveryStatus}" />
                                                                </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="Keine Produkte vorhanden.">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DetailProductItems.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                    </StackPanel>
                                </ScrollViewer>

                                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                                    <TextBlock FontWeight="SemiBold" Text="Lieferart:" />
                                    <TextBlock Text="{Binding DetailDeliveryType}" />

                                    <TextBlock Margin="0,12,0,0"
                                               FontWeight="SemiBold"
                                               Text="Notizen:" />
                                    <Border Margin="0,4,0,0"
                                            Padding="10"
                                            CornerRadius="12"
                                            Background="{DynamicResource Brush.CardSoft}"
                                            BorderBrush="{DynamicResource Brush.BorderSoft}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DetailNotes}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding DetailNotes}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="Bold"
                                                   Foreground="#DC2626">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DetailNotes}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="Keine Notizen vorhanden.">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DetailNotes}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <Grid Grid.Row="3" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Button Height="36"
                                                Margin="0"
                                                Content="Zu Tour hinzufügen"
                                                Style="{StaticResource SuccessButtonStyle}"
                                                Command="{Binding AddToRouteCommand}" />
                                    </Grid>

                                     <Grid>
                                         <Grid.Style>
                                             <Style TargetType="Grid">
                                                 <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditDetailAvisoStatus}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                         </Grid.Style>
                                        <Button
                                                Height="36"
                                                Margin="0"
                                                Content="Tour anzeigen"
                                                ToolTip="Nur verfügbar bei zugeordneter Tour."
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ShowSelectedOrderTourCommand}" />
                                     </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>










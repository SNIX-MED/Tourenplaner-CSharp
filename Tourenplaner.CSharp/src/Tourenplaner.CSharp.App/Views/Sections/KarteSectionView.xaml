                                                <Grid>
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Text="Kontaktdaten:" />
                                                </Grid>
                                                <TextBlock Margin="0,6,0,0" FontWeight="SemiBold" Text="E-Mail:" />

                            <Button Grid.Column="0" Content="Tour schließen" Command="{Binding LeaveSelectedTourCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Grid.Column="1" Content="Tour löschen" Margin="8,0,0,0" Command="{Binding DeleteSelectedTourCommand}" Style="{StaticResource DangerOutlineButtonStyle}" />
                            <Button Grid.Column="2" Content="Speichern" Margin="8,0,0,0" Command="{Binding SaveCurrentTourCommand}" Style="{StaticResource SuccessButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns"
                              ShowsPreview="False"
                              MouseDoubleClick="OnMainSplitterMouseDoubleClick"
                              Background="{DynamicResource Brush.BorderSoft}" />

                <Border Grid.Column="2" Padding="4" Margin="4,0,4,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
                            <Setter Property="Effect" Value="{x:Null}" />
                        </Style>
                    </Border.Style>
                    <Border BorderBrush="{DynamicResource Brush.BorderSoft}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Background="{DynamicResource Brush.Card}"
                            ClipToBounds="True">
                        <Grid>
                            <wv2:WebView2 x:Name="MapWebView" Margin="0" />

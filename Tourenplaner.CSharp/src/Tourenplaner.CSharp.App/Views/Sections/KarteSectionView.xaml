                                                                        <TextBlock Text="{Binding TrafficBufferAfterText}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="#8A5A00" />
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Padding="7,3"
                                                                        VerticalAlignment="Center"
                                                                        Background="#FFF7E8"
                                                                        BorderBrush="#F5C66B"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasPauseAfter}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>

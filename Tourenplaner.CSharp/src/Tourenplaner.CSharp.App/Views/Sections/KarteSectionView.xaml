<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.KarteSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1500">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="DetailsToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="104" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="DetailsHeaderToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="MapActionGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            <Setter Property="TextOptions.TextHintingMode" Value="Animated" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style x:Key="InlineRouteLoadingBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="9" />
            <Setter Property="Background" Value="#E7EDF6" />
            <Setter Property="Foreground" Value="#0F9D58" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border x:Name="Track"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <Grid ClipToBounds="True">
                                <Border x:Name="IndeterminateBar"
                                        Width="30"
                                        CornerRadius="3"
                                        Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left"
                                        Opacity="0.95">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="-40" />
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="InlineSweepAnimation">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateBar"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             From="-40"
                                                             To="96"
                                                             Duration="0:0:1.1">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailsRailButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterPanelCardStyle" TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,14,8" />
            <Setter Property="Width" Value="215" />
            <Setter Property="MinHeight" Value="150" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
        </Style>

        <Style x:Key="FilterPanelIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardSoft}" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="FilterPanelIconGlyphStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterPanelOptionBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardSoft}" />
        </Style>

        <Style x:Key="FilterPanelOptionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent" SnapsToDevicePixels="True">
                            <BulletDecorator.Bullet>
                                <Grid Width="20" Height="20">
                                    <Border x:Name="Box"
                                            Width="18"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6" />
                                    <Path x:Name="CheckGlyph"
                                          Width="10"
                                          Height="7"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M1,3.5 L3.8,6.2 L9,1"
                                          Stroke="{DynamicResource Brush.TextPrimary}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed" />
                                    <Border x:Name="IndeterminateGlyph"
                                            Width="8"
                                            Height="2"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            CornerRadius="1"
                                            Background="{DynamicResource Brush.TextPrimary}"
                                            Visibility="Collapsed" />
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter x:Name="ContentHost"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                <Setter TargetName="ContentHost" Property="Margin" Value="0" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                <Setter TargetName="ContentHost" Property="Margin" Value="0" />
                            </DataTrigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.BorderStrong}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.BorderStrong}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                                <Setter TargetName="IndeterminateGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.DarkButton}" />
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.CardMuted}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.BorderSoft}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
                            </MultiTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Box" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Box" Property="BorderThickness" Value="2" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.DarkButton}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextSubtle}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FilterPanelOptionTemplate">
            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FilterPanelOptionBorderStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <CheckBox Style="{StaticResource FilterPanelOptionCheckBoxStyle}"
                          IsChecked="{Binding IsSelected, Mode=TwoWay}">
                    <TextBlock Text="{Binding Label}"
                               TextWrapping="Wrap" />
                </CheckBox>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SupplierFilterPanelOptionTemplate">
            <Border Width="183"
                    HorizontalAlignment="Left"
                    Margin="6,0,6,8">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource FilterPanelOptionBorderStyle}">
                        <Setter Property="Width" Value="183" />
                        <Setter Property="HorizontalAlignment" Value="Left" />
                        <Setter Property="Margin" Value="6,0,6,8" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <CheckBox Style="{StaticResource FilterPanelOptionCheckBoxStyle}"
                          IsChecked="{Binding IsSelected, Mode=TwoWay}">
                    <TextBlock Text="{Binding Label}"
                               TextWrapping="Wrap" />
                </CheckBox>
            </Border>
        </DataTemplate>

        <Style x:Key="RouteStopsListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="RouteStopListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DetailOrderStatusBadgeStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="RouteStopContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Popup.AllowsTransparency" Value="True" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="2"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True">
                            <StackPanel>
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RouteStopContextMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              ContentSource="Header"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Brush.CardMuted}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalContentAlignment="Stretch">
        <Grid Margin="0,2,0,0"
              HorizontalAlignment="Stretch"
              Width="{Binding ElementName=PageScrollViewer, Path=ViewportWidth}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,4"
                    Background="Transparent"
                    BorderThickness="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMapFilterPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsMapLegendPanelVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Border Visibility="{Binding IsMapFilterPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="430">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0"
                                      Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Style="{StaticResource FilterPanelCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                               Text="&#xE8EF;" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Margin="12,0,0,0">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="Auftragstyp" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="Art des Auftrags"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                            <StackPanel Grid.Row="1"
                                                        Margin="0,16,0,0">
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource FilterPanelOptionBorderStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IncludeOpenOrders}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <CheckBox Style="{StaticResource FilterPanelOptionCheckBoxStyle}"
                                                              AutomationProperties.Name="Offene Aufträge"
                                                              Content="Offene Aufträge"
                                                              IsChecked="{Binding IncludeOpenOrders, Mode=TwoWay}" />
                                                </Border>
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource FilterPanelOptionBorderStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IncludePlannedOrders}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.AccentSoft}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <CheckBox Style="{StaticResource FilterPanelOptionCheckBoxStyle}"
                                                              AutomationProperties.Name="Eingeplante Aufträge"
                                                              Content="Eingeplante Aufträge"
                                                              IsChecked="{Binding IncludePlannedOrders, Mode=TwoWay}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource FilterPanelCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                               Text="&#xE8D4;" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Margin="12,0,0,0">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="Auftragsstatus" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="Status des Auftrags"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                            <ItemsControl Grid.Row="1"
                                                          Margin="0,16,0,0"
                                                          ItemTemplate="{StaticResource FilterPanelOptionTemplate}"
                                                          ItemsSource="{Binding OrderStatusFilters}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Style="{StaticResource FilterPanelCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                               Text="&#xE806;" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Margin="12,0,0,0">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="Lieferart" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="Art der Lieferung"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                            <ItemsControl Grid.Row="1"
                                                          Margin="0,16,0,0"
                                                          ItemTemplate="{StaticResource FilterPanelOptionTemplate}"
                                                          ItemsSource="{Binding DeliveryTypeFilters}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="3"
                                            Style="{StaticResource FilterPanelCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                               Text="&#xE7ED;" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Margin="12,0,0,0">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="Avisierungsstatus" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="Status der Avisierung"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                            <ItemsControl Grid.Row="1"
                                                          Margin="0,16,0,0"
                                                          ItemTemplate="{StaticResource FilterPanelOptionTemplate}"
                                                          ItemsSource="{Binding AvisoStatusFilters}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="4"
                                            Style="{StaticResource FilterPanelCardStyle}"
                                            Width="{x:Static sys:Double.NaN}"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Style="{StaticResource FilterPanelIconBadgeStyle}">
                                                    <TextBlock Style="{StaticResource FilterPanelIconGlyphStyle}"
                                                               Text="&#xE80F;" />
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Margin="12,0,0,0">
                                                    <TextBlock FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Text="Lieferant" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource Brush.TextMuted}"
                                                               Text="Auswahl des Lieferanten"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        MinWidth="150"
                                                        Margin="16,0,0,0"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Content="{Binding ToggleAllFiltersButtonText}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding ToggleAllOrderFiltersCommand}"
                                                        AutomationProperties.Name="Alle Filter auswählen oder abwählen" />
                                            </Grid>
                                            <ItemsControl Grid.Row="1"
                                                          Margin="0,16,0,0"
                                                          ItemTemplate="{StaticResource SupplierFilterPanelOptionTemplate}"
                                                          ItemsSource="{Binding SupplierFilters}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"
                                                                   ItemWidth="195" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <Border Visibility="{Binding IsMapLegendPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="300">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Form = Lieferart | Farbe = Auftragsstatus | Badge = Eingeplant/Avisierungsstatus | Linie: Blau normal, Rot bei Kapazitätsreserve &lt;= Toleranz" />

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0"
                                          Margin="0,0,14,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Lieferart (Form)" />
                                        <StackPanel Grid.Row="1"
                                                    Margin="0,8,0,0"
                                                    Orientation="Horizontal">
                                            <Ellipse Width="18"
                                                     Height="18"
                                                     Fill="#0EA5E9"
                                                     Stroke="White"
                                                     StrokeThickness="2" />
                                            <TextBlock Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="Frei Bordsteinkante (Kreis)" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal">
                                            <Border Width="18"
                                                    Height="18"
                                                    Background="#0EA5E9"
                                                    BorderBrush="White"
                                                    BorderThickness="2"
                                                    CornerRadius="4" />
                                            <TextBlock Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="Mit Verteilung (Quadrat)" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="3"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal">
                                            <Grid Width="18"
                                                  Height="18">
                                                <Polygon Points="9,1 17,16 1,16"
                                                         Fill="White" />
                                                <Polygon Points="9,3 15,15 3,15"
                                                         Fill="#0EA5E9" />
                                            </Grid>
                                            <TextBlock Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="Mit Verteilung &amp; Montage (Dreieck)" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Column="1"
                                          Margin="0,0,14,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Auftragsstatus (Farbe)" />
                                        <Grid Grid.Row="1"
                                              Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal">
                                                <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorNotSpecified}" Stroke="White" StrokeThickness="2" />
                                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="nicht festgelegt" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Margin="14,0,0,0"
                                                        Orientation="Horizontal">
                                                <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorInStock}" Stroke="White" StrokeThickness="2" />
                                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Lieferbereit" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Grid.Row="2"
                                              Margin="0,6,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal">
                                                <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorOrdered}" Stroke="White" StrokeThickness="2" />
                                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Bestellt" />
                                            </StackPanel>
                                        </Grid>
                                        <StackPanel Grid.Row="3"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorOnTheWay}" Stroke="White" StrokeThickness="2" />
                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Unterwegs" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="4"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorPendingPreparation}" Stroke="White" StrokeThickness="2" />
                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Zu richten / Teilweise zu richten" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="5"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal">
                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorOnTheWay}" Stroke="White" StrokeThickness="2" />
                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Teilweise bereit" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Avisierungsstatus (Badge)" />
                                        <StackPanel Grid.Row="1"
                                                    Margin="0,8,0,0"
                                                    Orientation="Horizontal">
                                            <Grid Width="22"
                                                  Height="22">
                                                <Ellipse Width="18" Height="18" Fill="#0EA5E9" Stroke="White" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="9" Height="9" Fill="{Binding LegendAvisoBadgeColorNotAvisiert}" Stroke="White" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                            </Grid>
                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="nicht avisiert (zugeordnet)" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal">
                                            <Grid Width="22"
                                                  Height="22">
                                                <Ellipse Width="18" Height="18" Fill="#0EA5E9" Stroke="White" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="9" Height="9" Fill="{Binding LegendAvisoBadgeColorInformiert}" Stroke="White" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                            </Grid>
                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="informiert" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="3"
                                                    Margin="0,6,0,0"
                                                    Orientation="Horizontal">
                                            <Grid Width="22"
                                                  Height="22">
                                                <Ellipse Width="18" Height="18" Fill="#0EA5E9" Stroke="White" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="9" Height="9" Fill="{Binding LegendAvisoBadgeColorBestaetigt}" Stroke="White" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                            </Grid>
                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Bestätigt" />
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="RoutePanelColumn" Width="460" MinWidth="320" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition x:Name="DetailsPanelColumn" Width="390" MinWidth="280" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="12" Margin="0,0,6,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                            <Setter Property="Effect" Value="{x:Null}" />
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="0,0,0,10" Padding="10">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRouteCalculating}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ProgressBar Width="90"
                                             IsIndeterminate="True"
                                             Style="{StaticResource InlineRouteLoadingBarStyle}" />
                                <TextBlock Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextSecondary}"
                                           Text="Route wird berechnet..." />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="0,0,0,10" Style="{StaticResource FlatCardStyle}" Padding="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Margin="0,0,8,0"
                                        Command="{Binding PreviousTourCommand}"
                                        ToolTip="Vorherige Tour">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DetailsHeaderToggleButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowRouteStopsPanel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Text="&#xE76B;" />
                                </Button>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Margin="2,0,0,0"
                                           Text="Routen&#xFC;bersicht">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowTourOverviewPanel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,0"
                                           Text="{Binding CurrentStopViewTourName}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowRouteStopsPanel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Button Grid.Column="2"
                                        Margin="8,0,10,0"
                                        Command="{Binding NextTourCommand}"
                                        ToolTip="Nächste Tour">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DetailsHeaderToggleButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowRouteStopsPanel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Text="&#xE76C;" />
                                </Button>
                                <Button Grid.Column="3"
                                        Margin="10,0,0,0"
                                        Command="{Binding LeaveSelectedTourCommand}"
                                        ToolTip="Tour schließen"
                                        >
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DetailsHeaderToggleButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowTourOverviewPanel}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Style="{StaticResource MapActionGlyphStyle}"
                                               Text="&#xE700;" />
                                </Button>
                                <Button Grid.Column="4"
                                        Margin="8,0,0,0"
                                        Command="{Binding DeleteSelectedTourCommand}"
                                        ToolTip="Tour löschen"
                                        Style="{StaticResource DetailsHeaderToggleButtonStyle}">
                                    <TextBlock Style="{StaticResource MapActionGlyphStyle}"
                                               Text="&#xE74D;" />
                                </Button>
                                <Button Grid.Column="5"
                                        Margin="8,0,0,0"
                                        Command="{Binding OpenSelectedTourOverviewCommand}"
                                        ToolTip="Tour auf Karte anzeigen">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource DetailsHeaderToggleButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowRouteStopsPanel}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               FontSize="16"
                                               FontWeight="Normal"
                                               Foreground="{DynamicResource Brush.TextPrimary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="&#xE7B3;" />
                                </Button>
                                <Button Grid.Column="6"
                                        Margin="8,0,0,0"
                                        Command="{Binding EditSelectedTourCommand}"
                                        ToolTip="Tour bearbeiten"
                                        Style="{StaticResource DetailsHeaderToggleButtonStyle}">
                                    <TextBlock Style="{StaticResource MapActionGlyphStyle}"
                                               Text="&#xE70F;" />
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource Brush.BorderSoft}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Background="{DynamicResource Brush.TableBackground}"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowTourOverviewPanel}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PreviewMouseWheel="OnRouteStopsPreviewMouseWheel">
                                        <ListBox x:Name="TourOverviewList"
                                                 ItemsSource="{Binding TourOverviewItems}"
                                                 SelectedItem="{Binding SelectedTourOverviewItem, Mode=TwoWay}"
                                                 PreviewMouseLeftButtonDown="TourOverviewList_PreviewMouseLeftButtonDown"
                                                 MouseMove="TourOverviewList_MouseMove"
                                                 MouseLeave="TourOverviewList_MouseLeave"
                                                 MouseDoubleClick="TourOverviewList_MouseDoubleClick"
                                                 Style="{StaticResource RouteStopsListStyle}"
                                                 ItemContainerStyle="{StaticResource RouteStopListItemStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Padding="12"
                                                            CornerRadius="14"
                                                            BorderThickness="1">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
                                                                <Setter Property="Background" Value="{DynamicResource Brush.CardSoft}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource Brush.CardMuted}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                        <Setter Property="Background" Value="#EEF6FF" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock FontSize="16"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                                                           Text="{Binding TourName}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           Text="{Binding StopCountText}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1"
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Right">
                                                                <TextBlock HorizontalAlignment="Right"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding DateText}" />
                                                                <TextBlock Margin="0,3,0,0"
                                                                           HorizontalAlignment="Right"
                                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding StartTimeText}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </Border>

                                <Border Grid.Row="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowRouteStopsPanel}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ScrollViewer x:Name="RouteStopsScrollViewer"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PreviewMouseWheel="OnRouteStopsPreviewMouseWheel">
                                    <ListBox x:Name="RouteStopsList"
                                             ItemsSource="{Binding RouteStops}"
                                             SelectedItem="{Binding SelectedRouteStop, Mode=TwoWay}"
                                             MouseDoubleClick="RouteStopsList_MouseDoubleClick"
                                             PreviewMouseLeftButtonDown="RouteStopsList_PreviewMouseLeftButtonDown"
                                             MouseMove="RouteStopsList_MouseMove"
                                             DragOver="RouteStopsList_DragOver"
                                             Drop="RouteStopsList_Drop"
                                             AllowDrop="True"
                                             Style="{StaticResource RouteStopsListStyle}"
                                             ItemContainerStyle="{StaticResource RouteStopListItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPauseStop}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <Border CornerRadius="14"
                                                            BorderThickness="1"
                                                            Margin="0,0,0,8"
                                                            MouseLeftButtonDown="OnRouteStopMouseLeftButtonDown"
                                                            ContextMenuOpening="OnRouteStopContextMenuOpening">
                                                        <Border.ContextMenu>
                                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                         Placement="MousePoint"
                                                                         HorizontalOffset="6"
                                                                         VerticalOffset="2"
                                                                         Style="{StaticResource RouteStopContextMenuStyle}">
                                                                <ContextMenu.Resources>
                                                                    <Style TargetType="Separator">
                                                                        <Setter Property="Margin" Value="0,4" />
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Separator">
                                                                                    <Border Height="1"
                                                                                            Background="{DynamicResource Brush.BorderSoft}" />
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </ContextMenu.Resources>
                                                                <MenuItem Header="Stopp bearbeiten"
                                                                          Style="{StaticResource RouteStopContextMenuItemStyle}"
                                                                          Click="OnRouteStopEditStayMenuItemClick" />
                                                                <MenuItem Header="Pause danach einfügen"
                                                                          Style="{StaticResource RouteStopContextMenuItemStyle}"
                                                                          Click="OnRouteStopAddPauseMenuItemClick" />
                                                                <MenuItem Header="Auftrag bearbeiten"
                                                                          Click="OnRouteStopEditOrderMenuItemClick">
                                                                    <MenuItem.Style>
                                                                        <Style TargetType="MenuItem" BasedOn="{StaticResource RouteStopContextMenuItemStyle}">
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPauseStop}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </MenuItem.Style>
                                                                </MenuItem>
                                                                <Separator />
                                                                <MenuItem Header="Stopp entfernen"
                                                                          Style="{StaticResource RouteStopContextMenuItemStyle}"
                                                                          Foreground="{DynamicResource Brush.Danger}"
                                                                          Click="OnRouteStopRemoveMenuItemClick" />
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
                                                                <Setter Property="Padding" Value="12" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
                                                                <Setter Property="Effect" Value="{x:Null}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRouteStart}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#7BC6A4" />
                                                                        <Setter Property="Background" Value="#F2FBF6" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRouteEnd}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#8EC6E8" />
                                                                        <Setter Property="Background" Value="#F2F9FF" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCompanyAnchor}" Value="True">
                                                                        <Setter Property="Padding" Value="4,2" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsStopSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="46" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="84" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="38"
                                                                    Height="38"
                                                                    CornerRadius="19"
                                                                    VerticalAlignment="Top"
                                                                    HorizontalAlignment="Center"
                                                                    Background="#4EBA74">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Width" Value="38" />

                        <Style TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
                            <Setter Property="Effect" Value="{x:Null}" />
                        </Style>
                    </Border.Style>
                    <Border BorderBrush="{DynamicResource Brush.BorderSoft}"
                            BorderThickness="1"
                            CornerRadius="14"

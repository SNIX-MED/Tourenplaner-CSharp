<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.GpsSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="640"
             d:DesignWidth="1020">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="26" FontWeight="SemiBold" />

        <DockPanel Grid.Row="1" Margin="0,12,0,12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Width="110" Margin="8,0,0,0" Content="Reload" Command="{Binding RefreshCommand}" />
                <Button Width="150" Margin="8,0,0,0" Content="Open in Browser" Command="{Binding OpenInBrowserCommand}" />
                <Button Width="120" Margin="8,0,0,0" Content="Copy URL" Command="{Binding CopyUrlCommand}" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="#334155"
                       Text="{Binding StatusText}" />
        </DockPanel>

        <Border Grid.Row="2" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12" Background="#F8FAFC">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="GPS URL" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="8,4,0,4"
                         Text="{Binding GpsUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Loaded URL" />
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="8,4,0,4" VerticalAlignment="Center" Text="{Binding LoadedUrl}" />

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,12,0,0">
                    <TextBlock Text="Embedded View Status" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Text="This migration keeps a runtime fallback: if WebView2 is not available locally, use 'Open in Browser' for the GPS feed." />
                    <TextBlock Margin="0,8,0,0">
                        <Run Text="WebView2 Runtime Available: " />
                        <Run Text="{Binding WebView2Available}" />
                    </TextBlock>
                    <TextBlock Margin="0,2,0,0">
                        <Run Text="Last Reload: " />
                        <Run Text="{Binding LastReloadAt}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="#475569"
                   Text="Fallback behavior mirrors Python desktop mode when embedded browser dependencies are missing." />
    </Grid>
</UserControl>

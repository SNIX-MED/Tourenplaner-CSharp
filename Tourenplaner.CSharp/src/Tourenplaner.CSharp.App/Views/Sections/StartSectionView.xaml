<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.StartSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1280"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <Style x:Key="SharpFlatCardStyle" TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SharpSoftCardStyle" TargetType="Border" BasedOn="{StaticResource SoftCardStyle}">
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="StartUpcomingCardStyle" TargetType="Border" BasedOn="{StaticResource SharpFlatCardStyle}">
            <Setter Property="Padding" Value="4" />
            <Setter Property="Height" Value="62" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource Spacing.PageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="28"
                Background="{DynamicResource Brush.CardSoft}"
                BorderBrush="{DynamicResource Brush.BorderSoft}"
                BorderThickness="1"
                Padding="10">
            <Grid>
                <Border CornerRadius="18" ClipToBounds="True">
                    <Grid Height="292">
                        <Image Source="{Binding BannerImagePath}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource GlassPanelBorderStyle}"
                    Padding="20">
                <StackPanel>
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="Schnellstart" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="13"
                               Text="{Binding NextPlannedDayText}" />

                    <Button Height="50"
                            Margin="0,18,0,0"
                            Content="Neue Tour planen"
                            FontSize="17"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding NewTourPlanCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource GlassPanelBorderStyle}"
                    Padding="20">
                <StackPanel>
                    <TextBlock FontSize="30" FontWeight="SemiBold" Text="{Binding CalendarHeadline}" />

                    <Border Margin="0,14,0,0"
                            Padding="8"
                            CornerRadius="12"
                            Background="{DynamicResource Brush.CardSoft}"
                            BorderBrush="{DynamicResource Brush.BorderSoft}"
                            BorderThickness="1"
                            Style="{StaticResource SharpSoftCardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Height="340">
                            <ItemsControl ItemsSource="{Binding UpcomingDayCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6"
                                                Background="{Binding LoadBackground}"
                                                BorderBrush="{Binding LoadBorderBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding LoadForeground}"
                                                           Text="{Binding DateText}" />

                                                <ItemsControl Grid.Column="1"
                                                              Margin="8,0,0,0"
                                                              VerticalAlignment="Center"
                                                              ItemsSource="{Binding SummaryLines}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Ellipse Grid.Column="0"
                                                                         Width="6"
                                                                         Height="6"
                                                                         Margin="0,4,5,0"
                                                                         VerticalAlignment="Top"
                                                                         Fill="{Binding DotColor}">
                                                                    <Ellipse.Style>
                                                                        <Style TargetType="Ellipse">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding ShowManualDot}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Ellipse.Style>
                                                                </Ellipse>
                                                                <TextBlock Grid.Column="1"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Foreground="{Binding DataContext.LoadForeground, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                           Opacity="0.9"
                                                                           FontSize="11"
                                                                           Text="{Binding Text}" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StartUpcomingCardStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="BorderThickness" Value="2" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

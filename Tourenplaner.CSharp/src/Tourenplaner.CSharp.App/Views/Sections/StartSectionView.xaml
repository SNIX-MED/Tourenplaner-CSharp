<UserControl x:Class="Tourenplaner.CSharp.App.Views.Sections.StartSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1280">
    <UserControl.Resources>
        <Style x:Key="StartUpcomingCardStyle" TargetType="Border" BasedOn="{StaticResource FlatCardStyle}">
            <Setter Property="Padding" Value="8" />
            <Setter Property="Height" Value="92" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="24"
                Background="#F4F7FB"
                BorderBrush="#DCE4EF"
                BorderThickness="1"
                Padding="8">
            <Grid>
                <Border CornerRadius="18" ClipToBounds="True">
                    <Grid Height="292">
                        <Image Source="{Binding BannerImagePath}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource GlassPanelBorderStyle}"
                    Padding="18">
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="Schnellstart" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="13"
                               Text="{Binding NextPlannedDayText}" />

                    <Button Height="48"
                            Margin="0,18,0,0"
                            Content="Neue Tour planen"
                            FontSize="15"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding NewTourPlanCommand}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource GlassPanelBorderStyle}"
                    Padding="18">
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="SemiBold" Text="{Binding CalendarHeadline}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="14"
                               Text="{Binding CalendarSubtitle}" />

                    <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding UpcomingWeeks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,10,0"
                                        Padding="12"
                                        CornerRadius="16"
                                        Background="#F8FAFC"
                                        BorderBrush="#DCE4EF"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A"
                                                   Text="{Binding Label}" />
                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Days}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="1" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,6"
                                                            Background="{Binding LoadBackground}"
                                                            BorderBrush="{Binding LoadBorderBrush}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="92" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding LoadForeground}"
                                                                           Text="{Binding DateText}" />
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="10"
                                                                           Foreground="{Binding LoadForeground}"
                                                                           Opacity="0.9"
                                                                           Text="{Binding TourCountText}" />
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="1"
                                                                       Margin="10,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{Binding LoadForeground}"
                                                                       Opacity="0.9"
                                                                       FontSize="10"
                                                                       MaxHeight="32"
                                                                       Text="{Binding SummaryText}" />
                                                        </Grid>
                                                        <Border.Style>
                                                            <Style TargetType="Border" BasedOn="{StaticResource StartUpcomingCardStyle}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                        <Setter Property="BorderThickness" Value="2" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14"
                CornerRadius="16"
                Background="{DynamicResource Brush.GlassSurfaceSoft}"
                BorderBrush="{DynamicResource Brush.GlassStroke}"
                BorderThickness="1">
            <TextBlock Foreground="{DynamicResource Brush.TextMuted}"
                       FontSize="13"
                       Text="Hinweis: Farben stammen direkt aus den Kalender-Einstellungen. Orange markiert höhere Auslastung, Rot volle Auslastung." />
        </Border>
    </Grid>
</UserControl>

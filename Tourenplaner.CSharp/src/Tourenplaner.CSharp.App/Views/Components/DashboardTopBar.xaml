                                    HorizontalAlignment="Center"
                                    CornerRadius="12"
                                    BorderBrush="{DynamicResource Brush.InputBorder}"
                                    BorderThickness="1"
                                    Background="{DynamicResource Brush.InputBackground}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontFamily="Segoe Fluent Icons"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="&#xE721;" />
                                    <Grid Grid.Column="1">
                                        <TextBox BorderThickness="0"
                                                 Background="Transparent"
                                                 ToolTip="Suche nach Nummer, Auftraggeber, Lieferadresse oder Tour"
                                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock IsHitTestVisible="False"
                                                   Margin="2,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.TextSubtle}"
                                                   Text="Suche...">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                <ToggleButton x:Name="OrdersFilterPopupButton"
                                              Width="44"
                                              Padding="0"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              ToolTip="Filter"
                                              IsChecked="{Binding IsOrdersFilterPanelVisible, Mode=TwoWay}">
                                    <Viewbox Style="{StaticResource FilterIconViewboxStyle}">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource FilterIconPathStyle}" />
                                        </Canvas>
                                    </Viewbox>
                                </ToggleButton>
                            </Grid>

                            <Grid Grid.Column="3" Margin="0,0,8,0">
                                <ToggleButton x:Name="OrdersColumnsPopupButton"
                                              Width="44"
                                              Padding="0"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              ToolTip="Spalten">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="15"
                                               Text="&#xE8A5;" />
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=OrdersColumnsPopupButton}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       IsOpen="{Binding IsChecked, ElementName=OrdersColumnsPopupButton, Mode=TwoWay}">
                                    <Border Style="{StaticResource SoftCardStyle}"
                                            Margin="0,6,0,0"
                                            Padding="10"
                                            MinWidth="190">
                                        <StackPanel>
                                            <CheckBox Margin="0,0,0,8"
                                                      Content="Auftraggeber"
                                                      IsChecked="{Binding IsCustomerColumnVisible, Mode=TwoWay}" />
                                            <CheckBox Margin="0,0,0,8"
                                                      Content="Lieferadresse"
                                                      IsChecked="{Binding IsDeliveryAddressColumnVisible, Mode=TwoWay}" />
                                            <CheckBox Content="Lieferperson"
                                                      IsChecked="{Binding IsDeliveryPersonColumnVisible, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <Button Grid.Column="4"
                                    Margin="0,0,8,0"
                                    Content="&#xE7A7;"
                                    ToolTip="Gelöschten Auftrag wiederherstellen"
                                    Style="{StaticResource TopbarCompactButtonStyle}"
                                    Command="{Binding UndoDeleteCommand}" />
                            <Button Grid.Column="5"
                                    Margin="0,0,8,0"
                                    Content="&#xE710;"
                                    ToolTip="Manuell hinzufügen"
                                    Style="{StaticResource TopbarCompactSuccessButtonStyle}"
                                    Command="{Binding AddManualOrderCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:NonMapOrdersSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Width="300"
                                    Height="40"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Center"
                                    CornerRadius="12"
                                    BorderBrush="{DynamicResource Brush.InputBorder}"
                                    BorderThickness="1"
                                    Background="{DynamicResource Brush.InputBackground}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontFamily="Segoe Fluent Icons"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="&#xE721;" />
                                    <Grid Grid.Column="1">
                                        <TextBox BorderThickness="0"
                                                 Background="Transparent"
                                                 ToolTip="Suche nach Nummer, Auftraggeber, Lieferadresse oder Tour"
                                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock IsHitTestVisible="False"
                                                   Margin="2,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.TextSubtle}"
                                                   Text="Suche...">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                <ToggleButton x:Name="NonMapOrdersFilterPopupButton"
                                              Width="44"
                                              Padding="0"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              ToolTip="Filter"
                                              IsChecked="{Binding IsNonMapOrdersFilterPanelVisible, Mode=TwoWay}">
                                    <Viewbox Style="{StaticResource FilterIconViewboxStyle}">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource FilterIconPathStyle}" />
                                        </Canvas>
                                    </Viewbox>
                                </ToggleButton>
                            </Grid>

                            <Grid Grid.Column="3" Margin="0,0,8,0">
                                <ToggleButton x:Name="NonMapOrdersColumnsPopupButton"
                                              Width="44"
                                              Padding="0"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              ToolTip="Spalten">
                                    <TextBlock FontFamily="Segoe Fluent Icons"
                                               FontSize="15"
                                               Text="&#xE8A5;" />
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=NonMapOrdersColumnsPopupButton}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True"
                                       IsOpen="{Binding IsChecked, ElementName=NonMapOrdersColumnsPopupButton, Mode=TwoWay}">
                                    <Border Style="{StaticResource SoftCardStyle}"
                                            Margin="0,6,0,0"
                                            Padding="10"
                                            MinWidth="190">
                                        <StackPanel>
                                            <CheckBox Margin="0,0,0,8"
                                                      Content="Auftraggeber"
                                                      IsChecked="{Binding IsCustomerColumnVisible, Mode=TwoWay}" />
                                            <CheckBox Margin="0,0,0,8"
                                                      Content="Lieferadresse"
                                                      IsChecked="{Binding IsDeliveryAddressColumnVisible, Mode=TwoWay}" />
                                            <CheckBox Content="Lieferperson"
                                                      IsChecked="{Binding IsDeliveryPersonColumnVisible, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <Button Grid.Column="4"
                                    Margin="0,0,8,0"
                                    Content="&#xE7A7;"
                                    ToolTip="Gelöschten Auftrag wiederherstellen"
                                    Style="{StaticResource TopbarCompactButtonStyle}"
                                    Command="{Binding UndoDeleteCommand}" />
                            <Button Grid.Column="5"
                                    Margin="0,0,8,0"
                                    Content="&#xE710;"
                                    ToolTip="Manuell hinzufügen"
                                    Style="{StaticResource TopbarCompactSuccessButtonStyle}"
                                    Command="{Binding AddManualOrderCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:EmployeesSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource TopbarStatusTextStyle}"
                                       Text="{Binding StatusText}" />

                            <Button Grid.Column="1"
                                    Content="&#xE710;"
                                    ToolTip="Mitarbeiter hinzufügen"
                                    Style="{StaticResource TopbarCompactSuccessButtonStyle}"
                                    Command="{Binding RequestAddEntryCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:VehiclesSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="420" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource TopbarStatusTextStyle}"
                                       Text="{Binding StatusText}" />

                            <Border Grid.Column="1"
                                    Margin="0,0,10,0"
                                    CornerRadius="13"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    Background="{DynamicResource Brush.CardMuted}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Margin="4"
                                            Height="36"
                                            Content="Zugfahrzeuge"
                                            Command="{Binding ShowVehiclesCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVehicleMode}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Margin="4"
                                            Height="36"
                                            Content="Anhänger"
                                            Command="{Binding ShowTrailersCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTrailerMode}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Margin="4"
                                            Height="36"
                                            Content="Kombinationen"
                                            Command="{Binding ShowCombinationsCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCombinationMode}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                                    Content="&#xE710;"
                                    ToolTip="{Binding AddButtonText}"
                                    Style="{StaticResource TopbarCompactSuccessButtonStyle}"
                                    Command="{Binding RequestAddEntryCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:GpsSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource TopbarStatusTextStyle}"
                                       Text="{Binding StatusText}" />

                            <Button Grid.Column="1"
                                    Content="&#xE72C;"
                                    ToolTip="Neu laden"
                                    Style="{StaticResource TopbarCompactButtonStyle}"
                                    Command="{Binding RefreshCommand}" />
                            <Button Grid.Column="2"
                                    Margin="8,0,0,0"
                                    Content="&#xE774;"
                                    ToolTip="Im Browser öffnen"
                                    Style="{StaticResource TopbarCompactButtonStyle}"
                                    Command="{Binding OpenInBrowserCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:SpediteurSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource TopbarStatusTextStyle}"
                                       Text="{Binding StatusText}" />

                            <Button Grid.Column="1"
                                    Content="&#xE72C;"
                                    ToolTip="Neu laden"
                                    Style="{StaticResource TopbarCompactButtonStyle}"
                                    Command="{Binding RefreshCommand}" />
                            <Button Grid.Column="2"
                                    Margin="8,0,0,0"
                                    Content="&#xE774;"
                                    ToolTip="Im Browser öffnen"
                                    Style="{StaticResource TopbarCompactButtonStyle}"
                                    Command="{Binding OpenInBrowserCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:SettingsSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource TopbarStatusTextStyle}"
                                       Text="Einstellungen bearbeiten und speichern." />

                            <Button Grid.Column="1"
                                    Content="&#xE74E;"
                                    ToolTip="Speichern"
                                    Style="{StaticResource TopbarCompactSuccessButtonStyle}"
                                    Command="{Binding SaveCommand}" />
                        </Grid>
                    </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                    <Grid Margin="0,0,8,0"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleButton x:Name="UserSelectionButton"
                                      Grid.Column="0"
                                      Width="40"
                                      Height="40"
                                      Click="UserSelectionButton_Click"
                                      ToolTip="{Binding CurrentUserName}"
                                      Background="{DynamicResource Brush.ButtonBackground}"
                                      BorderBrush="{DynamicResource Brush.ButtonBorder}"
                                      BorderThickness="1"
                                      Cursor="Hand"
                                      Foreground="{DynamicResource Brush.ButtonForeground}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="Root"
                                                        CornerRadius="12"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ButtonHoverBackground}" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Root" Property="Opacity" Value="0.86" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                            <TextBlock FontFamily="Segoe Fluent Icons"
                                       FontSize="16"
                                       Text="&#xE716;" />
                        </ToggleButton>
                        <Popup x:Name="UserSelectionPopup"
                               PlacementTarget="{Binding ElementName=UserSelectionButton}"
                               Placement="Custom"
                               CustomPopupPlacementCallback="CenterPopupUnderButton"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               Closed="UserSelectionPopup_Closed">
                            <Border Style="{StaticResource SoftCardStyle}"
                                    Margin="0,8,0,0"
                                    Padding="10"
                                    MinWidth="230">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Margin="0,0,0,8"
                                               Text="Benutzerprofil"
                                               HorizontalAlignment="Center" />
                                    <ComboBox Height="36"
                                              Width="170"
                                              HorizontalAlignment="Center"
                                              ItemsSource="{Binding AvailableUserNames}"
                                              SelectedItem="{Binding SelectedUserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <Button Width="40"
                            Height="40"
                            Margin="0,0,8,0"
                            Padding="0"
                            ToolTip="{Binding UndoToolTip}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding UndoCommand}">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Text="&#xE7A7;" />
                    </Button>
                    <Button Width="40"
                            Height="40"
                            Margin="0,0,8,0"
                            Padding="0"
                            ToolTip="{Binding RedoToolTip}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RedoCommand}">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Text="&#xE7A6;" />
                    </Button>
                    <Button Width="40"
                            Height="40"
                            Padding="0"
                            VerticalAlignment="Center"
                            ToolTip="Einstellungen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenSettingsCommand}">
                        <Image Width="18"
                               Height="18"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Einstellungen.png" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>



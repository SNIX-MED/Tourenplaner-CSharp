<UserControl x:Class="Tourenplaner.CSharp.App.Views.Components.DashboardTopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sections="clr-namespace:Tourenplaner.CSharp.App.ViewModels.Sections"
             mc:Ignorable="d"
             d:DesignHeight="130"
             d:DesignWidth="1400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Border Style="{StaticResource FilterBarCardStyle}" Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedNavigationItem.DisplayName}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="12"
                               Text="GAWELA Tourenplaner" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="40"
                        Height="40"
                        Margin="0,0,12,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        ToolTip="Einstellungen"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding OpenSettingsCommand}">
                    <Image Width="18"
                           Height="18"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           SnapsToDevicePixels="True"
                           Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Einstellungen.png" />
                </Button>

                <Border Grid.Column="2"
                        Style="{StaticResource SoftCardStyle}"
                        Padding="10,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="24" Height="24" CornerRadius="12" Background="{DynamicResource Brush.Accent}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Text="MW" />
                        </Border>
                        <TextBlock Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="{Binding CurrentUserName}" />
                    </StackPanel>
                </Border>
            </Grid>

            <ContentControl Grid.Row="1"
                            Margin="0,10,0,0"
                            Content="{Binding CurrentSection}"
                            Visibility="{Binding IsMapSectionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type sections:KarteSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Height="40"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"
                                         ToolTip="Ort suchen (Enter)..."
                                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        Height="40"
                                        Margin="0,0,10,0"
                                        Content="Suchen"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding RefreshCommand}" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="{Binding FilterSummaryText}" />
                            </Grid>

                            <Button Grid.Column="1"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Content="Reset"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ResetOrderFiltersCommand}" />
                            <Button Grid.Column="2"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Content="{Binding ToggleAllFiltersButtonText}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ToggleAllOrderFiltersCommand}" />
                            <Button Grid.Column="3"
                                    Height="40"
                                    Margin="0,0,10,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding OpenSplitScreenCommand}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⧉" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Split-Ansicht" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="4"
                                    Height="40"
                                    Content="Route exportieren"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding ExportRouteCommand}" />
                        </Grid>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Grid>
    </Border>
</UserControl>

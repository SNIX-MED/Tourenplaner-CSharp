<UserControl x:Class="Tourenplaner.CSharp.App.Views.Components.DashboardTopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="72"
             d:DesignWidth="1400">
    <Border Style="{StaticResource FilterBarCardStyle}" Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="170" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Text="{Binding SelectedNavigationItem.DisplayName}" />
                <TextBlock Margin="0,2,0,0"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           FontSize="12"
                           Text="GAWELA Tourenplaner" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="40"
                    Height="40"
                    Margin="0,0,12,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    ToolTip="Einstellungen"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding OpenSettingsCommand}">
                <Image Width="18"
                       Height="18"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"
                       Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Einstellungen.png" />
            </Button>

            <Border Grid.Column="2"
                    Style="{StaticResource SoftCardStyle}"
                    Padding="10,6"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="12" Background="{DynamicResource Brush.Accent}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Text="MW" />
                    </Border>
                    <TextBlock Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="{Binding CurrentUserName}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

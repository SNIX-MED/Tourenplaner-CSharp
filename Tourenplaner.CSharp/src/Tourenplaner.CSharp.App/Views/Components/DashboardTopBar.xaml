<UserControl x:Class="Tourenplaner.CSharp.App.Views.Components.DashboardTopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="72"
             d:DesignWidth="1400">
    <Border Style="{StaticResource FlatCardStyle}" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="6,0,12,0"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding SelectedNavigationItem.DisplayName}" />

            <Button Grid.Column="2"
                    Width="40"
                    Height="40"
                    Margin="0,0,10,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    ToolTip="Einstellungen"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding OpenSettingsCommand}">
                <Image Width="18"
                       Height="18"
                       Stretch="Uniform"
                       Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Einstellungen.png" />
            </Button>

            <Border Grid.Column="3" Style="{StaticResource SoftCardStyle}" Padding="8,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Brush.Accent}">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="10" FontWeight="SemiBold" Text="MW" />
                    </Border>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding CurrentUserName}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

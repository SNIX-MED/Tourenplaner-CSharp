<UserControl x:Class="Tourenplaner.CSharp.App.Views.Components.DashboardTopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sections="clr-namespace:Tourenplaner.CSharp.App.ViewModels.Sections"
             mc:Ignorable="d"
             d:DesignHeight="130"
             d:DesignWidth="1400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="TopbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.ButtonForeground}" />
            <Setter Property="Background" Value="{DynamicResource Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Padding="14">
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource FilterBarCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMapSectionActive}" Value="True">
                        <Setter Property="Effect" Value="{x:Null}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Width="22"
                        Height="64"
                        Margin="0,0,10,0"
                        Padding="0"
                        ToolTip="{Binding SidebarToggleToolTip}"
                        Command="{Binding ToggleSidebarCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Visibility" Value="{Binding IsSidebarToggleVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSidebarVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Text="{Binding SidebarToggleGlyph}" />
                </Button>
                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Text="{Binding SelectedNavigationItem.DisplayName}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="12"
                               Text="GAWELA Tourenplaner" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ContentControl Grid.Column="0"
                                Content="{Binding CurrentSection}"
                                Visibility="{Binding IsTopBarSectionControlsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type sections:KarteSectionViewModel}">
                        <Grid x:Name="MapTopBarControlsRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="130" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Height="40"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"
                                         ToolTip="Ort suchen (Enter)..."
                                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        Height="40"
                                        Margin="0,0,10,0"
                                        Content="Suchen"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding RefreshCommand}" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="{Binding FilterSummaryText}" />
                            </Grid>

                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                <ToggleButton x:Name="MapFilterPopupButton"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              IsChecked="{Binding IsMapFilterPanelVisible, Mode=TwoWay}"
                                              PreviewMouseLeftButtonDown="TogglePopupButton_PreviewMouseLeftButtonDown"
                                              Content="Filter" />
                                <Popup PlacementTarget="{Binding ElementName=MapTopBarControlsRoot}"
                                       Placement="Custom"
                                       CustomPopupPlacementCallback="CenterPopupUnderButton"
                                       StaysOpen="True"
                                       AllowsTransparency="True"
                                       IsOpen="False">
                                    <Border Style="{StaticResource SoftCardStyle}"
                                            Padding="10"
                                            Width="920"
                                            MaxHeight="360">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              Margin="0,0,18,0"
                                                              VerticalAlignment="Center"
                                                              Content="Offene Aufträge"
                                                              IsChecked="{Binding IncludeOpenOrders, Mode=TwoWay}" />
                                                    <CheckBox Grid.Column="1"
                                                              Margin="0,0,18,0"
                                                              VerticalAlignment="Center"
                                                              Content="Eingeplante Aufträge"
                                                              IsChecked="{Binding IncludePlannedOrders, Mode=TwoWay}" />
                                                    <Button Grid.Column="2"
                                                            Width="150"
                                                            Margin="0,0,10,0"
                                                            HorizontalAlignment="Right"
                                                            Content="{Binding ToggleAllFiltersButtonText}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding ToggleAllOrderFiltersCommand}" />
                                                    <Button Grid.Column="3"
                                                            Width="120"
                                                            HorizontalAlignment="Right"
                                                            Content="Filter Reset"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding ResetOrderFiltersCommand}" />
                                                </Grid>
                                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Column="0" Margin="0,0,12,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Auftragsstatus" />
                                                        <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding OrderStatusFilters}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Margin="0,0,10,6"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                    <Grid Grid.Column="1" Margin="0,0,12,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Lieferart" />
                                                        <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding DeliveryTypeFilters}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Margin="0,0,10,6"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                    <Grid Grid.Column="2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Avisierungsstatus" />
                                                        <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding AvisoStatusFilters}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Margin="0,0,10,6"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                <ToggleButton x:Name="MapLegendPopupButton"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              IsChecked="{Binding IsMapLegendPanelVisible, Mode=TwoWay}"
                                              PreviewMouseLeftButtonDown="TogglePopupButton_PreviewMouseLeftButtonDown"
                                              Content="Legende" />
                                <Popup PlacementTarget="{Binding ElementName=MapTopBarControlsRoot}"
                                       Placement="Custom"
                                       CustomPopupPlacementCallback="CenterPopupUnderButton"
                                       StaysOpen="True"
                                       AllowsTransparency="True"
                                       IsOpen="False">
                                    <Border Style="{StaticResource SoftCardStyle}"
                                            Padding="10"
                                            Width="920"
                                            MaxHeight="360">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           Text="Form = Lieferart | Farbe = Auftragsstatus | Badge = Eingeplant/Avisierungsstatus | Blaue Linie = aktuelle Route" />

                                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0" Margin="0,0,14,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Lieferart (Form)" />

                                                        <StackPanel Grid.Row="1" Margin="0,8,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18"
                                                                     Height="18"
                                                                     Fill="#0EA5E9"
                                                                     Stroke="White"
                                                                     StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Frei Bordsteinkante (Kreis)" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Border Width="18"
                                                                    Height="18"
                                                                    Background="#0EA5E9"
                                                                    BorderBrush="White"
                                                                    BorderThickness="2"
                                                                    CornerRadius="4" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Mit Verteilung (Quadrat)" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="3" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Grid Width="18" Height="18">
                                                                <Polygon Points="9,1 17,16 1,16" Fill="White" />
                                                                <Polygon Points="9,3 15,15 3,15" Fill="#0EA5E9" />
                                                            </Grid>
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Mit Verteilung &amp; Montage (Dreieck)" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Column="1" Margin="0,0,14,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Auftragsstatus (Farbe)" />

                                                        <StackPanel Grid.Row="1" Margin="0,8,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorNotSpecified}" Stroke="White" StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="nicht festgelegt" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorOrdered}" Stroke="White" StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Bestellt" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="3" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorOnTheWay}" Stroke="White" StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Unterwegs / Teilweise bereit" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="4" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorInStock}" Stroke="White" StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Lieferbereit" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Column="2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Avisierungsstatus (Badge)" />

                                                        <StackPanel Grid.Row="1" Margin="0,8,0,0" Orientation="Horizontal">
                                                            <Grid Width="22" Height="22">
                                                                <Ellipse Width="18" Height="18" Fill="#0EA5E9" Stroke="White" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                <Ellipse Width="9" Height="9" Fill="{Binding LegendAvisoBadgeColorNotAvisiert}" Stroke="White" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                                            </Grid>
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="nicht avisiert (zugeordnet)" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Grid Width="22" Height="22">
                                                                <Ellipse Width="18" Height="18" Fill="#0EA5E9" Stroke="White" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                <Ellipse Width="9" Height="9" Fill="{Binding LegendAvisoBadgeColorInformiert}" Stroke="White" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                                            </Grid>
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="informiert" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="3" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Grid Width="22" Height="22">
                                                                <Ellipse Width="18" Height="18" Fill="#0EA5E9" Stroke="White" StrokeThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                <Ellipse Width="9" Height="9" Fill="{Binding LegendAvisoBadgeColorBestaetigt}" Stroke="White" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Top" />
                                                            </Grid>
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Bestätigt" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Button Grid.Column="3"
                                    Width="64"
                                    Height="40"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    ToolTip="Schaltet die Infokarten auf der Karte ein oder aus."
                                    ToolTipService.InitialShowDelay="1500"
                                    ToolTipService.ShowDuration="8000"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding TogglePinInfoCardsCommand}">
                                <Image Width="36"
                                       Height="36"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"
                                       Source="{Binding PinInfoCardsImagePath}" />
                            </Button>
                            <Border Grid.Column="4"
                                    Height="40"
                                    Margin="0,0,8,0"
                                    Padding="10,6"
                                    CornerRadius="12"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    BorderThickness="1"
                                    Background="{DynamicResource Brush.CardSoft}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider Grid.Column="0"
                                            Minimum="0.7"
                                            Maximum="1.8"
                                            TickFrequency="0.05"
                                            IsSnapToTickEnabled="False"
                                            VerticalAlignment="Center"
                                            ToolTip="Groesse der Infokarten (Doppelklick = Standardgroesse)"
                                            PreviewMouseDoubleClick="PinInfoCardScaleSlider_PreviewMouseDoubleClick"
                                            Value="{Binding PinInfoCardScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Brush.TextMuted}"
                                               Text="{Binding PinInfoCardScalePercentText}" />
                                </Grid>
                            </Border>
                            <Button Grid.Column="5"
                                    Width="64"
                                    Height="40"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    ToolTip="Öffnet die Split-Screen Ansicht für paralleles Arbeiten."
                                    ToolTipService.InitialShowDelay="1500"
                                    ToolTipService.ShowDuration="8000"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding OpenSplitScreenCommand}">
                                <Image Width="38"
                                       Height="38"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"
                                       Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/icon-split-screen.jpg" />
                            </Button>
                            <Button Grid.Column="6"
                                    Height="40"
                                    Content="Route exportieren"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding ExportRouteCommand}" />
                        </Grid>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type sections:ToursSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontWeight="SemiBold"
                                       Text="{Binding FilterInfoText}" />

                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Text="Von" />
                                <Grid Margin="0,0,8,0">
                                    <Button x:Name="FromDateButton"
                                            Width="154"
                                            Height="36"
                                            Padding="10,0"
                                            HorizontalContentAlignment="Left"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ToggleFromDatePopupCommand}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock VerticalAlignment="Center"
                                                       Text="{Binding FromDateDisplayText}" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe Fluent Icons"
                                                       Text="&#xE787;" />
                                        </Grid>
                                    </Button>
                                    <Popup IsOpen="{Binding IsFromDatePopupOpen, Mode=TwoWay}"
                                           PlacementTarget="{Binding ElementName=FromDateButton}"
                                           Placement="Bottom"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade">
                                        <Border Margin="0,6,0,0"
                                                Padding="10"
                                                CornerRadius="14"
                                                Background="{DynamicResource Brush.Card}"
                                                BorderBrush="{DynamicResource Brush.InputBorder}"
                                                BorderThickness="1">
                                            <StackPanel Width="244">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="36" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Width="30"
                                                            Height="30"
                                                            Padding="0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            FontFamily="Segoe Fluent Icons"
                                                            Content="&#xE76B;"
                                                            Command="{Binding PreviousFromMonthCommand}" />
                                                    <Border Grid.Column="1"
                                                            Margin="8,0"
                                                            CornerRadius="10"
                                                            Background="{DynamicResource Brush.CardMuted}"
                                                            BorderBrush="{DynamicResource Brush.InputBorder}"
                                                            BorderThickness="1">
                                                        <TextBlock HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding FromMonthDisplayText}" />
                                                    </Border>
                                                    <Button Grid.Column="2"
                                                            Width="30"
                                                            Height="30"
                                                            Padding="0"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            FontFamily="Segoe Fluent Icons"
                                                            Content="&#xE76C;"
                                                            Command="{Binding NextFromMonthCommand}" />
                                                </Grid>

                                                <UniformGrid Columns="7" Margin="0,0,0,6">
                                                    <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" Text="M" />
                                                    <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" Text="D" />

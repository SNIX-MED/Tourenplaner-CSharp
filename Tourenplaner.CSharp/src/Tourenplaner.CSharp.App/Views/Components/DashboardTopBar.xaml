                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="420" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontWeight="SemiBold"
                                       Text="{Binding StatusText}" />

                            <Border Grid.Column="1"
                                    Margin="0,0,10,0"
                                    CornerRadius="13"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Brush.BorderSoft}"
                                    Background="{DynamicResource Brush.CardMuted}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Margin="4"
                                            Height="36"
                                            Content="Zugfahrzeuge"
                                            Command="{Binding ShowVehiclesCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsVehicleMode}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Margin="4"
                                            Height="36"
                                            Content="Anhänger"
                                            Command="{Binding ShowTrailersCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTrailerMode}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Margin="4"
                                            Height="36"
                                            Content="Kombinationen"
                                            Command="{Binding ShowCombinationsCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCombinationMode}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>

                            <Button Grid.Column="2"
                                    Height="38"
                                    Content="{Binding AddButtonText}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding RequestAddEntryCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:GpsSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontWeight="SemiBold"
                                       Text="{Binding StatusText}" />

                            <Button Grid.Column="1"
                                    Height="38"
                                    Content="Reload"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding RefreshCommand}" />
                            <Button Grid.Column="2"
                                    Height="38"
                                    Margin="8,0,0,0"
                                    Content="Open in Browser"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding OpenInBrowserCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:SpediteurSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontWeight="SemiBold"
                                       Text="{Binding StatusText}" />

                            <Button Grid.Column="1"
                                    Height="38"
                                    Content="Reload"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding RefreshCommand}" />
                            <Button Grid.Column="2"
                                    Height="38"
                                    Margin="8,0,0,0"
                                    Content="Open in Browser"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding OpenInBrowserCommand}" />
                        </Grid>
                    </DataTemplate>

                    <DataTemplate DataType="{x:Type sections:SettingsSectionViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{DynamicResource Brush.TextMuted}"
                                       FontWeight="SemiBold"
                                       Text="Einstellungen bearbeiten und speichern." />

                            <Button Grid.Column="1"
                                    Width="148"
                                    Height="40"
                                    Content="Speichern"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Command="{Binding SaveCommand}" />
                        </Grid>
                    </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Button Width="40"
                            Height="40"
                            Margin="0,0,8,0"
                            Padding="0"
                            ToolTip="{Binding UndoToolTip}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding UndoCommand}">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Text="&#xE7A7;" />
                    </Button>
                    <Button Width="40"
                            Height="40"
                            Margin="0,0,8,0"
                            Padding="0"
                            ToolTip="{Binding RedoToolTip}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RedoCommand}">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Text="&#xE7A6;" />
                    </Button>
                    <Button Width="40"
                            Height="40"
                            Padding="0"
                            VerticalAlignment="Center"
                            ToolTip="Einstellungen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenSettingsCommand}">
                        <Image Width="18"
                               Height="18"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               Source="pack://application:,,,/Tourenplaner.CSharp.App;component/Assets/Einstellungen.png" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>



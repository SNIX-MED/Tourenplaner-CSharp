<UserControl x:Class="Tourenplaner.CSharp.App.Views.Components.DashboardTopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Tourenplaner.CSharp.App.Views.Controls"
             xmlns:sections="clr-namespace:Tourenplaner.CSharp.App.ViewModels.Sections"
             mc:Ignorable="d"
             d:DesignHeight="130"
             d:DesignWidth="1400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="TopbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.ButtonForeground}" />
            <Setter Property="Background" Value="{DynamicResource Brush.ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.ButtonBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF7F0FF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Brush.Focus}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ButtonHoverBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopbarStatusTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="TopbarCompactButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="TopbarCompactPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="TopbarCompactSuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource SuccessButtonStyle}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="TopbarFilterSegmentHostStyle" TargetType="Border">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}" />
            <Setter Property="Background" Value="{DynamicResource Brush.CardMuted}" />
        </Style>

        <Style x:Key="TopbarFilterSegmentButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="TopbarFilterResetButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="TopbarInlineIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Brush.ButtonHoverBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopbarFilterChipLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </UserControl.Resources>

    <Border Padding="14">
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource FilterBarCardStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMapSectionActive}" Value="True">
                        <Setter Property="Effect" Value="{x:Null}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Width="22"
                        Height="40"
                        Margin="0,0,10,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        ToolTip="{Binding SidebarToggleToolTip}"
                        Command="{Binding ToggleSidebarCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Visibility" Value="{Binding IsSidebarToggleVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsSidebarVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Text="{Binding SidebarToggleGlyph}" />
                </Button>
                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding SelectedNavigationItem.DisplayName}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               FontSize="12"
                               Text="GAWELA Tourenplaner" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ContentControl Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Content="{Binding CurrentSection}"
                                Visibility="{Binding IsTopBarSectionControlsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type sections:KarteSectionViewModel}">
                        <Grid x:Name="MapTopBarControlsRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
                                  HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="300"
                                        Height="40"
                                        Margin="0,0,8,0"
                                        CornerRadius="12"
                                        BorderBrush="{DynamicResource Brush.InputBorder}"
                                        BorderThickness="1"
                                        Background="{DynamicResource Brush.InputBackground}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   FontFamily="Segoe Fluent Icons"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.TextMuted}"
                                                   Text="&#xE721;" />
                                        <Grid Grid.Column="1">
                                            <TextBox BorderThickness="0"
                                                     Background="Transparent"
                                                     ToolTip="Aufträge filtern, mit Enter auf Karte suchen"
                                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                                </TextBox.InputBindings>
                                            </TextBox>
                                            <TextBlock IsHitTestVisible="False"
                                                       Margin="2,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextSubtle}"
                                                       Text="Suche...">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                <ToggleButton x:Name="MapFilterPopupButton"
                                              Width="44"
                                              Padding="0"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              ToolTip="Filter"
                                              IsChecked="{Binding IsMapFilterPanelVisible, Mode=TwoWay}"
                                              PreviewMouseLeftButtonDown="TogglePopupButton_PreviewMouseLeftButtonDown">
                                    <Viewbox Style="{StaticResource FilterIconViewboxStyle}">
                                        <Canvas Width="24" Height="24">
                                            <Path Style="{StaticResource FilterIconPathStyle}" />
                                        </Canvas>
                                    </Viewbox>
                                </ToggleButton>
                                <Border MinWidth="18"
                                        Height="18"
                                        Margin="0,-5,-5,0"
                                        Padding="4,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        CornerRadius="9"
                                        Background="{DynamicResource Brush.Accent}"
                                        BorderBrush="White"
                                        BorderThickness="1"
                                        IsHitTestVisible="False">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasActiveFilterGroups}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{Binding ActiveFilterGroupCount}" />
                                </Border>
                                <Popup PlacementTarget="{Binding ElementName=MapTopBarControlsRoot}"
                                       Placement="Custom"
                                       CustomPopupPlacementCallback="CenterPopupUnderButton"
                                       StaysOpen="True"
                                       AllowsTransparency="True"
                                       IsOpen="False">
                                    <Border Style="{StaticResource FilterPopupPanelStyle}"
                                            Width="920"
                                            MaxHeight="360">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              Margin="0,0,18,0"
                                                              VerticalAlignment="Center"
                                                              Content="Offene Aufträge"
                                                              IsChecked="{Binding IncludeOpenOrders, Mode=TwoWay}" />
                                                    <CheckBox Grid.Column="1"
                                                              Margin="0,0,18,0"
                                                              VerticalAlignment="Center"
                                                              Content="Eingeplante Aufträge"
                                                              IsChecked="{Binding IncludePlannedOrders, Mode=TwoWay}" />
                                                    <Button Grid.Column="2"
                                                            Width="150"
                                                            Margin="0,0,10,0"
                                                            HorizontalAlignment="Right"
                                                            Content="{Binding ToggleAllFiltersButtonText}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding ToggleAllOrderFiltersCommand}" />
                                                    <Button Grid.Column="3"
                                                            Width="120"
                                                            HorizontalAlignment="Right"
                                                            Content="Filter Reset"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding ResetOrderFiltersCommand}" />
                                                </Grid>
                                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Column="0" Margin="0,0,12,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Auftragsstatus" />
                                                        <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding OrderStatusFilters}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Margin="0,0,10,6"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                    <Grid Grid.Column="1" Margin="0,0,12,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Lieferart" />
                                                        <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding DeliveryTypeFilters}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Margin="0,0,10,6"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                    <Grid Grid.Column="2" Margin="0,0,12,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Avisierungsstatus" />
                                                        <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding AvisoStatusFilters}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Margin="0,0,10,6"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                    <Grid Grid.Column="3">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Lieferant" />
                                                        <ItemsControl Grid.Row="1" Margin="0,6,0,0" ItemsSource="{Binding SupplierFilters}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox Margin="0,0,10,6"
                                                                              Content="{Binding Label}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Grid>
                                            </Grid>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Grid Grid.Column="2" Margin="0,0,8,0">
                                <ToggleButton x:Name="MapLegendPopupButton"
                                              Width="44"
                                              Padding="0"
                                              Style="{StaticResource TopbarToggleButtonStyle}"
                                              ToolTip="Legende"
                                              IsChecked="{Binding IsMapLegendPanelVisible, Mode=TwoWay}"
                                              PreviewMouseLeftButtonDown="TogglePopupButton_PreviewMouseLeftButtonDown">
                                    <Viewbox Style="{StaticResource FilterIconViewboxStyle}">
                                        <Canvas Width="24" Height="24">
                                            <Ellipse Canvas.Left="4.7"
                                                     Canvas.Top="4.8"
                                                     Width="3.8"
                                                     Height="3.8"
                                                     Fill="Transparent"
                                                     Stroke="{DynamicResource Brush.ButtonForeground}"
                                                     StrokeThickness="1.45" />
                                            <Rectangle Canvas.Left="4.9"
                                                       Canvas.Top="10.4"
                                                       Width="3.5"
                                                       Height="3.5"
                                                       RadiusX="0.8"
                                                       RadiusY="0.8"
                                                       Fill="Transparent"
                                                       Stroke="{DynamicResource Brush.ButtonForeground}"
                                                       StrokeThickness="1.45" />
                                            <Polygon Points="6.7,16.2 4.5,19.4 8.9,19.4"
                                                     Fill="Transparent"
                                                     Stroke="{DynamicResource Brush.ButtonForeground}"
                                                     StrokeThickness="1.45"
                                                     StrokeLineJoin="Round" />
                                            <Path Data="M11,6.7 L19.2,6.7 M11,12.2 L19.2,12.2 M11,18 L19.2,18"
                                                  Fill="Transparent"
                                                  Stroke="{DynamicResource Brush.ButtonForeground}"
                                                  StrokeThickness="1.45"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Viewbox>
                                </ToggleButton>
                                <Popup PlacementTarget="{Binding ElementName=MapTopBarControlsRoot}"
                                       Placement="Custom"
                                       CustomPopupPlacementCallback="CenterPopupUnderButton"
                                       StaysOpen="True"
                                       AllowsTransparency="True"
                                       IsOpen="False">
                                    <Border Style="{StaticResource SoftCardStyle}"
                                            Padding="10"
                                            Width="920"
                                            MaxHeight="360">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Foreground="{DynamicResource Brush.TextMuted}"
                                                           Text="Form = Lieferart | Farbe = Auftragsstatus | Badge = Eingeplant/Avisierungsstatus | Linie: Blau normal, Rot bei Kapazitätsreserve &lt;= Toleranz" />

                                                <Grid Grid.Row="1" Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0" Margin="0,0,14,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Lieferart (Form)" />

                                                        <StackPanel Grid.Row="1" Margin="0,8,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18"
                                                                     Height="18"
                                                                     Fill="#0EA5E9"
                                                                     Stroke="White"
                                                                     StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Frei Bordsteinkante (Kreis)" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Border Width="18"
                                                                    Height="18"
                                                                    Background="#0EA5E9"
                                                                    BorderBrush="White"
                                                                    BorderThickness="2"
                                                                    CornerRadius="4" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Mit Verteilung (Quadrat)" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="3" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Grid Width="18" Height="18">
                                                                <Polygon Points="9,1 17,16 1,16" Fill="White" />
                                                                <Polygon Points="9,3 15,15 3,15" Fill="#0EA5E9" />
                                                            </Grid>
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Mit Verteilung &amp; Montage (Dreieck)" />
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Grid.Column="1" Margin="0,0,14,0">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock FontWeight="SemiBold" Text="Auftragsstatus (Farbe)" />

                                                        <StackPanel Grid.Row="1" Margin="0,8,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorNotSpecified}" Stroke="White" StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="nicht festgelegt" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="2" Margin="0,6,0,0" Orientation="Horizontal">
                                                            <Ellipse Width="18" Height="18" Fill="{Binding LegendStatusColorOrdered}" Stroke="White" StrokeThickness="2" />
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Bestellt" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Row="3" Margin="0,6,0,0" Orientation="Horizontal">

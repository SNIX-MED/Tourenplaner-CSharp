<UserControl x:Class="Tourenplaner.CSharp.App.Views.Components.DashboardTopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="72"
             d:DesignWidth="1400">
    <Border Style="{StaticResource FlatCardStyle}" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="6,0,12,0"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="{Binding SelectedNavigationItem.DisplayName}" />

            <TextBox Grid.Column="1"
                     Height="36"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     ToolTip="Ort suchen (Enter)..."
                     Text="{Binding GlobalSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Column="2" Height="36" Margin="0,0,10,0" Content="Suchen" Style="{StaticResource PrimaryButtonStyle}" />

            <Border Grid.Column="3" Style="{StaticResource SoftCardStyle}" Padding="8,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Brush.Accent}">
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="10" FontWeight="SemiBold" Text="MW" />
                    </Border>
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding CurrentUserName}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>

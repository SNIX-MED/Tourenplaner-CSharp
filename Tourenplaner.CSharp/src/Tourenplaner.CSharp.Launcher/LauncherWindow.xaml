<Window x:Class="Tourenplaner.CSharp.Launcher.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GAWELA Tourenplaner"
        Width="480"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Icon="Assets/Applogo.png">
    <Border CornerRadius="26"
            Background="#FFF8FAFC"
            BorderBrush="#220F172A"
            BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center">
                <Border Width="96"
                        Height="96"
                        CornerRadius="24"
                        Background="#FFFFFFFF"
                        BorderBrush="#140F172A"
                        BorderThickness="1"
                        HorizontalAlignment="Left">
                    <Image Source="Assets/Applogo.png"
                           Width="62"
                           Height="62"
                           Stretch="Uniform" />
                </Border>

                <TextBlock Margin="0,20,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#FF0F766E"
                           Text="GAWELA LOGISTIK" />
                <TextBlock Margin="0,10,0,0"
                           FontSize="31"
                           FontWeight="SemiBold"
                           Foreground="#FF0F172A"
                           Text="Tourenplaner" />
                <TextBlock x:Name="StatusTextBlock"
                           Margin="0,14,0,0"
                           FontSize="15"
                           Foreground="#FF475569"
                           Text="Anwendung wird gestartet..." />
            </StackPanel>

            <ProgressBar Grid.Row="1"
                         Height="8"
                         IsIndeterminate="True"
                         Foreground="#FF0F766E"
                         Background="#140F172A"
                         BorderThickness="0" />
        </Grid>
    </Border>
</Window>
